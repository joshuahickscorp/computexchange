<?xml version="1.0" encoding="utf-8"?>
<!--
  Sample Sparkle appcast for ComputeExchangeAgent.

  This is the feed the app polls (Info.plist SUFeedURL). Host it at the SUFeedURL
  you set, over HTTPS. Each <item> describes one release; Sparkle compares
  sparkle:version (CFBundleVersion) against the running app and offers an update
  when the feed has a newer one.

  HONESTY / SECURITY (BLACKHOLE): the `sparkle:edSignature` on each <enclosure> is
  an EdDSA (ed25519) signature of THAT zip, produced by the OWNER's private key
  (Sparkle's `sign_update` tool, run by macapp/sign-notarize.sh when SPARKLE_KEY is
  set). Sparkle verifies it against the SUPublicEDKey embedded in the app's
  Info.plist and REFUSES to install if it does not match. The placeholder signature
  below is NOT valid · replace it with the real one printed at sign time, or the
  update will be (correctly) rejected. Do not ship a placeholder.

  Per release, replace: version numbers, the enclosure url + length (bytes of the
  zip), the edSignature, the pubDate, and the release notes.
-->
<rss version="2.0" xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle" xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>ComputeExchangeAgent</title>
    <link>https://updates.computexchange.net/appcast.xml</link>
    <description>Auto-update feed for the Computexchange supplier menu-bar app.</description>
    <language>en</language>

    <item>
      <title>Version 0.1.0</title>
      <pubDate>Mon, 29 Jun 2026 12:00:00 +0000</pubDate>
      <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
      <description><![CDATA[
        <ul>
          <li>First signed, notarized release of the supplier menu-bar app.</li>
          <li>Live agent status, earnings, thermal and memory telemetry.</li>
          <li>First-run consent gate; earnings sparkline, payout proof, and an
              honest verification badge.</li>
        </ul>
      ]]></description>
      <enclosure
        url="https://updates.computexchange.net/releases/ComputeExchangeAgent-0.1.0.zip"
        sparkle:version="0.1.0"
        sparkle:shortVersionString="0.1.0"
        sparkle:edSignature="REPLACE_WITH_REAL_ED25519_SIGNATURE_FROM_sign_update"
        length="0"
        type="application/octet-stream" />
    </item>
  </channel>
</rss>
