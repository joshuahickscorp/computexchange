<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Bundle Info.plist for the menu-bar app. LSUIElement = no Dock icon / agent app.
     Used when assembling the .app bundle (Xcode or a manual bundle); the signing +
     notarization that make it distributable are the external step. -->
<plist version="1.0">
<dict>
  <key>CFBundleName</key><string>ComputeExchangeAgent</string>
  <key>CFBundleDisplayName</key><string>Computexchange</string>
  <key>CFBundleIdentifier</key><string>dev.computeexchange.agent.menubar</string>
  <key>CFBundleExecutable</key><string>ComputeExchangeAgent</string>
  <key>CFBundlePackageType</key><string>APPL</string>
  <key>CFBundleVersion</key><string>0.1.0</string>
  <key>CFBundleShortVersionString</key><string>0.1.0</string>
  <key>LSUIElement</key><true/>
  <key>LSMinimumSystemVersion</key><string>13.0</string>
  <key>NSHumanReadableCopyright</key><string>Computexchange</string>
</dict>
</plist>
