<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Bundle Info.plist for the menu-bar app. LSUIElement = no Dock icon / agent app.
     Used when assembling the .app bundle (Xcode or a manual bundle); the signing +
     notarization that make it distributable are the external step. -->
<plist version="1.0">
<dict>
  <key>CFBundleName</key><string>ComputeExchangeAgent</string>
  <key>CFBundleDisplayName</key><string>Computexchange</string>
  <key>CFBundleIdentifier</key><string>dev.computeexchange.agent.menubar</string>
  <key>CFBundleExecutable</key><string>ComputeExchangeAgent</string>
  <key>CFBundlePackageType</key><string>APPL</string>
  <key>CFBundleVersion</key><string>0.1.0</string>
  <key>CFBundleShortVersionString</key><string>0.1.0</string>
  <key>LSUIElement</key><true/>
  <key>LSMinimumSystemVersion</key><string>13.0</string>
  <key>NSHumanReadableCopyright</key><string>Computexchange</string>

  <!-- Sparkle auto-update.
       SUFeedURL    : the appcast the app polls for updates. Replace the host with
                      your real release host before shipping. Must be HTTPS so the
                      feed itself cannot be tampered with in transit.
       SUPublicEDKey: the EdDSA (ed25519) PUBLIC key. OWNER STEP · generate the key
                      pair once with Sparkle's `generate_keys` tool (it stores the
                      PRIVATE key in your login keychain) and paste the printed
                      public key here. Sparkle refuses to install any update whose
                      appcast entry is not signed by the matching private key, so an
                      empty/placeholder value here means NO update can install · an
                      honest fail-closed default, never a silent unsigned install.
       SUEnableAutomaticChecks: background update checks on by default. -->
  <key>SUFeedURL</key><string>https://updates.computexchange.net/appcast.xml</string>
  <key>SUPublicEDKey</key><string>REPLACE_WITH_YOUR_SPARKLE_ED25519_PUBLIC_KEY</string>
  <key>SUEnableAutomaticChecks</key><true/>
  <key>SUScheduledCheckInterval</key><integer>86400</integer>
</dict>
</plist>
