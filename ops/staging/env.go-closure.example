# Copy to the repository root as .env.go-closure, fill it through the approved
# secret channel, and chmod 600. This template contains no working credentials.

# Exact external inputs are declared in ops/go-closure-inputs.json.
STAGING_SSH_TARGET=deploy-user@staging.example.invalid
STAGING_TLS_HOSTNAME=canary.example.invalid
STAGING_DEPLOYMENT_ROOT=/srv/computexchange-go-closure
CX_BACKUP_OFFSITE=s3://private-staging-backups/computexchange
AWS_ACCESS_KEY_ID=REPLACE_VIA_SECRET_CHANNEL
AWS_SECRET_ACCESS_KEY=REPLACE_VIA_SECRET_CHANNEL
CX_BACKUP_ENCRYPTION_RECIPIENT=age1REPLACE_WITH_PUBLIC_RECIPIENT
CX_BACKUP_DECRYPTION_IDENTITY_FILE=/secure/path/staging-backup-identity.txt
STRIPE_SECRET_KEY=sk_test_REPLACE_VIA_SECRET_CHANNEL
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_VIA_SECRET_CHANNEL
CX_CONNECT_WEBHOOK_SECRET=whsec_REPLACE_WITH_DISTINCT_SECRET
CX_CONNECT_CLIENT_ID=ca_REPLACE_WITH_TEST_PLATFORM_ID
STRIPE_TEST_CONNECTED_ACCOUNT_ID=acct_REPLACE_WITH_TEST_ACCOUNT
ALERT_RECEIVER_WEBHOOK_URL=https://receiver.example.invalid/private-path
ALERT_RECEIVER_NAME=REPLACE_WITH_RECEIVER_NAME

# Immutable release outputs. Every image value must contain @sha256:<64 hex>.
CX_CANDIDATE_CONTROL_IMAGE=ghcr.io/OWNER/computexchange-control@sha256:REPLACE_64_HEX
CX_CANDIDATE_COMMIT=REPLACE_40_HEX
CX_PRIOR_CONTROL_IMAGE=ghcr.io/OWNER/computexchange-control@sha256:REPLACE_64_HEX
CX_PRIOR_COMMIT=REPLACE_40_HEX
CX_PROMETHEUS_IMAGE=quay.io/prometheus/prometheus@sha256:REPLACE_64_HEX
CX_ALERTMANAGER_IMAGE=quay.io/prometheus/alertmanager@sha256:REPLACE_64_HEX
CX_GRAFANA_IMAGE=docker.io/grafana/grafana@sha256:REPLACE_64_HEX
CX_NODE_EXPORTER_IMAGE=quay.io/prometheus/node-exporter@sha256:REPLACE_64_HEX

# Persistent TLS and application secrets/configuration.
STAGING_STORAGE_TLS_HOSTNAME=storage.canary.example.invalid
STAGING_BIND_ADDRESS=192.0.2.10
ACME_EMAIL=staging-operator@example.invalid
POSTGRES_PASSWORD=REPLACE_VIA_SECRET_CHANNEL
MINIO_ROOT_USER=REPLACE_VIA_SECRET_CHANNEL
MINIO_ROOT_PASSWORD=REPLACE_VIA_SECRET_CHANNEL
GF_SECURITY_ADMIN_PASSWORD=REPLACE_VIA_SECRET_CHANNEL
CX_TOKEN_KEY=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
CX_VERIFICATION_SAMPLE_SECRET=REPLACE_WITH_DISTINCT_32_RANDOM_BYTES

# The compose manifest fixes the reviewed economic schedule and every canary
# ceiling. Only the two project-controlled participant allowlists are external.
CX_CANARY_APPROVED_BUYER_EMAILS=buyer-one@example.invalid,buyer-two@example.invalid
CX_CANARY_APPROVED_WORKER_IDS=REPLACE_UUID_ONE,REPLACE_UUID_TWO
CX_CANARY_APPROVED_AGENT_VERSIONS=REPLACE_REVIEWED_SEMVER
CX_CANARY_APPROVED_BUILD_HASHES=REPLACE_16_HEX_ONE,REPLACE_16_HEX_TWO

# Rehearsal adapters. The referenced executables run on the staging host and
# must return the strict JSON receipts described in ops/staging/README.md.
CX_CANARY_SCENARIO_DRIVER=/srv/computexchange-drivers/canary-scenario-driver
CX_AGENT_RESTART_DRIVER=/srv/computexchange-drivers/agent-restart-driver

# Optional bounded thresholds.
CX_SOAK_MAX_RSS_GROWTH_BYTES=134217728
CX_SOAK_MAX_DISK_GROWTH_KB=1048576
CX_REHEARSAL_NETWORK_INTERRUPTION_SECONDS=5
