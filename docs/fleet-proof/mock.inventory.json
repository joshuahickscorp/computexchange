{
  "schema_version": 1,
  "name": "local-four-node-contract-proof",
  "requirements": {
    "min_total_nodes": 4,
    "min_distinct_workers": 4,
    "min_distinct_machines": 4,
    "substrates": {
      "apple": 2,
      "cuda": 2
    },
    "lanes": {
      "cuda_vllm": 2,
      "metal_candle": 2
    },
    "min_receipts_per_node": 1,
    "require_artifact_sha256": true,
    "require_verification_class": true,
    "require_settlement": true
  },
  "readiness": {
    "attempts": 2,
    "poll_interval_seconds": 0,
    "command_timeout_seconds": 5
  },
  "collection": {
    "attempts": 2,
    "poll_interval_seconds": 0,
    "command_timeout_seconds": 5
  },
  "nodes": [
    {
      "id": "apple-m3pro",
      "substrate": "apple",
      "lane": "metal_candle",
      "provider": {
        "kind": "owned",
        "resource_id": "mock-apple-m3pro-physical",
        "ephemeral": false
      },
      "transport": {
        "kind": "mock"
      },
      "expect": {
        "engine": "candle",
        "hardware_class": "apple_silicon_pro",
        "build_hash": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
      },
      "mock": {
        "ready": {
          "schema_version": 1,
          "ok": true,
          "node_id": "apple-m3pro",
          "machine_id": "mock-machine-apple-m3pro",
          "provider_resource_id": "mock-apple-m3pro-physical",
          "worker_id": "11111111-1111-4111-8111-111111111111",
          "substrate": "apple",
          "lane": "metal_candle",
          "engine": "candle",
          "build_hash": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "hardware_class": "apple_silicon_pro"
        }
      }
    },
    {
      "id": "apple-studio",
      "substrate": "apple",
      "lane": "metal_candle",
      "provider": {
        "kind": "owned",
        "resource_id": "mock-apple-studio-physical",
        "ephemeral": false
      },
      "transport": {
        "kind": "mock"
      },
      "expect": {
        "engine": "candle",
        "hardware_class": "apple_silicon_max",
        "build_hash": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
      },
      "mock": {
        "ready": {
          "schema_version": 1,
          "ok": true,
          "node_id": "apple-studio",
          "machine_id": "mock-machine-apple-studio",
          "provider_resource_id": "mock-apple-studio-physical",
          "worker_id": "22222222-2222-4222-8222-222222222222",
          "substrate": "apple",
          "lane": "metal_candle",
          "engine": "candle",
          "build_hash": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
          "hardware_class": "apple_silicon_max"
        }
      }
    },
    {
      "id": "cuda-pod-a",
      "substrate": "cuda",
      "lane": "cuda_vllm",
      "provider": {
        "kind": "runpod",
        "resource_id": "mock-runpod-a",
        "ephemeral": true,
        "cleanup": {
          "kind": "runpod_api",
          "api_key_env": "RUNPOD_API_KEY"
        }
      },
      "transport": {
        "kind": "mock"
      },
      "expect": {
        "engine": "vllm",
        "hardware_class": "nvidia_80g",
        "build_hash": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
      },
      "mock": {
        "ready": {
          "schema_version": 1,
          "ok": true,
          "node_id": "cuda-pod-a",
          "machine_id": "mock-gpu-uuid-a",
          "provider_resource_id": "mock-runpod-a",
          "worker_id": "33333333-3333-4333-8333-333333333333",
          "substrate": "cuda",
          "lane": "cuda_vllm",
          "engine": "vllm",
          "build_hash": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
          "hardware_class": "nvidia_80g"
        }
      }
    },
    {
      "id": "cuda-pod-b",
      "substrate": "cuda",
      "lane": "cuda_vllm",
      "provider": {
        "kind": "runpod",
        "resource_id": "mock-runpod-b",
        "ephemeral": true,
        "cleanup": {
          "kind": "runpod_api",
          "api_key_env": "RUNPOD_API_KEY"
        }
      },
      "transport": {
        "kind": "mock"
      },
      "expect": {
        "engine": "vllm",
        "hardware_class": "nvidia_80g",
        "build_hash": "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"
      },
      "mock": {
        "ready": {
          "schema_version": 1,
          "ok": true,
          "node_id": "cuda-pod-b",
          "machine_id": "mock-gpu-uuid-b",
          "provider_resource_id": "mock-runpod-b",
          "worker_id": "44444444-4444-4444-8444-444444444444",
          "substrate": "cuda",
          "lane": "cuda_vllm",
          "engine": "vllm",
          "build_hash": "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd",
          "hardware_class": "nvidia_80g"
        }
      }
    }
  ],
  "workflow": {
    "mock": {
      "submit": {
        "schema_version": 1,
        "ok": true,
        "proof_run_id": "${CX_FLEET_PROOF_RUN_ID}",
        "workload_id": "mock-mixed-lane-workload",
        "job_ids": [
          "mock-job-apple",
          "mock-job-cuda"
        ]
      },
      "collect": {
        "schema_version": 1,
        "ok": true,
        "proof_run_id": "${CX_FLEET_PROOF_RUN_ID}",
        "workload_id": "mock-mixed-lane-workload",
        "receipts": [
          {
            "job_id": "mock-job-apple",
            "task_id": "mock-task-apple-m3pro",
            "worker_id": "11111111-1111-4111-8111-111111111111",
            "status": "complete",
            "artifact_sha256": "1111111111111111111111111111111111111111111111111111111111111111",
            "verification_class": "candle|aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
            "settled": true
          },
          {
            "job_id": "mock-job-apple",
            "task_id": "mock-task-apple-studio",
            "worker_id": "22222222-2222-4222-8222-222222222222",
            "status": "complete",
            "artifact_sha256": "2222222222222222222222222222222222222222222222222222222222222222",
            "verification_class": "candle|bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
            "settled": true
          },
          {
            "job_id": "mock-job-cuda",
            "task_id": "mock-task-cuda-a",
            "worker_id": "33333333-3333-4333-8333-333333333333",
            "status": "complete",
            "artifact_sha256": "3333333333333333333333333333333333333333333333333333333333333333",
            "verification_class": "vllm|cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
            "settled": true
          },
          {
            "job_id": "mock-job-cuda",
            "task_id": "mock-task-cuda-b",
            "worker_id": "44444444-4444-4444-8444-444444444444",
            "status": "complete",
            "artifact_sha256": "4444444444444444444444444444444444444444444444444444444444444444",
            "verification_class": "vllm|dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd",
            "settled": true
          }
        ]
      },
      "cleanup_rc": 0
    }
  }
}
