{
  "schema_version": 1,
  "name": "physical-two-apple-two-cuda-proof",
  "requirements": {
    "min_total_nodes": 4,
    "min_distinct_workers": 4,
    "min_distinct_machines": 4,
    "substrates": {
      "apple": 2,
      "cuda": 2
    },
    "lanes": {
      "cuda_vllm": 2,
      "metal_candle": 2
    },
    "min_receipts_per_node": 1,
    "require_artifact_sha256": true,
    "require_verification_class": true,
    "require_settlement": true
  },
  "readiness": {
    "attempts": 30,
    "poll_interval_seconds": 5,
    "command_timeout_seconds": 30
  },
  "collection": {
    "attempts": 120,
    "poll_interval_seconds": 5,
    "command_timeout_seconds": 60
  },
  "nodes": [
    {
      "id": "apple-m3pro",
      "substrate": "apple",
      "lane": "metal_candle",
      "provider": {
        "kind": "owned",
        "resource_id": "REPLACE_WITH_M3PRO_PLATFORM_UUID",
        "ephemeral": false
      },
      "transport": {
        "kind": "ssh",
        "target": "REPLACE_WITH_M3PRO_SSH_ALIAS",
        "host_key_policy": "strict"
      },
      "expect": {
        "engine": "candle",
        "hardware_class": "apple_silicon_pro",
        "build_hash": "REPLACE_WITH_M3PRO_AGENT_BUILD_HASH"
      },
      "commands": {
        "start": "REPLACE_WITH_IDEMPOTENT_M3PRO_AGENT_START_COMMAND",
        "ready": "REPLACE_WITH_M3PRO_READINESS_JSON_COMMAND",
        "cleanup": "REPLACE_WITH_M3PRO_AGENT_STOP_COMMAND"
      }
    },
    {
      "id": "apple-studio",
      "substrate": "apple",
      "lane": "metal_candle",
      "provider": {
        "kind": "owned",
        "resource_id": "REPLACE_WITH_STUDIO_PLATFORM_UUID",
        "ephemeral": false
      },
      "transport": {
        "kind": "ssh",
        "target": "REPLACE_WITH_STUDIO_SSH_ALIAS",
        "host_key_policy": "strict"
      },
      "expect": {
        "engine": "candle",
        "hardware_class": "apple_silicon_max",
        "build_hash": "REPLACE_WITH_STUDIO_AGENT_BUILD_HASH"
      },
      "commands": {
        "start": "REPLACE_WITH_IDEMPOTENT_STUDIO_AGENT_START_COMMAND",
        "ready": "REPLACE_WITH_STUDIO_READINESS_JSON_COMMAND",
        "cleanup": "REPLACE_WITH_STUDIO_AGENT_STOP_COMMAND"
      }
    },
    {
      "id": "cuda-pod-a",
      "substrate": "cuda",
      "lane": "cuda_vllm",
      "provider": {
        "kind": "runpod",
        "resource_id": "REPLACE_WITH_RUNPOD_A_POD_ID",
        "ephemeral": true,
        "cleanup": {
          "kind": "runpod_api",
          "api_key_env": "RUNPOD_API_KEY"
        }
      },
      "transport": {
        "kind": "ssh",
        "target": "REPLACE_WITH_RUNPOD_A_USER_AT_IP",
        "port": 22,
        "identity_file": "~/.ssh/id_ed25519",
        "host_key_policy": "accept-new",
        "connect_timeout_seconds": 12
      },
      "expect": {
        "engine": "vllm",
        "hardware_class": "nvidia_80g",
        "build_hash": "REPLACE_WITH_CUDA_A_AGENT_BUILD_HASH"
      },
      "commands": {
        "start": "REPLACE_WITH_IDEMPOTENT_CUDA_A_AGENT_AND_VLLM_START_COMMAND",
        "ready": "REPLACE_WITH_CUDA_A_READINESS_JSON_COMMAND",
        "cleanup": "REPLACE_WITH_CUDA_A_AGENT_AND_VLLM_STOP_COMMAND"
      }
    },
    {
      "id": "cuda-pod-b",
      "substrate": "cuda",
      "lane": "cuda_vllm",
      "provider": {
        "kind": "runpod",
        "resource_id": "REPLACE_WITH_RUNPOD_B_POD_ID",
        "ephemeral": true,
        "cleanup": {
          "kind": "runpod_api",
          "api_key_env": "RUNPOD_API_KEY"
        }
      },
      "transport": {
        "kind": "ssh",
        "target": "REPLACE_WITH_RUNPOD_B_USER_AT_IP",
        "port": 22,
        "identity_file": "~/.ssh/id_ed25519",
        "host_key_policy": "accept-new",
        "connect_timeout_seconds": 12
      },
      "expect": {
        "engine": "vllm",
        "hardware_class": "nvidia_80g",
        "build_hash": "REPLACE_WITH_CUDA_B_AGENT_BUILD_HASH"
      },
      "commands": {
        "start": "REPLACE_WITH_IDEMPOTENT_CUDA_B_AGENT_AND_VLLM_START_COMMAND",
        "ready": "REPLACE_WITH_CUDA_B_READINESS_JSON_COMMAND",
        "cleanup": "REPLACE_WITH_CUDA_B_AGENT_AND_VLLM_STOP_COMMAND"
      }
    }
  ],
  "workflow": {
    "commands": {
      "submit": "REPLACE_WITH_LOCAL_MIXED_LANE_SUBMIT_COMMAND",
      "collect": "REPLACE_WITH_LOCAL_RECEIPT_COLLECTOR_COMMAND",
      "cleanup": "REPLACE_WITH_LOCAL_UNFINISHED_JOB_CANCEL_COMMAND"
    }
  }
}
