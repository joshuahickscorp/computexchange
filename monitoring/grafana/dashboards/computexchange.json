{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Computexchange · Control Plane",
  "uid": "cx-control-plane",
  "tags": ["computexchange"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Ticker · seconds since last successful cycle",
      "description": "cx_ticker_seconds_since_success. >300s == WEDGED (see alerts.yml).",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 120 },
            { "color": "red", "value": 300 }
          ] }
        }
      },
      "targets": [
        { "expr": "max by (instance) (cx_ticker_seconds_since_success)", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Active workers",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "targets": [ { "expr": "sum(cx_active_workers)" } ]
    },
    {
      "type": "stat",
      "title": "Instances up",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [
        { "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 2 }
      ] } } },
      "targets": [ { "expr": "sum(up{job=\"control\"})" } ]
    },
    {
      "type": "timeseries",
      "title": "Queue depth by tier / job_type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [ { "expr": "cx_queue_depth", "legendFormat": "{{tier}}/{{job_type}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Throughput (rate /5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        { "expr": "rate(cx_jobs_submitted_total[5m])", "legendFormat": "submitted" },
        { "expr": "rate(cx_tasks_dispatched_total[5m])", "legendFormat": "dispatched" },
        { "expr": "rate(cx_tasks_completed_total[5m])", "legendFormat": "completed" },
        { "expr": "rate(cx_payouts_released_total[5m])", "legendFormat": "payouts released" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Edge HTTP responses by code (Caddy)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "targets": [ { "expr": "sum by (code) (rate(caddy_http_requests_total[5m]))", "legendFormat": "{{code}}" } ]
    },
    {
      "type": "timeseries",
      "title": "5xx ratio",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [ { "expr": "sum(rate(caddy_http_requests_total{code=~\"5..\"}[5m])) / sum(rate(caddy_http_requests_total[5m]))", "legendFormat": "5xx %" } ]
    },
    {
      "type": "timeseries",
      "title": "Fraud / integrity signals (rate /5m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "targets": [
        { "expr": "rate(cx_verification_mismatch_total[5m])", "legendFormat": "mismatch" },
        { "expr": "rate(cx_quarantines_total[5m])", "legendFormat": "quarantines" },
        { "expr": "rate(cx_task_failures_total[5m])", "legendFormat": "task failures" }
      ]
    },
    {
      "type": "timeseries",
      "title": "TLS cert days until expiry",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "d" } },
      "targets": [ { "expr": "(probe_ssl_earliest_cert_expiry - time()) / 86400", "legendFormat": "{{instance}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Container memory vs limit",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 29 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "container_memory_usage_bytes{name=~\"computexchange.*\"}", "legendFormat": "{{name}}" }
      ]
    }
  ]
}
