From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: CX Spec Lab <spec-lab@computexchange.local>
Date: Thu, 9 Jul 2026 14:05:00 -0400
Subject: [PATCH] standalone: expose CX crop buffer CLI

Expose a minimal standalone Cycles crop primitive for selective tile
refinement. The flag renders a small output buffer while preserving the
camera's full-frame resolution and offsetting kernel work through
BufferParams::full_x/full_y.

Usage:

  --cx-crop X,Y,W,H,FULL_W,FULL_H

The X/Y coordinates are Cycles full-buffer coordinates, where Y is the
bottom-up render-buffer coordinate. Callers that work in top-left image
coordinates should pass Y = FULL_H - (image_y0 + H).
---
 src/app/cycles_standalone.cpp | 69 +++++++++++++++++++++++++++++++++--
 1 file changed, 66 insertions(+), 3 deletions(-)

diff --git a/src/app/cycles_standalone.cpp b/src/app/cycles_standalone.cpp
index eb736a9e..3b90e443 100644
--- a/src/app/cycles_standalone.cpp
+++ b/src/app/cycles_standalone.cpp
@@ -52,6 +52,13 @@ struct Options {
   string output_pass;
   bool disable_adaptive_sampling;
   string cx_batch_manifest;
+  bool cx_crop_enabled;
+  int cx_crop_x;
+  int cx_crop_y;
+  int cx_crop_width;
+  int cx_crop_height;
+  int cx_crop_full_width;
+  int cx_crop_full_height;
 } options;
 
 struct CXBatchJob {
@@ -102,8 +109,15 @@ static BufferParams &session_buffer_params()
   static BufferParams buffer_params;
   buffer_params.width = options.width;
   buffer_params.height = options.height;
-  buffer_params.full_width = options.width;
-  buffer_params.full_height = options.height;
+  buffer_params.full_x = options.cx_crop_enabled ? options.cx_crop_x : 0;
+  buffer_params.full_y = options.cx_crop_enabled ? options.cx_crop_y : 0;
+  buffer_params.full_width = options.cx_crop_enabled ? options.cx_crop_full_width :
+                                                        options.width;
+  buffer_params.full_height = options.cx_crop_enabled ? options.cx_crop_full_height :
+                                                         options.height;
+  buffer_params.window_x = 0;
+  buffer_params.window_y = 0;
+  buffer_params.update_offset_stride();
 
   return buffer_params;
 }
@@ -127,10 +141,14 @@ static void scene_init()
     options.scene->integrator->set_use_adaptive_sampling(false);
   }
 
+  const int camera_width = options.cx_crop_enabled ? options.cx_crop_full_width : options.width;
+  const int camera_height = options.cx_crop_enabled ? options.cx_crop_full_height :
+                                                      options.height;
+
   /* Camera width/height override? */
-  if (!(options.width == 0 || options.height == 0)) {
-    options.scene->camera->set_full_width(options.width);
-    options.scene->camera->set_full_height(options.height);
+  if (!(camera_width == 0 || camera_height == 0)) {
+    options.scene->camera->set_full_width(camera_width);
+    options.scene->camera->set_full_height(camera_height);
   }
   else {
     options.width = options.scene->camera->get_full_width();
@@ -473,6 +491,46 @@ static void parse_string(OIIO::cspan<const char *> argv, std::string *s)
   *s = argv[1];
 }
 
+static void parse_cx_crop(OIIO::cspan<const char *> argv)
+{
+  assert(argv.size() == 2);
+  vector<string> tokens;
+  string_split(tokens, argv[1], ",", true);
+  if (tokens.size() != 6) {
+    fprintf(stderr, "Invalid --cx-crop: expected X,Y,W,H,FULL_W,FULL_H\n");
+    exit(EXIT_FAILURE);
+  }
+
+  int values[6];
+  for (int i = 0; i < 6; i++) {
+    values[i] = atoi(tokens[i].c_str());
+  }
+
+  const int x = values[0];
+  const int y = values[1];
+  const int width = values[2];
+  const int height = values[3];
+  const int full_width = values[4];
+  const int full_height = values[5];
+
+  if (x < 0 || y < 0 || width <= 0 || height <= 0 || full_width <= 0 ||
+      full_height <= 0 || x + width > full_width || y + height > full_height)
+  {
+    fprintf(stderr, "Invalid --cx-crop bounds: %s\n", argv[1]);
+    exit(EXIT_FAILURE);
+  }
+
+  options.cx_crop_enabled = true;
+  options.cx_crop_x = x;
+  options.cx_crop_y = y;
+  options.cx_crop_width = width;
+  options.cx_crop_height = height;
+  options.cx_crop_full_width = full_width;
+  options.cx_crop_full_height = full_height;
+  options.width = width;
+  options.height = height;
+}
+
 static void options_parse(const int argc, const char **argv)
 {
   options.width = 1024;
@@ -480,6 +538,7 @@ static void options_parse(const int argc, const char **argv)
   options.filepath = "";
   options.session = nullptr;
   options.quiet = false;
+  options.cx_crop_enabled = false;
   options.session_params.use_auto_tile = false;
   options.session_params.tile_size = 0;
 
@@ -537,6 +596,9 @@ static void options_parse(const int argc, const char **argv)
   ap.arg("--cx-batch-manifest %s:MANIFEST")
       .help("Run CX batch manifest lines: OUTPUT SAMPLES OFFSET LENGTH")
       .action([&](auto argv) { parse_string(argv, &options.cx_batch_manifest); });
+  ap.arg("--cx-crop %s:X,Y,W,H,FULL_W,FULL_H")
+      .help("Render a CX crop in Cycles full-frame buffer coordinates")
+      .action([&](auto argv) { parse_cx_crop(argv); });
 
   ap.arg("--output %s:OUTPUT").help("File path to write output image").action([&](auto argv) {
     parse_string(argv, &options.output_filepath);
@@ -609,6 +671,12 @@ static void options_parse(const int argc, const char **argv)
   if (options.session_params.tile_size > 0) {
     options.session_params.use_auto_tile = true;
   }
+  if (options.cx_crop_enabled) {
+    /* Keep crop dimensions authoritative regardless of CLI argument order. */
+    options.width = options.cx_crop_width;
+    options.height = options.cx_crop_height;
+    options.session_params.use_auto_tile = false;
+  }
 
   /* find matching device */
   const DeviceType device_type = Device::type_from_string(devicename.c_str());
-- 
