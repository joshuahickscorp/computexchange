From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: CX Spec Lab <spec-lab@computexchange.local>
Date: Tue, 7 Jul 2026 23:55:00 -0400
Subject: [PATCH] device: skip OIDN CUDA probe by default

OpenImageDenoise's CUDA device-support probe can load
libOpenImageDenoise_device_cuda during Cycles device enumeration. On the
RunPod L40S runtime this segfaults after CUDA itself has already opened
/dev/nvidia0, preventing standalone Cycles from listing or selecting CUDA
devices at all.

For CX, render-device availability is more important than advertising the
OIDN GPU denoiser bit during enumeration. Keep the probe available behind an
explicit environment variable, but make the stable default skip it.
---
 src/device/cuda/device.cpp | 9 +++++++--
 1 file changed, 7 insertions(+), 2 deletions(-)

diff --git a/src/device/cuda/device.cpp b/src/device/cuda/device.cpp
index 0000000000..0000000000 100644
--- a/src/device/cuda/device.cpp
+++ b/src/device/cuda/device.cpp
@@ -4,6 +4,8 @@
 
 #include "device/cuda/device.h"
 #include "device/device.h"
+
+#include <cstdlib>
 
 #include "util/log.h"
 
@@ -168,12 +170,15 @@ void device_cuda_info(vector<DeviceInfo> &devices)
                             (unsigned int)pci_location[2]);
 
 #  if defined(WITH_OPENIMAGEDENOISE)
+    const bool cx_probe_oidn_cuda = getenv("CX_CYCLES_PROBE_OIDN_CUDA") != nullptr;
+    if (cx_probe_oidn_cuda) {
 #    if OIDN_VERSION >= 20300
-    if (oidnIsCUDADeviceSupported(num)) {
+      if (oidnIsCUDADeviceSupported(num)) {
 #    else
-    if (OIDNDenoiserGPU::is_device_supported(info)) {
+      if (OIDNDenoiserGPU::is_device_supported(info)) {
 #    endif
-      info.denoisers |= DENOISER_OPENIMAGEDENOISE;
+        info.denoisers |= DENOISER_OPENIMAGEDENOISE;
+      }
     }
 #  endif
 
