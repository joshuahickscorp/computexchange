From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: CX Spec Lab <spec-lab@computexchange.local>
Date: Tue, 7 Jul 2026 23:10:00 -0400
Subject: [PATCH] standalone: expose sample subset CLI controls

Expose Cycles' existing SessionParams sample-subset controls in the
standalone binary. This gives CX a stable, minimal fork hook for exact
sample-range fan-out experiments without going through Blender.
---
 src/app/cycles_standalone.cpp | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/src/app/cycles_standalone.cpp b/src/app/cycles_standalone.cpp
index 0000000000..0000000000 100644
--- a/src/app/cycles_standalone.cpp
+++ b/src/app/cycles_standalone.cpp
@@ -424,6 +424,14 @@ static void options_parse(const int argc, const char **argv)
   ap.arg("--samples %d:SAMPLES").help("Number of samples to render").action([&](auto argv) {
     parse_int(argv, &options.session_params.samples);
   });
+  ap.arg("--sample-subset-offset %d:OFFSET").help("Sample subset offset").action([&](auto argv) {
+    parse_int(argv, &options.session_params.sample_subset_offset);
+    options.session_params.use_sample_subset = true;
+  });
+  ap.arg("--sample-subset-length %d:LENGTH").help("Sample subset length").action([&](auto argv) {
+    parse_int(argv, &options.session_params.sample_subset_length);
+    options.session_params.use_sample_subset = true;
+  });
   ap.arg("--output %s:OUTPUT").help("File path to write output image").action([&](auto argv) {
     parse_string(argv, &options.output_filepath);
   });
-- 
