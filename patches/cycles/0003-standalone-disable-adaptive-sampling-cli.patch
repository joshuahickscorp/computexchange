From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: CX Spec Lab <spec-lab@computexchange.local>
Date: Wed, 8 Jul 2026 01:20:00 -0400
Subject: [PATCH] standalone: expose adaptive sampling disable switch

Expose a minimal standalone CLI switch for disabling Cycles' default adaptive
sampling. CX uses this for strict sample-subset fan-out probes, where the full
render and each subset must use the same fixed sample schedule.
---
 src/app/cycles_standalone.cpp | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/src/app/cycles_standalone.cpp b/src/app/cycles_standalone.cpp
index 0000000000..0000000000 100644
--- a/src/app/cycles_standalone.cpp
+++ b/src/app/cycles_standalone.cpp
@@ -38,7 +38,8 @@ struct Options {
   bool quiet;
   bool show_help, interactive, pause;
   string output_filepath;
   string output_pass;
+  bool disable_adaptive_sampling;
 } options;
 
 static void session_print(const string &str)
@@ -95,6 +96,10 @@ static void scene_init()
     xml_read_file(options.scene, options.filepath.c_str());
   }
 
+  if (options.disable_adaptive_sampling) {
+    options.scene->integrator->set_use_adaptive_sampling(false);
+  }
+
   /* Camera width/height override? */
   if (!(options.width == 0 || options.height == 0)) {
     options.scene->camera->set_full_width(options.width);
@@ -432,6 +437,9 @@ static void options_parse(const int argc, const char **argv)
     parse_int(argv, &options.session_params.sample_subset_length);
     options.session_params.use_sample_subset = true;
   });
+  ap.arg("--disable-adaptive-sampling", &options.disable_adaptive_sampling)
+      .help("Disable adaptive sampling for fixed-sample renders");
+
   ap.arg("--output %s:OUTPUT").help("File path to write output image").action([&](auto argv) {
     parse_string(argv, &options.output_filepath);
   });
-- 
