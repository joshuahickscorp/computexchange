From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: CX Spec Lab <spec-lab@computexchange.local>
Date: Thu, 9 Jul 2026 15:00:00 -0400
Subject: [PATCH] standalone: add CX crop fields to batch manifest

Extend the resident CX batch manifest with an optional per-job crop suffix:

  OUTPUT SAMPLES OFFSET LENGTH [CROP_X CROP_Y CROP_W CROP_H FULL_W FULL_H]

The original four-column sample-subset manifest remains valid. Crop jobs reuse
the already-loaded scene and warm process, then reset the session buffer to the
per-job crop bounds. This keeps selective tile refinement from paying a full
standalone Cycles process and scene setup cost for every tile.
---
 src/app/cycles_standalone.cpp | 61 +++++++++++++++++++++++++++++++++--
 1 file changed, 58 insertions(+), 3 deletions(-)

diff --git a/src/app/cycles_standalone.cpp b/src/app/cycles_standalone.cpp
index 3b90e443..7a5ad040 100644
--- a/src/app/cycles_standalone.cpp
+++ b/src/app/cycles_standalone.cpp
@@ -66,6 +66,13 @@ struct CXBatchJob {
   int samples;
   int sample_subset_offset;
   int sample_subset_length;
+  bool cx_crop_enabled;
+  int cx_crop_x;
+  int cx_crop_y;
+  int cx_crop_width;
+  int cx_crop_height;
+  int cx_crop_full_width;
+  int cx_crop_full_height;
 };
 
 static void session_print(const string &str)
@@ -228,14 +235,36 @@ static vector<CXBatchJob> cx_read_batch_manifest(const string &filepath)
 
     std::istringstream line_stream(line);
     CXBatchJob job;
+    job.cx_crop_enabled = false;
     if (!(line_stream >> job.output_filepath >> job.samples >> job.sample_subset_offset >>
           job.sample_subset_length))
     {
       fprintf(stderr,
-              "Invalid CX batch manifest line %d: expected OUTPUT SAMPLES OFFSET LENGTH\n",
+              "Invalid CX batch manifest line %d: expected OUTPUT SAMPLES OFFSET LENGTH "
+              "[CROP_X CROP_Y CROP_W CROP_H FULL_W FULL_H]\n",
               line_number);
       exit(EXIT_FAILURE);
     }
+    if (line_stream >> job.cx_crop_x) {
+      if (!(line_stream >> job.cx_crop_y >> job.cx_crop_width >> job.cx_crop_height >>
+            job.cx_crop_full_width >> job.cx_crop_full_height))
+      {
+        fprintf(stderr,
+                "Invalid CX batch manifest line %d: incomplete crop bounds\n",
+                line_number);
+        exit(EXIT_FAILURE);
+      }
+      if (job.cx_crop_x < 0 || job.cx_crop_y < 0 || job.cx_crop_width <= 0 ||
+          job.cx_crop_height <= 0 || job.cx_crop_full_width <= 0 ||
+          job.cx_crop_full_height <= 0 ||
+          job.cx_crop_x + job.cx_crop_width > job.cx_crop_full_width ||
+          job.cx_crop_y + job.cx_crop_height > job.cx_crop_full_height)
+      {
+        fprintf(stderr, "Invalid CX batch crop bounds on line %d\n", line_number);
+        exit(EXIT_FAILURE);
+      }
+      job.cx_crop_enabled = true;
+    }
     jobs.push_back(job);
   }
 
@@ -275,6 +304,21 @@ static void cx_batch_run()
     options.session_params.sample_subset_offset = job.sample_subset_offset;
     options.session_params.sample_subset_length = job.sample_subset_length;
     options.output_filepath = job.output_filepath;
+    options.cx_crop_enabled = job.cx_crop_enabled;
+    if (job.cx_crop_enabled) {
+      options.cx_crop_x = job.cx_crop_x;
+      options.cx_crop_y = job.cx_crop_y;
+      options.cx_crop_width = job.cx_crop_width;
+      options.cx_crop_height = job.cx_crop_height;
+      options.cx_crop_full_width = job.cx_crop_full_width;
+      options.cx_crop_full_height = job.cx_crop_full_height;
+      options.width = job.cx_crop_width;
+      options.height = job.cx_crop_height;
+    }
+    else {
+      options.width = options.scene->camera->get_full_width();
+      options.height = options.scene->camera->get_full_height();
+    }
 
     options.session->set_output_driver(make_unique<OIIOOutputDriver>(
         options.output_filepath, options.output_pass, session_print));
@@ -282,12 +326,13 @@ static void cx_batch_run()
     options.session->start();
     options.session->wait();
 
-    printf("\nCX_CYCLES_BATCH_JOB_OK index=%zu output=%s samples=%d offset=%d length=%d\n",
+    printf("\nCX_CYCLES_BATCH_JOB_OK index=%zu output=%s samples=%d offset=%d length=%d crop=%d\n",
            i,
            job.output_filepath.c_str(),
            job.samples,
            job.sample_subset_offset,
-           job.sample_subset_length);
+           job.sample_subset_length,
+           job.cx_crop_enabled ? 1 : 0);
   }
 
   session_exit();
@@ -596,7 +641,8 @@ static void options_parse(const int argc, const char **argv)
   ap.arg("--disable-adaptive-sampling", &options.disable_adaptive_sampling)
       .help("Disable adaptive sampling for fixed-sample renders");
   ap.arg("--cx-batch-manifest %s:MANIFEST")
-      .help("Run CX batch manifest lines: OUTPUT SAMPLES OFFSET LENGTH")
+      .help("Run CX batch manifest lines: OUTPUT SAMPLES OFFSET LENGTH "
+            "[CROP_X CROP_Y CROP_W CROP_H FULL_W FULL_H]")
       .action([&](auto argv) { parse_string(argv, &options.cx_batch_manifest); });
   ap.arg("--cx-crop %s:X,Y,W,H,FULL_W,FULL_H")
       .help("Render a CX crop in Cycles full-frame buffer coordinates")
-- 
