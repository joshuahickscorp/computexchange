From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: CX Spec Lab <spec-lab@computexchange.local>
Date: Wed, 8 Jul 2026 13:45:00 -0400
Subject: [PATCH] standalone: add CX batch manifest mode

Add a minimal CX-only batch mode to standalone Cycles. The mode keeps one
process and one loaded scene alive while rendering multiple sample-subset jobs
from a manifest of:

  OUTPUT SAMPLES OFFSET LENGTH

This is the first scaffold toward resident workers. It deliberately avoids a
socket protocol or deeper scheduler changes so the patch remains small and easy
to rebase while giving CX a measurable next step beyond one standalone process
per sample subset.
---
 src/app/cycles_standalone.cpp | 102 ++++++++++++++++++++++++++++++++++
 1 file changed, 102 insertions(+)

diff --git a/src/app/cycles_standalone.cpp b/src/app/cycles_standalone.cpp
index e9a11987..eb736a9e 100644
--- a/src/app/cycles_standalone.cpp
+++ b/src/app/cycles_standalone.cpp
@@ -3,6 +3,8 @@
  * SPDX-License-Identifier: Apache-2.0 */
 
 #include <cstdio>
+#include <fstream>
+#include <sstream>
 
 #include "device/device.h"
 #include "scene/camera.h"
@@ -49,8 +51,16 @@ struct Options {
   string output_filepath;
   string output_pass;
   bool disable_adaptive_sampling;
+  string cx_batch_manifest;
 } options;
 
+struct CXBatchJob {
+  string output_filepath;
+  int samples;
+  int sample_subset_offset;
+  int sample_subset_length;
+};
+
 static void session_print(const string &str)
 {
   /* print with carriage return to overwrite previous */
@@ -181,6 +191,91 @@ static void session_exit()
   }
 }
 
+static vector<CXBatchJob> cx_read_batch_manifest(const string &filepath)
+{
+  vector<CXBatchJob> jobs;
+  std::ifstream stream(filepath.c_str());
+  if (!stream) {
+    fprintf(stderr, "Unable to open CX batch manifest: %s\n", filepath.c_str());
+    exit(EXIT_FAILURE);
+  }
+
+  string line;
+  int line_number = 0;
+  while (std::getline(stream, line)) {
+    line_number++;
+    if (line.empty() || line[0] == '#') {
+      continue;
+    }
+
+    std::istringstream line_stream(line);
+    CXBatchJob job;
+    if (!(line_stream >> job.output_filepath >> job.samples >> job.sample_subset_offset >>
+          job.sample_subset_length))
+    {
+      fprintf(stderr,
+              "Invalid CX batch manifest line %d: expected OUTPUT SAMPLES OFFSET LENGTH\n",
+              line_number);
+      exit(EXIT_FAILURE);
+    }
+    jobs.push_back(job);
+  }
+
+  if (jobs.empty()) {
+    fprintf(stderr, "CX batch manifest has no jobs: %s\n", filepath.c_str());
+    exit(EXIT_FAILURE);
+  }
+
+  return jobs;
+}
+
+static void cx_batch_session_init()
+{
+  options.output_pass = "combined";
+  options.session = make_unique<Session>(options.session_params, options.scene_params);
+
+  if (options.session_params.background && !options.quiet) {
+    options.session->progress.set_update_callback([] { session_print_status(); });
+  }
+
+  scene_init();
+
+  Pass *pass = options.scene->create_node<Pass>();
+  pass->set_name(ustring(options.output_pass.c_str()));
+  pass->set_type(PASS_COMBINED);
+}
+
+static void cx_batch_run()
+{
+  const vector<CXBatchJob> jobs = cx_read_batch_manifest(options.cx_batch_manifest);
+  cx_batch_session_init();
+
+  for (size_t i = 0; i < jobs.size(); i++) {
+    const CXBatchJob &job = jobs[i];
+    options.session_params.samples = job.samples;
+    options.session_params.use_sample_subset = true;
+    options.session_params.sample_subset_offset = job.sample_subset_offset;
+    options.session_params.sample_subset_length = job.sample_subset_length;
+    options.output_filepath = job.output_filepath;
+
+    options.session->set_output_driver(make_unique<OIIOOutputDriver>(
+        options.output_filepath, options.output_pass, session_print));
+    options.session->reset(options.session_params, session_buffer_params());
+    options.session->start();
+    options.session->wait();
+
+    printf("\nCX_CYCLES_BATCH_JOB_OK index=%zu output=%s samples=%d offset=%d length=%d\n",
+           i,
+           job.output_filepath.c_str(),
+           job.samples,
+           job.sample_subset_offset,
+           job.sample_subset_length);
+  }
+
+  session_exit();
+  printf("CX_CYCLES_BATCH_OK jobs=%zu\n", jobs.size());
+}
+
 #ifdef WITH_CYCLES_STANDALONE_GUI
 static void display_info(Progress &progress)
 {
@@ -439,6 +534,9 @@ static void options_parse(const int argc, const char **argv)
   });
   ap.arg("--disable-adaptive-sampling", &options.disable_adaptive_sampling)
       .help("Disable adaptive sampling for fixed-sample renders");
+  ap.arg("--cx-batch-manifest %s:MANIFEST")
+      .help("Run CX batch manifest lines: OUTPUT SAMPLES OFFSET LENGTH")
+      .action([&](auto argv) { parse_string(argv, &options.cx_batch_manifest); });
 
   ap.arg("--output %s:OUTPUT").help("File path to write output image").action([&](auto argv) {
     parse_string(argv, &options.output_filepath);
@@ -559,6 +657,11 @@ int main(const int argc, const char **argv)
   path_init();
   options_parse(argc, argv);
 
+  if (!options.cx_batch_manifest.empty()) {
+    cx_batch_run();
+    return 0;
+  }
+
 #ifdef WITH_CYCLES_STANDALONE_GUI
   if (options.session_params.background) {
 #endif
