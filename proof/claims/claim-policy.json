{
  "schema_version": 1,
  "surface_discovery": {
    "patterns": [
      "*.md",
      "docs/*.md",
      "*/README.md",
      "*/*/README.md",
      "web/*.html",
      "web/**/*.md"
    ],
    "ignored_prefixes": [
      ".claude/",
      ".pytest_cache/",
      "agent/vendor/",
      "docs/legal/"
    ]
  },
  "active_surfaces": [
    "README.md",
    "cli/README.md",
    "docs/ALPHA_READINESS.md",
    "docs/API_CLIENT_SUPPORT.md",
    "docs/FIVE_BY_FIVE.md",
    "docs/PERFORMANCE_PROOF.md",
    "docs/QUICKSTART.md",
    "docs/RUNBOOKS.md",
    "docs/RUNTIME_MATRIX.md",
    "docs/SECURITY.md",
    "docs/fleet-proof/README.md",
    "sdk/python/README.md",
    "monitoring/README.md",
    "web/admin.html",
    "web/index.html",
    "web/demo.html"
  ],
  "archival_surfaces": [
    {
      "path": "RELEASE_CANDIDATE.md",
      "required_marker": "CLAIM-SCOPE: historical-non-authoritative",
      "required_fragments": [
        "not current",
        "proof/5x5-gates.json"
      ]
    },
    {
      "path": "GO_LIVE.md",
      "required_marker": "CLAIM-SCOPE: draft-runbook-non-authoritative",
      "required_fragments": [
        "does not mean the engine, product, policies, deployment, or market are go-live",
        "explicit authorization"
      ]
    },
    {
      "path": "docs/SITE-CLAIMS.md",
      "required_marker": "CLAIM-SCOPE: historical-non-authoritative",
      "required_fragments": [
        "not current product evidence",
        "proof/5x5-gates.json"
      ]
    },
    {
      "path": "docs/ARCHIVE_INDEX.md",
      "required_marker": "CLAIM-SCOPE: archival-index-non-authoritative",
      "required_fragments": [
        "not current product evidence"
      ]
    }
  ],
  "internal_surfaces": [
    {
      "path": "web/assets/site/CONTRACT.md",
      "required_marker": "CLAIM-SCOPE: internal-engineering-non-authoritative"
    },
    {
      "path": "CONDENSATION_STATUS.md",
      "required_marker": "CLAIM-SCOPE: internal-engineering-non-authoritative"
    },
    {
      "path": "WAVE2_RECENSUS.md",
      "required_marker": "CLAIM-SCOPE: internal-engineering-non-authoritative"
    }
  ],
  "forbidden_active_patterns": [
    {
      "id": "stale_proof_count",
      "gate": "policy_gtm/marketing_claim_conformance",
      "pattern": "(?i)\\b(?:\\d+\\s*/\\s*\\d+\\s+(?:pass(?:ed)?|checks?)|\\d+\\s+(?:pass(?:ed)?|checks?))\\b",
      "reason": "A pasted historical test count is not source-bound product evidence."
    },
    {
      "id": "whole_product_proof",
      "gate": "policy_gtm/marketing_claim_conformance",
      "pattern": "(?i)\\b(?:prove(?:s|d)? everything|everything (?:that can be [^.]+ )?(?:is|are) (?:done|proven)|what(?:'s| is) left is external|external only)\\b",
      "reason": "Local proof cannot collapse remaining local, physical, money, policy, or market gates."
    },
    {
      "id": "decentralized_topology",
      "gate": "marketplace/topology_claim_boundary",
      "pattern": "(?i)\\b(?:peer[- ]to[- ]peer|p2p|decentrali[sz](?:ed|ation)?)\\b",
      "reason": "The implemented topology is a central control plane and Postgres scheduler."
    },
    {
      "id": "universal_runtime",
      "gate": "platform_runtime/runtime_claim_boundary",
      "pattern": "(?i)\\b(?:all platforms|all runtimes)\\b",
      "reason": "Only production cells from the runtime matrix may be advertised."
    },
    {
      "id": "confidential_absolute",
      "gate": "policy_gtm/confidential_compute_claim_boundary",
      "pattern": "(?i)\\b(?:trusted execution environment guaranteed|hardware[- ]attested confidential compute)\\b",
      "reason": "No TEE/operator-blind control is implemented or independently attested."
    },
    {
      "id": "airgapped_absolute",
      "gate": "policy_gtm/confidential_compute_claim_boundary",
      "pattern": "(?i)\\bair[- ]gapped\\b",
      "reason": "Local/offline components do not establish a paid-market air-gap or confidentiality guarantee."
    },
    {
      "id": "openai_compatibility_absolute",
      "gate": "developer_experience/api_contract",
      "pattern": "(?i)\\bopenai[- ]compatible\\b",
      "reason": "Only a batch-shaped subset exists; synchronous and streaming compatibility are absent."
    },
    {
      "id": "legacy_split",
      "gate": "pricing_economics/margin_guard",
      "pattern": "\\b90/10\\b",
      "reason": "Frozen buyer/supplier economics replaced the historical fixed split."
    },
    {
      "id": "only_external_stub",
      "gate": "pricing_economics/production_money_movement",
      "pattern": "(?i)\\b(?:only (?:phase-?3 )?stub|single intentional local stub)\\b",
      "reason": "Transfer code and a stub are both narrower than full money/reconciliation proof, and other local gaps remain."
    }
  ],
  "required_active_fragments": [
    {
      "path": "README.md",
      "gate": "marketplace/topology_claim_boundary",
      "fragment": "centrally coordinated exchange implementation"
    },
    {
      "path": "README.md",
      "gate": "platform_runtime/runtime_claim_boundary",
      "fragment": "Current advertised runtime projection: Candle/Metal on Apple Silicon only"
    },
    {
      "path": "README.md",
      "gate": "policy_gtm/confidential_compute_claim_boundary",
      "fragment": "not a TEE, operator-blind"
    },
    {
      "path": "README.md",
      "gate": "policy_gtm/marketing_claim_conformance",
      "fragment": "not yet a 5/5 product or a demonstrated market"
    },
    {
      "path": "README.md",
      "gate": "pricing_economics/production_money_movement",
      "fragment": "does not prove a real charge, payout, reversal, fee"
    },
    {
      "path": "README.md",
      "gate": "developer_experience/api_contract",
      "fragment": "OpenAI-shaped Batch API subset"
    },
    {
      "path": "docs/QUICKSTART.md",
      "gate": "developer_experience/api_contract",
      "fragment": "There is no separate synchronous"
    },
    {
      "path": "docs/QUICKSTART.md",
      "gate": "policy_gtm/confidential_compute_claim_boundary",
      "fragment": "does not by itself claim encryption-at-rest"
    },
    {
      "path": "sdk/python/README.md",
      "gate": "developer_experience/python_distribution",
      "fragment": "not published on PyPI yet"
    },
    {
      "path": "web/index.html",
      "gate": "policy_gtm/public_site",
      "fragment": "Development preview"
    },
    {
      "path": "web/index.html",
      "gate": "policy_gtm/marketing_claim_conformance",
      "fragment": "No live-money, market-liquidity, signed-distribution, or physical-fleet claim"
    },
    {
      "path": "web/demo.html",
      "gate": "policy_gtm/public_site",
      "fragment": "Development simulation"
    },
    {
      "path": "web/demo.html",
      "gate": "policy_gtm/marketing_claim_conformance",
      "fragment": "Static runs and earnings are illustrative"
    }
  ]
}
