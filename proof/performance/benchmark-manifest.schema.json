{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://computexchange.local/schemas/performance-benchmark-manifest-v1.json",
  "title": "Computexchange comparable performance benchmark manifest",
  "description": "Pins every workload, runtime, hardware, environment, timing, and regression-policy field required for an honest comparison. A valid manifest is a plan/identity contract, not evidence that a physical run occurred.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "comparison_id",
    "arm",
    "lane_id",
    "evidence_class",
    "allowed_differences",
    "workload",
    "runtime",
    "hardware",
    "environment",
    "timing_scope",
    "sampling",
    "regression_policy"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "manifest_id": {"$ref": "#/$defs/id"},
    "comparison_id": {"$ref": "#/$defs/id"},
    "arm": {"enum": ["baseline", "candidate"]},
    "lane_id": {"$ref": "#/$defs/id"},
    "evidence_class": {"enum": ["synthetic", "physical"]},
    "allowed_differences": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "lane_id",
          "runtime.engine",
          "runtime.agent",
          "runtime.toolchain",
          "hardware.host_id_sha256",
          "hardware.sku",
          "hardware.accelerator_count",
          "hardware.accelerator_memory_gb",
          "hardware.system_memory_gb",
          "hardware.cpu",
          "hardware.os",
          "hardware.os_version",
          "hardware.driver",
          "hardware.firmware",
          "environment.power.source",
          "environment.power.mode",
          "environment.power.limit_watts",
          "environment.power.measurement_source",
          "environment.thermal.temperature_c",
          "environment.thermal.sensor",
          "environment.thermal.fan_policy",
          "environment.competing_load.process_snapshot_sha256",
          "environment.competing_load.cpu_utilization_pct",
          "environment.competing_load.gpu_utilization_pct",
          "environment.competing_load.memory_used_gb"
        ]
      }
    },
    "workload": {"$ref": "#/$defs/workload"},
    "runtime": {"$ref": "#/$defs/runtime"},
    "hardware": {"$ref": "#/$defs/hardware"},
    "environment": {"$ref": "#/$defs/environment"},
    "timing_scope": {"$ref": "#/$defs/timing_scope"},
    "sampling": {"$ref": "#/$defs/sampling"},
    "regression_policy": {"$ref": "#/$defs/regression_policy"}
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "nonempty": {
      "type": "string",
      "minLength": 1
    },
    "nullable_sha256": {
      "oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision", "weights_sha256", "tokenizer_sha256"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "revision": {"$ref": "#/$defs/nonempty"},
        "weights_sha256": {"$ref": "#/$defs/sha256"},
        "tokenizer_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "quantization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scheme", "bits", "group_size", "calibration_sha256"],
      "properties": {
        "scheme": {"$ref": "#/$defs/nonempty"},
        "bits": {"type": "integer", "minimum": 0},
        "group_size": {
          "oneOf": [
            {"type": "integer", "minimum": 1},
            {"type": "null"}
          ]
        },
        "calibration_sha256": {"$ref": "#/$defs/nullable_sha256"}
      }
    },
    "precision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compute_dtype", "weight_dtype", "accumulator_dtype", "quantization"],
      "properties": {
        "compute_dtype": {"$ref": "#/$defs/nonempty"},
        "weight_dtype": {"$ref": "#/$defs/nonempty"},
        "accumulator_dtype": {"$ref": "#/$defs/nonempty"},
        "quantization": {"$ref": "#/$defs/quantization"}
      }
    },
    "prompt_corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256", "record_count", "format"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "record_count": {"type": "integer", "minimum": 1},
        "format": {"$ref": "#/$defs/nonempty"}
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested_tokens_per_prompt", "include_prompt_tokens", "stop_conditions_sha256", "throughput_unit"],
      "properties": {
        "requested_tokens_per_prompt": {"type": "integer", "minimum": 1},
        "include_prompt_tokens": {"const": false},
        "stop_conditions_sha256": {"$ref": "#/$defs/sha256"},
        "throughput_unit": {"const": "output_token"}
      }
    },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "batch_size", "max_batch_size", "max_wait_ms", "padding", "ordering"],
      "properties": {
        "mode": {"enum": ["fixed", "dynamic"]},
        "batch_size": {"type": "integer", "minimum": 1},
        "max_batch_size": {"type": "integer", "minimum": 1},
        "max_wait_ms": {"type": "number", "minimum": 0},
        "padding": {"$ref": "#/$defs/nonempty"},
        "ordering": {"$ref": "#/$defs/nonempty"}
      }
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["job_type", "model", "precision", "prompt_corpus", "output", "batch"],
      "properties": {
        "job_type": {"$ref": "#/$defs/id"},
        "model": {"$ref": "#/$defs/model"},
        "precision": {"$ref": "#/$defs/precision"},
        "prompt_corpus": {"$ref": "#/$defs/prompt_corpus"},
        "output": {"$ref": "#/$defs/output"},
        "batch": {"$ref": "#/$defs/batch"}
      }
    },
    "versioned_build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "build_sha256"],
      "properties": {
        "name": {"$ref": "#/$defs/nonempty"},
        "version": {"$ref": "#/$defs/nonempty"},
        "build_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "agent", "toolchain"],
      "properties": {
        "engine": {"$ref": "#/$defs/versioned_build"},
        "agent": {"$ref": "#/$defs/versioned_build"},
        "toolchain": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/versioned_build"}
        }
      }
    },
    "hardware": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host_id_sha256",
        "sku",
        "accelerator_count",
        "accelerator_memory_gb",
        "system_memory_gb",
        "cpu",
        "os",
        "os_version",
        "driver",
        "firmware"
      ],
      "properties": {
        "host_id_sha256": {"$ref": "#/$defs/sha256"},
        "sku": {"$ref": "#/$defs/nonempty"},
        "accelerator_count": {"type": "integer", "minimum": 1},
        "accelerator_memory_gb": {"type": "number", "minimum": 0},
        "system_memory_gb": {"type": "number", "exclusiveMinimum": 0},
        "cpu": {"$ref": "#/$defs/nonempty"},
        "os": {"$ref": "#/$defs/nonempty"},
        "os_version": {"$ref": "#/$defs/nonempty"},
        "driver": {"$ref": "#/$defs/nonempty"},
        "firmware": {"$ref": "#/$defs/nonempty"}
      }
    },
    "power": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "mode", "limit_watts", "measurement_source"],
      "properties": {
        "source": {"$ref": "#/$defs/nonempty"},
        "mode": {"$ref": "#/$defs/nonempty"},
        "limit_watts": {
          "oneOf": [
            {"type": "number", "exclusiveMinimum": 0},
            {"type": "null"}
          ]
        },
        "measurement_source": {"$ref": "#/$defs/nonempty"}
      }
    },
    "thermal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "temperature_c", "sensor", "fan_policy"],
      "properties": {
        "state": {"$ref": "#/$defs/nonempty"},
        "temperature_c": {
          "oneOf": [
            {"type": "number", "minimum": -50, "maximum": 150},
            {"type": "null"}
          ]
        },
        "sensor": {"$ref": "#/$defs/nonempty"},
        "fan_policy": {"$ref": "#/$defs/nonempty"}
      }
    },
    "competing_load": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "process_snapshot_sha256",
        "cpu_utilization_pct",
        "gpu_utilization_pct",
        "memory_used_gb"
      ],
      "properties": {
        "policy": {"enum": ["idle", "recorded"]},
        "process_snapshot_sha256": {"$ref": "#/$defs/sha256"},
        "cpu_utilization_pct": {"type": "number", "minimum": 0, "maximum": 100},
        "gpu_utilization_pct": {"type": "number", "minimum": 0, "maximum": 100},
        "memory_used_gb": {"type": "number", "minimum": 0}
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["power", "thermal", "competing_load"],
      "properties": {
        "power": {"$ref": "#/$defs/power"},
        "thermal": {"$ref": "#/$defs/thermal"},
        "competing_load": {"$ref": "#/$defs/competing_load"}
      }
    },
    "timing_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provisioning_included",
        "queue_included",
        "transfer_in_included",
        "transfer_out_included",
        "clock",
        "start_boundary",
        "end_boundary"
      ],
      "properties": {
        "provisioning_included": {"const": true},
        "queue_included": {"const": true},
        "transfer_in_included": {"const": true},
        "transfer_out_included": {"const": true},
        "clock": {"$ref": "#/$defs/nonempty"},
        "start_boundary": {"$ref": "#/$defs/nonempty"},
        "end_boundary": {"$ref": "#/$defs/nonempty"}
      }
    },
    "sampling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["warmup_iterations", "measured_iterations", "order", "seed"],
      "properties": {
        "warmup_iterations": {"type": "integer", "minimum": 0},
        "measured_iterations": {"type": "integer", "minimum": 20},
        "order": {"enum": ["interleaved_ab_ba", "baseline_then_candidate", "candidate_then_baseline"]},
        "seed": {"type": "integer", "minimum": 0}
      }
    },
    "regression_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_throughput_ratio",
        "max_p95_latency_ratio",
        "max_p99_latency_ratio",
        "max_oom_events",
        "max_restart_events",
        "max_disconnect_events",
        "max_corrupt_output_events",
        "max_cleanup_failures",
        "require_cleanup"
      ],
      "properties": {
        "min_throughput_ratio": {"type": "number", "exclusiveMinimum": 0},
        "max_p95_latency_ratio": {"type": "number", "minimum": 1},
        "max_p99_latency_ratio": {"type": "number", "minimum": 1},
        "max_oom_events": {"type": "integer", "minimum": 0},
        "max_restart_events": {"type": "integer", "minimum": 0},
        "max_disconnect_events": {"type": "integer", "minimum": 0},
        "max_corrupt_output_events": {"type": "integer", "minimum": 0},
        "max_cleanup_failures": {"type": "integer", "minimum": 0},
        "require_cleanup": {"const": true}
      }
    }
  }
}
