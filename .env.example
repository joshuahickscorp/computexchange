DATABASE_URL=postgres://cx:cx@localhost:5432/cx?sslmode=disable
LISTEN_ADDR=:8080
CX_PUBLIC_CONTROL_ORIGIN=http://localhost:8080
DB_MAX_CONNS=20

S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=cx-jobs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

CX_CONTROL_URL=http://localhost:8080
CX_WORKER_TOKEN=replace-with-enrolled-worker-token
# CX_MODEL_CACHE=/absolute/model/cache
# CX_REQUIRE_SANDBOX=1

CX_ENV=development
# CX_TOKEN_KEY=at-least-32-random-bytes
# CX_VERIFICATION_SAMPLE_SECRET=at-least-32-distinct-random-bytes

# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# CX_CONNECT_WEBHOOK_SECRET=whsec_distinct_xxx
# CX_CONNECT_CLIENT_ID=ca_xxx
CX_CONNECT_RETURN_URL=http://localhost:8080/v1/supplier/status
CX_CONNECT_REFRESH_URL=http://localhost:8080/v1/supplier/status

CX_ECON_SCHEDULE_VERSION=2026-07-19
CX_PROCESSOR_PERCENT_BPS=290
CX_PROCESSOR_FIXED_USD=0.30
CX_CONTROL_PLANE_PER_TASK_USD=0.0001
CX_TARGET_MARGIN_BPS=1000

POSTGRES_PASSWORD=replace-with-random-password
MINIO_ROOT_USER=replace-with-random-access-key
MINIO_ROOT_PASSWORD=replace-with-random-secret
S3_PUBLIC_ENDPOINT=https://storage.example.com
CX_PUBLIC_CONTROL_ORIGIN=https://cx.example.com
SITE_HOST=cx.example.com
STORAGE_HOST=storage.example.com
ACME_EMAIL=ops@example.com

# Backups must leave the deployment host. Use an independent S3-compatible
# bucket and restricted credentials; do not reuse the live artifact-store keys.
# CX_BACKUP_OFFSITE=s3://cx-backups/production
# CX_BACKUP_S3_ENDPOINT=https://s3.example.com
# AWS_ACCESS_KEY_ID=replace-with-backup-only-access-key
# AWS_SECRET_ACCESS_KEY=replace-with-backup-only-secret
# CX_BACKUP_KEEP_LOCAL=7
