DATABASE_URL=postgres://cx:cx@localhost:5432/cx?sslmode=disable
LISTEN_ADDR=:8080
CX_PUBLIC_CONTROL_ORIGIN=http://localhost:8080
DB_MAX_CONNS=20

S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=cx-jobs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

CX_CONTROL_URL=http://localhost:8080
CX_WORKER_TOKEN=replace-with-enrolled-worker-token
# CX_MODEL_CACHE=/absolute/model/cache
# CX_REQUIRE_SANDBOX=1

CX_ENV=development
# Only directly connected reverse proxies may supply client-IP headers.
# CX_TRUSTED_PROXY_CIDRS=172.16.0.0/12
# CX_TOKEN_KEY=at-least-32-random-bytes
# CX_VERIFICATION_SAMPLE_SECRET=at-least-32-distinct-random-bytes

# Supervised private-canary envelope. Enabling canary mode without every limit
# and both explicit allowlists makes /readyz fail closed.
# CX_CANARY_MODE=true
# CX_CANARY_APPROVED_BUYER_EMAILS=buyer-one@example.test,buyer-two@example.test
# CX_CANARY_APPROVED_WORKER_IDS=00000000-0000-4000-8000-000000000001,00000000-0000-4000-8000-000000000002
# CX_CANARY_APPROVED_AGENT_VERSIONS=0.1.0
# CX_CANARY_APPROVED_BUILD_HASHES=0123456789abcdef,fedcba9876543210
# CX_CANARY_MAX_ACTIVE_BUYERS=2
# CX_CANARY_MAX_ACTIVE_WORKERS=2
# CX_CANARY_MAX_QUEUED_JOBS=20
# CX_CANARY_MAX_TASKS_PER_JOB=64
# CX_CANARY_MAX_ARTIFACT_BYTES=33554432
# CX_CANARY_MAX_INPUT_BYTES=33554432
# CX_CANARY_MAX_OUTPUT_TOKENS=256
# CX_CANARY_MAX_JOB_DURATION_SECS=600
# CX_CANARY_MAX_RETRIES=3
# CX_CANARY_MAX_DAILY_JOBS=100
# CX_CANARY_MAX_SHADOW_VALUE_USD=10
# CX_CANARY_MAX_HELD_SHADOW_PAYOUT_USD=10

# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# CX_CONNECT_WEBHOOK_SECRET=whsec_distinct_xxx
# CX_CONNECT_CLIENT_ID=ca_xxx
CX_CONNECT_RETURN_URL=http://localhost:8080/v1/supplier/status
CX_CONNECT_REFRESH_URL=http://localhost:8080/v1/supplier/status

CX_ECON_SCHEDULE_VERSION=2026-07-19
CX_PROCESSOR_PERCENT_BPS=290
CX_PROCESSOR_FIXED_USD=0.30
CX_CONTROL_PLANE_PER_TASK_USD=0.0001
CX_TARGET_MARGIN_BPS=1000

POSTGRES_PASSWORD=replace-with-random-password
MINIO_ROOT_USER=replace-with-random-access-key
MINIO_ROOT_PASSWORD=replace-with-random-secret
S3_PUBLIC_ENDPOINT=https://storage.example.com
CX_PUBLIC_CONTROL_ORIGIN=https://cx.example.com
SITE_HOST=cx.example.com
STORAGE_HOST=storage.example.com
ACME_EMAIL=ops@example.com

# Backups must leave the deployment host. Use an independent S3-compatible
# bucket and restricted credentials; do not reuse the live artifact-store keys.
# CX_BACKUP_OFFSITE=s3://cx-backups/production
# CX_BACKUP_S3_ENDPOINT=https://s3.example.com
# AWS_ACCESS_KEY_ID=replace-with-backup-only-access-key
# AWS_SECRET_ACCESS_KEY=replace-with-backup-only-secret
# CX_BACKUP_ENCRYPTION_RECIPIENT=age1...
# CX_BACKUP_DECRYPTION_IDENTITY_FILE=/run/secrets/cx-backup-age-identity
# CX_BACKUP_KEEP_LOCAL=7

# Exact-candidate human approval and exercise receipt bundle. See the schema;
# keep the filled receipt outside git and provide only its absolute path.
# GOVERNANCE_APPROVAL_BUNDLE_PATH=/absolute/private/governance-approval-bundle.json
