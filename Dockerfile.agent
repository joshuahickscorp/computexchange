# Computexchange — supplier AGENT image, NVIDIA/CUDA lane (Linux + NVIDIA GPU).
#
# This is the ONE containerizable lane. Metal is unavailable inside Linux containers,
# so Apple Silicon suppliers run the agent NATIVELY (see README "Why no agent image");
# the CUDA build, by contrast, runs in a standard NVIDIA container. The CUDA inference
# path was proven on an A100 — docs/RUNPOD_SPIKE.md (170 tok/s, 3,213 emb/s).
#
# Build:  docker build -f Dockerfile.agent -t cx-agent-cuda .
# Run:    docker run --gpus all --rm \
#           -e CX_CONTROL_URL=https://computexchange.net \
#           -e CX_WORKER_TOKEN=cxw_...  \
#           -v cx-models:/var/lib/cx/models \
#           cx-agent-cuda
#         (configure via env — see .env.example — or mount an agent.toml.)
#
# The host needs the NVIDIA Container Toolkit for `--gpus all`. The build context is
# scoped by Dockerfile.agent.dockerignore so only agent/ source enters it.

# ── build stage ──────────────────────────────────────────────────────────────────
# CUDA *devel* image: ships nvcc, which Candle needs to compile its CUDA kernels.
FROM nvidia/cuda:12.4.1-devel-ubuntu22.04 AS build
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl ca-certificates build-essential pkg-config libssl-dev && \
    rm -rf /var/lib/apt/lists/*
# Rust toolchain (rustup, stable).
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal
ENV PATH="/root/.cargo/bin:${PATH}"
WORKDIR /src
COPY agent/ ./agent/
WORKDIR /src/agent
# Drop the default `metal` feature (Linux has no Metal) and build the CUDA lane —
# the exact build the RunPod spike validated.
RUN cargo build --release --no-default-features --features cuda

# ── runtime stage ────────────────────────────────────────────────────────────────
# CUDA *runtime* image: the shared libs the agent links against, without the toolkit.
FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04 AS runtime
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*
COPY --from=build /src/agent/target/release/cx-agent /usr/local/bin/cx-agent
# HF model cache — mount a volume here to persist downloaded weights across restarts
# (BLACKHOLE: assets are never re-fetched or orphaned needlessly).
ENV CX_MODEL_CACHE=/var/lib/cx/models
RUN mkdir -p /var/lib/cx/models
ENTRYPOINT ["/usr/local/bin/cx-agent"]
