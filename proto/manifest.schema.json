{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compute.exchange/proto/manifest.schema.json",
  "title": "Compute Exchange wire contract",
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "hw_class": {
      "enum": ["apple_silicon_base", "apple_silicon_pro", "apple_silicon_max", "apple_silicon_ultra"]
    },
    "tier": { "enum": ["batch", "priority", "trusted"] },
    "model_kind": { "enum": ["gguf", "hf"] },
    "job_tag": { "enum": ["embed", "batch_infer"] },
    "ModelRef": {
      "type": "object",
      "properties": {
        "kind": { "$ref": "#/$defs/model_kind" },
        "ref": { "type": "string", "minLength": 1 }
      },
      "required": ["kind", "ref"],
      "additionalProperties": false
    },
    "JobType": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": { "const": "embed" },
            "batch_size": { "type": "integer", "minimum": 0 },
            "binary": { "type": "boolean" }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "batch_infer" },
            "max_tokens": { "type": "integer", "minimum": 0 },
            "temperature": { "type": "number" }
          },
          "required": ["type"],
          "additionalProperties": false
        }
      ]
    },
    "InputRef": {
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "bytes": { "type": "integer", "minimum": 0 }
      },
      "required": ["url", "bytes"],
      "additionalProperties": false
    },
    "OutputRef": {
      "type": "object",
      "properties": { "url": { "type": "string" } },
      "required": ["url"],
      "additionalProperties": false
    },
    "JobConstraints": {
      "type": "object",
      "properties": {
        "min_memory_gb": { "type": "number", "minimum": 0 },
        "hw_classes": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/hw_class" }
        },
        "max_duration_secs": { "type": "integer", "minimum": 0 },
        "data_residency": {
          "type": ["array", "null"],
          "items": { "type": "string", "minLength": 2, "maxLength": 2 }
        }
      },
      "required": ["min_memory_gb", "hw_classes", "max_duration_secs", "data_residency"],
      "additionalProperties": false
    },
    "VerificationPolicy": {
      "type": "object",
      "properties": {
        "redundancy_frac": { "type": "number", "minimum": 0, "maximum": 1 },
        "honeypot_frac": { "type": "number", "minimum": 0, "maximum": 1 },
        "payout_hold_secs": { "type": "integer", "minimum": 0 },
        "skip_verification_floor": { "type": "boolean" }
      },
      "required": ["redundancy_frac", "honeypot_frac", "payout_hold_secs"],
      "additionalProperties": false
    },
    "JobManifest": {
      "type": "object",
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "job_type": { "$ref": "#/$defs/JobType" },
        "model": { "$ref": "#/$defs/ModelRef" },
        "inputs": { "type": "array", "items": { "$ref": "#/$defs/InputRef" } },
        "output": { "$ref": "#/$defs/OutputRef" },
        "params": true,
        "constraints": { "$ref": "#/$defs/JobConstraints" },
        "verification": { "$ref": "#/$defs/VerificationPolicy" },
        "tier": { "$ref": "#/$defs/tier" }
      },
      "required": ["id", "job_type", "model", "inputs", "output", "params", "constraints", "verification", "tier"],
      "additionalProperties": false
    },
    "BenchResult": {
      "type": "object",
      "properties": {
        "model_id": { "type": "string" },
        "job_type": { "$ref": "#/$defs/job_tag" },
        "tps": { "type": "number", "minimum": 0 },
        "eps": { "type": "number", "minimum": 0 },
        "p99_ms": { "type": "integer", "minimum": 0 },
        "thermal_ok": { "type": "boolean" },
        "load_ms": { "type": "integer", "minimum": 0 }
      },
      "required": ["model_id", "job_type", "tps", "eps", "p99_ms", "thermal_ok"],
      "additionalProperties": false
    },
    "WorkerCapability": {
      "type": "object",
      "properties": {
        "worker_id": { "$ref": "#/$defs/uuid" },
        "supplier_id": { "$ref": "#/$defs/uuid" },
        "hw_class": { "$ref": "#/$defs/hw_class" },
        "engine": { "const": "candle" },
        "build_hash": { "type": "string" },
        "memory_gb": { "type": "number", "minimum": 0 },
        "memory_bw_gbps": { "type": "number", "minimum": 0 },
        "supported_jobs": { "type": "array", "items": { "$ref": "#/$defs/job_tag" } },
        "supported_models": { "type": "array", "items": { "type": "string" } },
        "min_payout_usd_hr": { "type": "number", "minimum": 0 },
        "benchmarks": { "type": "array", "items": { "$ref": "#/$defs/BenchResult" } },
        "agent_version": { "type": "string" },
        "os_version": { "type": "string" }
      },
      "required": ["worker_id", "supplier_id", "hw_class", "memory_gb", "memory_bw_gbps", "supported_jobs", "supported_models", "benchmarks", "agent_version", "os_version"],
      "additionalProperties": false
    },
    "TaskDispatch": {
      "type": "object",
      "properties": {
        "task_id": { "$ref": "#/$defs/uuid" },
        "job_id": { "$ref": "#/$defs/uuid" },
        "runtime_cell_id": { "type": "string" },
        "runtime_id": { "type": "string" },
        "runtime_matrix_sha256": { "type": "string" },
        "manifest": { "$ref": "#/$defs/JobManifest" },
        "input_url": { "type": "string" },
        "output_url": { "type": "string" },
        "partial_put_url": { "type": "string" },
        "result_key": { "type": "string" },
        "offered_rate_usd_hr": { "type": "number", "minimum": 0 },
        "deadline": { "type": "integer", "minimum": 0 }
      },
      "required": ["task_id", "job_id", "manifest", "input_url", "output_url", "deadline"],
      "additionalProperties": false
    },
    "TaskCommit": {
      "type": "object",
      "properties": {
        "task_id": { "$ref": "#/$defs/uuid" },
        "result_key": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "tokens_used": { "type": "integer", "minimum": 0 },
        "result_sha256": { "type": "string" },
        "hardware_temp_c": { "type": ["number", "null"] }
      },
      "required": ["task_id", "result_key", "duration_ms", "tokens_used", "hardware_temp_c"],
      "additionalProperties": false
    },
    "Heartbeat": {
      "type": "object",
      "properties": {
        "worker_id": { "$ref": "#/$defs/uuid" },
        "timestamp": { "type": "integer", "minimum": 0 },
        "cpu_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "gpu_pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "gpu_temp_c": { "type": ["number", "null"] },
        "current_task": { "type": ["string", "null"], "format": "uuid" },
        "available_memory_gb": { "type": "number", "minimum": 0 },
        "effective_memory_gb": { "type": "number", "minimum": 0 },
        "reserved_headroom_gb": { "type": "number", "minimum": 0 },
        "throttled": { "type": "boolean" },
        "loaded_models": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["worker_id", "timestamp", "cpu_pct", "gpu_pct", "gpu_temp_c", "current_task"],
      "additionalProperties": false
    },
    "JobSubmitRequest": {
      "type": "object",
      "properties": {
        "job_type": { "$ref": "#/$defs/JobType" },
        "model": { "type": "string" },
        "params": true,
        "constraints": { "$ref": "#/$defs/JobConstraints" },
        "verification": { "$ref": "#/$defs/VerificationPolicy" },
        "tier": { "$ref": "#/$defs/tier" },
        "input": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "properties": { "s3_key": { "type": "string" } },
              "required": ["s3_key"],
              "additionalProperties": false
            }
          ]
        },
        "webhook_url": { "type": "string" },
        "max_usd": { "type": "number", "minimum": 0 }
      },
      "required": ["job_type", "model", "params", "constraints", "verification", "tier", "input"],
      "additionalProperties": false
    },
    "EmbedResult": {
      "type": "object",
      "properties": {
        "job_type": { "const": "embed" },
        "model": { "type": "string" },
        "dim": { "type": "integer", "minimum": 1 },
        "count": { "type": "integer", "minimum": 0 },
        "vectors": {
          "type": "array",
          "items": { "type": "array", "items": { "type": "number" } }
        }
      },
      "required": ["job_type", "model", "dim", "count", "vectors"],
      "additionalProperties": false
    },
    "BatchInferResult": {
      "type": "object",
      "properties": {
        "job_type": { "const": "batch_infer" },
        "model": { "type": "string" },
        "completions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "index": { "type": "integer", "minimum": 0 },
              "text": { "type": "string" },
              "tokens": { "type": "integer", "minimum": 0 }
            },
            "required": ["index", "text", "tokens"],
            "additionalProperties": false
          }
        }
      },
      "required": ["job_type", "model", "completions"],
      "additionalProperties": false
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/JobManifest" },
    { "$ref": "#/$defs/WorkerCapability" },
    { "$ref": "#/$defs/TaskDispatch" },
    { "$ref": "#/$defs/TaskCommit" },
    { "$ref": "#/$defs/Heartbeat" },
    { "$ref": "#/$defs/JobSubmitRequest" },
    { "$ref": "#/$defs/EmbedResult" },
    { "$ref": "#/$defs/BatchInferResult" }
  ]
}
