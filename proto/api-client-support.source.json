    {
      "id": "documented_native_clients_e2e",
      "kind": "black_box_subset",
      "command": "bash scripts/doc-as-test.sh",
      "scope": "Exercises documented curl submit/poll/results, Python submit/wait/results/embeddings, and CLI submit --wait against a running local stack."
    },
    {
      "id": "openai_batch_embeddings_db",
      "kind": "database_integration_subset",
      "command": "cx verify --ledger .artifacts/prove-local/proof-ledger.txt --mode contract_only --current-source --require-pass matrix:TestOpenAIBatchInlineEmbeddings",
      "scope": "When accepted by a terminal current-source proof ledger, this proves inline embeddings batch creation and batch status read; it does not cover chat batches, multipart file upload, output download, cancellation, sync, or streaming."
    },
    {
      "id": "openai_native_model_rejection",
      "kind": "unit_contract",
      "command": "(cd control && GOCACHE=\"$PWD/../.artifacts/go-cache\" go test . -run '^TestOpenAIBatch(ModelNamesAcceptOnlyNativeIdentityOrOmittedDefault|RejectsBrandedCrossModelAliasesWithNativeHint)$' -count=1)",
      "scope": "Proves only omitted defaults and exact native model IDs resolve, while former gpt-* and text-embedding-* rewrites return a typed error naming the endpoint and native model to use."
    },
    {
      "id": "runtime_projection",
      "kind": "deterministic_runtime_authority",
      "command": "python3 scripts/runtime_matrix.py --check --artifact-dir .artifacts/5x5/runtime-matrix && python3 -m unittest -v scripts/test_runtime_matrix.py",
      "scope": "Proves alias targets resolve to declared production job/model cells in the canonical matrix; physical runtime proof remains separate."
    }
