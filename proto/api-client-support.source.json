    {
      "id": "static_source_contract",
      "kind": "deterministic_static_contract",
      "command": "python3 scripts/api_contract.py --check --artifact-dir .artifacts/5x5/api-contract && python3 -m unittest -v scripts/test_api_contract.py && (cd control && GOCACHE=\"$PWD/../.artifacts/go-cache\" go test . -run '^(TestAdminLogoutIsPublicAndIdempotentWithoutSessionCookie|TestOpenAIBatch(ModelNamesAcceptOnlyNativeIdentityOrOmittedDefault|RejectsBrandedCrossModelAliasesWithNativeHint))$' -count=1)",
      "scope": "Exact route/auth inventory, public Python methods, CLI commands, declared route use, execution-mode flags, OpenAI endpoint labels and aliases, and runtime-target authority. It is not a live network proof."
    },
    {
      "id": "python_clean_install",
      "kind": "clean_install",
