@@ -0,0 +1,191 @@
+#!/usr/bin/env python3
+# SPDX-License-Identifier: Apache-2.0
+"""Build a deterministic prefix-cache corpus that actively exercises n-grams.
+
+This fixture is intentionally *not* a performance workload and does not reuse
+the historical Sonnet failure corpus.  It gives a parity gate a compact way to
+prove that a C16 candidate actually emitted n-gram drafts: every request has a
+shared cacheable prefix and ends with a repeated token-friendly sequence.
+
+The generated JSONL files follow ``spec_decode_paired_parity_gate.py``'s strict
+``request_id``/``prompt`` protocol.  The manifest binds their content and this
+builder's source.  All speed claims remain prohibited; this is correctness
+exercise input only.
+"""
+
+from __future__ import annotations
+
+import argparse
+import hashlib
+import json
+import os
+from pathlib import Path
+from typing import Any, Sequence
+
+
+SCHEMA = "cx.vllm_metal.ngram_exercise_fixture.v1"
+HISTORY_COUNT = 12
+CORPUS_COUNT = 16
+MIN_BASE_REPETITIONS = 6
+MIN_TAIL_REPETITIONS = 4
+
+
+class FixtureError(ValueError):
+    """The requested diagnostic fixture would be ambiguous or non-reproducible."""
+
+
+def canonical_json_bytes(value: Any) -> bytes:
+    return json.dumps(
+        value, sort_keys=True, ensure_ascii=False, separators=(",", ":")
+    ).encode("utf-8")
+
+
+def sha256_bytes(value: bytes) -> str:
+    return hashlib.sha256(value).hexdigest()
+
+
+def _source_sha256() -> str:
+    return sha256_bytes(Path(__file__).read_bytes())
+
+
+def _prompt(kind: str, index: int, *, base_repetitions: int, tail_repetitions: int) -> str:
+    # Keep a unique segment *before* the repeated suffix.  The common leading
+    # run creates a real prefix-cache hit; the final repeated run lets the
+    # upstream suffix matcher produce a concrete draft from prompt tokens.
+    base = "alpha beta gamma " * base_repetitions
+    tail = "alpha beta gamma " * tail_repetitions
+    return f"{base}{kind} marker {index}. {tail}"
+
+
+def build_records(
+    *,
+    kind: str,
+    count: int,
+    base_repetitions: int,
+    tail_repetitions: int,
+) -> list[dict[str, str]]:
+    if kind not in {"history", "measurement"}:
+        raise FixtureError("kind must be history or measurement")
+    if type(count) is not int or count < 1:
+        raise FixtureError("count must be a positive integer")
+    if type(base_repetitions) is not int or base_repetitions < MIN_BASE_REPETITIONS:
+        raise FixtureError(f"base_repetitions must be at least {MIN_BASE_REPETITIONS}")
+    if type(tail_repetitions) is not int or tail_repetitions < MIN_TAIL_REPETITIONS:
+        raise FixtureError(f"tail_repetitions must be at least {MIN_TAIL_REPETITIONS}")
+    return [
+        {
+            "request_id": f"ngram-exercise-{kind}-{index:03d}",
+            "prompt": _prompt(
+                kind,
+                index,
+                base_repetitions=base_repetitions,
+                tail_repetitions=tail_repetitions,
+            ),
+        }
+        for index in range(count)
+    ]
+
+
+def jsonl_bytes(records: Sequence[dict[str, str]]) -> bytes:
+    if not records:
+        raise FixtureError("records must not be empty")
+    return b"".join(canonical_json_bytes(record) + b"\n" for record in records)
+
+
+def _write_new(path: Path, value: bytes) -> None:
+    try:
+        fd = os.open(path, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
+    except FileExistsError as exc:
+        raise FixtureError(f"refusing to overwrite {path}") from exc
+    with os.fdopen(fd, "wb") as handle:
+        handle.write(value)
+        handle.flush()
+        os.fsync(handle.fileno())
+
+
+def write_fixture(
+    output_dir: Path,
+    *,
+    base_repetitions: int = 20,
+    tail_repetitions: int = 8,
+) -> dict[str, Any]:
+    if not output_dir.is_absolute() or output_dir.exists() or output_dir.is_symlink():
+        raise FixtureError("output_dir must be a new absolute non-symlink path")
+    if output_dir.parent.is_symlink() or not output_dir.parent.is_dir():
+        raise FixtureError("output_dir parent must be an existing non-symlink directory")
+    history = build_records(
+        kind="history",
+        count=HISTORY_COUNT,
+        base_repetitions=base_repetitions,
+        tail_repetitions=tail_repetitions,
+    )
+    corpus = build_records(
+        kind="measurement",
+        count=CORPUS_COUNT,
+        base_repetitions=base_repetitions,
+        tail_repetitions=tail_repetitions,
+    )
+    history_bytes = jsonl_bytes(history)
+    corpus_bytes = jsonl_bytes(corpus)
+    manifest = {
+        "schema": SCHEMA,
+        "purpose": "parity_only_active_ngram_exercise_not_a_speed_workload",
+        "builder": {"path": str(Path(__file__).resolve()), "sha256": _source_sha256()},
+        "parameters": {
+            "base_repetitions": base_repetitions,
+            "tail_repetitions": tail_repetitions,
+            "history_count": HISTORY_COUNT,
+            "corpus_count": CORPUS_COUNT,
+        },
+        "history": {
+            "sha256": sha256_bytes(history_bytes),
+            "request_order": [row["request_id"] for row in history],
+        },
+        "corpus": {
+            "sha256": sha256_bytes(corpus_bytes),
+            "request_order": [row["request_id"] for row in corpus],
+        },
+    }
+    os.mkdir(output_dir, mode=0o700)
+    try:
+        _write_new(output_dir / "history.jsonl", history_bytes)
+        _write_new(output_dir / "corpus.jsonl", corpus_bytes)
+        _write_new(output_dir / "fixture.json", canonical_json_bytes(manifest) + b"\n")
+    except BaseException:
+        for child in output_dir.iterdir():
+            child.unlink(missing_ok=True)
+        output_dir.rmdir()
+        raise
+    return manifest
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--output-dir", required=True, help="new absolute fixture directory")
+    parser.add_argument("--base-repetitions", type=int, default=20)
+    parser.add_argument("--tail-repetitions", type=int, default=8)
+    return parser
+
+
+def main(argv: Sequence[str] | None = None) -> int:
+    args = build_parser().parse_args(argv)
+    try:
+        manifest = write_fixture(
+            Path(args.output_dir),
+            base_repetitions=args.base_repetitions,
+            tail_repetitions=args.tail_repetitions,
+        )
+    except FixtureError as exc:
+        parser = build_parser()
+        parser.error(str(exc))
+    print(
+        "NGRAM_EXERCISE_FIXTURE_PASS "
+        f"history_sha256={manifest['history']['sha256']} "
+        f"corpus_sha256={manifest['corpus']['sha256']}",
+        flush=True,
+    )
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
