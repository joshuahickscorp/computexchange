+# SPDX-License-Identifier: Apache-2.0
+"""Model-free invariants for the deterministic Sonnet parity fixture builder."""
+
+from __future__ import annotations
+
+from types import SimpleNamespace
+import unittest
+
+from tools import build_sonnet_parity_fixture as fixture
+
+
+class _Tokenizer:
+    chat_template = "fixture-chat-template-v1"
+
+    def __call__(self, value: str) -> SimpleNamespace:
+        # The exact tokens are irrelevant to this unit test; stable whitespace
+        # tokenization gives the builder a realistic variable-length source.
+        return SimpleNamespace(input_ids=list(range(len(value.split()) or 1)))
+
+    def apply_chat_template(
+        self,
+        messages: list[dict[str, str]],
+        *,
+        add_generation_prompt: bool,
+        tokenize: bool,
+    ) -> str:
+        self.assert_flags(add_generation_prompt, tokenize)
+        return "<user> " + messages[0]["content"] + " <assistant>"
+
+    @staticmethod
+    def assert_flags(add_generation_prompt: bool, tokenize: bool) -> None:
+        if not add_generation_prompt or tokenize:
+            raise AssertionError("unexpected fixture chat-template flags")
+
+
+class TestSonnetParityFixture(unittest.TestCase):
+    def test_build_requests_is_deterministic_and_splits_sequential_ids(self) -> None:
+        lines = [f"line {index} repeats a unit-test phrase\n" for index in range(40)]
+        tokenizer = _Tokenizer()
+        first, first_lengths, first_sampler = fixture.build_requests(
+            lines,
+            tokenizer,
+            input_len=80,
+            prefix_len=24,
+            seed=0,
+            count=28,
+        )
+        second, second_lengths, second_sampler = fixture.build_requests(
+            lines,
+            tokenizer,
+            input_len=80,
+            prefix_len=24,
+            seed=0,
+            count=28,
+        )
+
+        self.assertEqual(first, second)
+        self.assertEqual(first_lengths, second_lengths)
+        self.assertEqual(first_sampler, second_sampler)
+        self.assertEqual([row["request_id"] for row in first], [f"sonnet-{i:03d}" for i in range(28)])
+        self.assertTrue(all(length <= 80 for length in first_lengths))
+        self.assertEqual(first[12]["request_id"], "sonnet-012")
+
+    def test_builder_rejects_impossible_input_budget(self) -> None:
+        with self.assertRaisesRegex(fixture.FixtureError, "must exceed"):
+            fixture.build_requests(
+                ["one stable line\n"],
+                _Tokenizer(),
+                input_len=1,
+                prefix_len=0,
+                count=1,
+            )
+
+    def test_jsonl_is_canonical_and_newline_terminated(self) -> None:
+        actual = fixture._jsonl_bytes(
+            [{"prompt": "hello", "request_id": "request-0"}]
+        )
+        self.assertEqual(
+            actual,
+            b'{"prompt":"hello","request_id":"request-0"}\n',
+        )
+
+
+if __name__ == "__main__":
+    unittest.main()
