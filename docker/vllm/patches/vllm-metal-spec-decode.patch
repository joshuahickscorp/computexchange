+# SPDX-License-Identifier: Apache-2.0
+"""Model-free checks for the active n-gram parity exercise fixture."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+import tempfile
+import unittest
+
+from tools import build_ngram_exercise_fixture as fixture
+
+
+class TestNgramExerciseFixture(unittest.TestCase):
+    def test_records_are_unique_and_end_in_a_repeated_draftable_suffix(self) -> None:
+        rows = fixture.build_records(
+            kind="measurement", count=16, base_repetitions=20, tail_repetitions=8
+        )
+        self.assertEqual(len(rows), 16)
+        self.assertEqual(len({row["request_id"] for row in rows}), 16)
+        self.assertTrue(all(row["prompt"].endswith("alpha beta gamma ") for row in rows))
+        self.assertTrue(all("measurement marker" in row["prompt"] for row in rows))
+
+    def test_writer_is_deterministic_and_binds_every_generated_file(self) -> None:
+        with tempfile.TemporaryDirectory() as temporary:
+            root = Path(temporary)
+            first = fixture.write_fixture(root / "first")
+            second = fixture.write_fixture(root / "second")
+            self.assertEqual(first["history"]["sha256"], second["history"]["sha256"])
+            self.assertEqual(first["corpus"]["sha256"], second["corpus"]["sha256"])
+            manifest = json.loads((root / "first" / "fixture.json").read_text())
+            self.assertEqual(manifest, first)
+            self.assertEqual(
+                fixture.sha256_bytes((root / "first" / "history.jsonl").read_bytes()),
+                first["history"]["sha256"],
+            )
+            self.assertEqual(
+                fixture.sha256_bytes((root / "first" / "corpus.jsonl").read_bytes()),
+                first["corpus"]["sha256"],
+            )
+
+    def test_invalid_repetition_budget_and_unsafe_output_are_rejected(self) -> None:
+        with self.assertRaises(fixture.FixtureError):
+            fixture.build_records(
+                kind="history", count=1, base_repetitions=2, tail_repetitions=8
+            )
+        with tempfile.TemporaryDirectory() as temporary:
+            with self.assertRaises(fixture.FixtureError):
+                fixture.write_fixture(Path(temporary))
+
+
+if __name__ == "__main__":
+    unittest.main()
