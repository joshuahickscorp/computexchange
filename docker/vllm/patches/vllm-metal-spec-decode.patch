+class _PrefixCacheTrace:
+    """Record real paged prefill start positions on the measured request."""
+
+    def __init__(self) -> None:
+        self.start_positions: list[int] = []
+        self._module: Any = None
+        self._original: Any = None
+
+    def __enter__(self) -> _PrefixCacheTrace:
+        from vllm_metal.v1 import model_runner  # noqa: PLC0415
+
+        self._module = model_runner
+        self._original = model_runner.prepare_unified
+
+        def traced_prepare_unified(decode_requests, prefill_requests, block_size):
+            for prefill in prefill_requests:
+                try:
+                    _, _, start_position = prefill
+                except (TypeError, ValueError) as exc:
+                    raise DiagnosticError(
+                        "unexpected paged prefill request shape while tracing cache"
+                    ) from exc
+                self.start_positions.append(int(start_position))
+            return self._original(decode_requests, prefill_requests, block_size)
+
+        model_runner.prepare_unified = traced_prepare_unified
+        return self
+
+    def __exit__(self, exc_type, exc_value, traceback) -> bool:
+        assert self._module is not None and self._original is not None
+        self._module.prepare_unified = self._original
+        return False
+
+
+class _DraftCounter:
+    """Observe a pre-fallback proposer without changing its draft decisions."""
+
+    def __init__(self, drafter: Any) -> None:
+        self._drafter = drafter
+        self._original: Any = None
+        self.draft_requests = 0
+        self.draft_tokens = 0
+        self.max_draft_width = 0
+
+    def __enter__(self) -> _DraftCounter:
+        self._original = self._drafter.propose
+
+        def counted(context):
+            drafts = self._original(context)
+            if drafts is not None:
+                request_ids = getattr(drafts, "req_ids", ())
+                tokens = getattr(drafts, "draft_token_ids", ())
+                self.draft_requests += len(request_ids)
+                self.draft_tokens += sum(len(row) for row in tokens)
+                widths = [len(row) for row in tokens]
+                if widths:
+                    self.max_draft_width = max(self.max_draft_width, *widths)
+            return drafts
+
+        self._drafter.propose = counted
+        return self
+
+    def reset(self) -> None:
+        self.draft_requests = 0
+        self.draft_tokens = 0
+        self.max_draft_width = 0
+
+    def __exit__(self, exc_type, exc_value, traceback) -> bool:
+        assert self._original is not None
+        self._drafter.propose = self._original
+        return False
+
+
+def _token_rows(
+    llm: Any,
+    requests: Sequence[dict[str, str]],
+    *,
+    sampling_params: Any,
+    max_tokens: int,
+) -> list[dict[str, Any]]:
+    """Issue exactly one C1 request at a time in immutable request order."""
+    rows: list[dict[str, Any]] = []
+    for request in requests:
+        outputs = llm.generate([request["prompt"]], sampling_params, use_tqdm=False)
+        if len(outputs) != 1 or outputs[0].prompt != request["prompt"]:
+            raise DiagnosticError("engine changed C1 request cardinality or order")
+        completions = outputs[0].outputs
+        if len(completions) != 1:
+            raise DiagnosticError("engine returned an unexpected completion count")
+        tokens = [int(token) for token in completions[0].token_ids]
+        if len(tokens) != max_tokens:
+            raise DiagnosticError(
+                f"request {request['request_id']!r} generated {len(tokens)} tokens; "
+                f"expected {max_tokens}"
+            )
+        rows.append({"request_id": request["request_id"], "token_ids": tokens})
+    return rows
+
+
+def _assert_engine_binding(llm: Any, manifest: Mapping[str, Any], arm: str) -> dict[str, Any]:
+    config = llm.llm_engine.vllm_config
+    profile = manifest["controlled_engine_profile"]
+    if bool(config.cache_config.enable_prefix_caching) is not bool(
+        profile["enable_prefix_caching"]
+    ):
+        raise DiagnosticError("engine prefix-cache setting differs from recovered profile")
+    if config.scheduler_config.async_scheduling is not False:
+        raise DiagnosticError("engine enabled async scheduling")
+    if config.scheduler_config.max_num_seqs != profile["max_num_seqs"]:
+        raise DiagnosticError("engine max_num_seqs differs from recovered profile")
+    if config.scheduler_config.max_num_batched_tokens != profile["max_num_batched_tokens"]:
+        raise DiagnosticError("engine resolved a different max_num_batched_tokens")
+    if config.model_config.max_model_len != profile["max_model_len"]:
+        raise DiagnosticError("engine resolved a different max_model_len")
+    runner = llm.llm_engine.model_executor.driver_worker.model_runner
+    metal_config = getattr(runner, "metal_config", None)
+    if metal_config is None or metal_config.use_paged_attention is not True:
+        raise DiagnosticError("engine did not resolve Metal paged attention")
+    if not math.isclose(
+        float(metal_config.memory_fraction),
+        float(profile["memory_fraction"]),
+        rel_tol=0.0,
+        abs_tol=1e-12,
+    ):
+        raise DiagnosticError("engine resolved a different memory fraction")
+    if getattr(runner, "paged_attention_runtime", None) is None:
+        raise DiagnosticError("engine lacks a paged-attention runtime")
+    binding: dict[str, Any] = {
+        "use_paged_attention": True,
+        "enable_prefix_caching": bool(config.cache_config.enable_prefix_caching),
+        "memory_fraction": float(metal_config.memory_fraction),
+        "max_num_seqs": config.scheduler_config.max_num_seqs,
+        "max_num_batched_tokens": config.scheduler_config.max_num_batched_tokens,
+        "max_model_len": config.model_config.max_model_len,
+        "paged_block_size": getattr(runner, "_paged_block_size", None),
+        "paged_attention_runtime_type": (
+            f"{type(runner.paged_attention_runtime).__module__}."
+            f"{type(runner.paged_attention_runtime).__qualname__}"
+        ),
+    }
+    speculative = config.speculative_config
+    if arm == "baseline":
+        if speculative is not None:
+            raise DiagnosticError("baseline unexpectedly resolved speculative decoding")
+        binding["proposer_type"] = None
+        return binding
+    if speculative is None or speculative.method != "ngram":
+        raise DiagnosticError("candidate did not resolve method=ngram")
+    if int(speculative.num_speculative_tokens) != HISTORICAL_NGRAM_K:
+        raise DiagnosticError("candidate did not resolve historical K=3")
+    if (
+        int(speculative.prompt_lookup_min) != HISTORICAL_LOOKUP_MIN
+        or int(speculative.prompt_lookup_max) != HISTORICAL_LOOKUP_MAX
+    ):
+        raise DiagnosticError("candidate did not resolve historical prompt lookup 2-4")
+    drafter = getattr(runner, "_drafter", None)
+    if drafter is None:
+        raise DiagnosticError("candidate has no installed n-gram proposer")
+    binding["proposer_type"] = f"{type(drafter).__module__}.{type(drafter).__qualname__}"
+    return binding
+
+
+def _run_child_main(args: argparse.Namespace) -> int:
+    if not all((args._child_arm, args._child_manifest, args._child_manifest_sha256, args._child_output)):
+        raise DiagnosticError("internal child invocation is incomplete")
+    manifest_path = _require_regular_file(args._child_manifest, "child manifest")
+    manifest, raw = _read_json_object(manifest_path, "child manifest")
+    actual_manifest_sha256 = _sha256_bytes(raw)
+    if actual_manifest_sha256 != args._child_manifest_sha256:
+        raise DiagnosticError("child manifest SHA-256 does not match parent binding")
+    if manifest.get("schema") != SCHEMA:
+        raise DiagnosticError("child manifest schema is unsupported")
+    arm = args._child_arm
+    repeat = args._child_repeat
+    if arm not in {"baseline", "ngram"} or not isinstance(repeat, int) or repeat < 0:
+        raise DiagnosticError("child arm or repeat is invalid")
+
+    runtime = _child_runtime_binding(
+        manifest["implementation"]["pre_fallback_ngram_proposer_sha256"]
+    )
+    from vllm import LLM, SamplingParams  # noqa: PLC0415
+
+    profile = manifest["controlled_engine_profile"]
+    kwargs: dict[str, Any] = {
+        "model": manifest["model"]["path"],
+        "revision": manifest["model"]["revision"],
+        "max_model_len": profile["max_model_len"],
+        "max_num_seqs": profile["max_num_seqs"],
+        "max_num_batched_tokens": profile["max_num_batched_tokens"],
+        "enable_prefix_caching": profile["enable_prefix_caching"],
+        "async_scheduling": False,
+    }
+    if arm == "ngram":
+        kwargs["speculative_config"] = {
+            "method": "ngram",
+            "num_speculative_tokens": HISTORICAL_NGRAM_K,
+            "prompt_lookup_min": HISTORICAL_LOOKUP_MIN,
+            "prompt_lookup_max": HISTORICAL_LOOKUP_MAX,
+        }
+    llm = LLM(**kwargs)
+    engine_binding = _assert_engine_binding(llm, manifest, arm)
+    sampling = manifest["sampling"]
+    history_sampling = SamplingParams(
+        temperature=sampling["temperature"],
+        top_p=sampling["top_p"],
+        top_k=sampling["top_k"],
+        max_tokens=sampling["history_max_tokens"],
+        ignore_eos=sampling["ignore_eos"],
+        seed=sampling["seed"],
+        detokenize=False,
+    )
+    measurement_sampling = SamplingParams(
+        temperature=sampling["temperature"],
+        top_p=sampling["top_p"],
+        top_k=sampling["top_k"],
+        max_tokens=sampling["measurement_max_tokens"],
+        ignore_eos=sampling["ignore_eos"],
+        seed=sampling["seed"],
+        detokenize=False,
+    )
+    inputs = manifest["inputs"]
+    history_requests = inputs["history_requests"]
+    measurement_request = inputs["measurement_request"]
+    if not isinstance(history_requests, list) or not isinstance(measurement_request, dict):
+        raise DiagnosticError("child manifest inputs are malformed")
+    runner = llm.llm_engine.model_executor.driver_worker.model_runner
+    counter: _DraftCounter | None = None
+    if arm == "ngram":
+        counter = _DraftCounter(runner._drafter)
+    with _PrefixCacheTrace() as cache_trace:
+        if counter is None:
+            history = _token_rows(
+                llm,
+                history_requests,
+                sampling_params=history_sampling,
+                max_tokens=HISTORICAL_HISTORY_MAX_TOKENS,
+            )
+            trace_offset = len(cache_trace.start_positions)
+            measurement_rows = _token_rows(
+                llm,
+                [measurement_request],
+                sampling_params=measurement_sampling,
+                max_tokens=HISTORICAL_TARGET_MAX_TOKENS,
+            )
+            history_drafts = measurement_drafts = None
+        else:
+            with counter:
+                history = _token_rows(
+                    llm,
+                    history_requests,
+                    sampling_params=history_sampling,
+                    max_tokens=HISTORICAL_HISTORY_MAX_TOKENS,
+                )
+                history_drafts = {
+                    "draft_requests": counter.draft_requests,
+                    "draft_tokens": counter.draft_tokens,
+                    "max_draft_width": counter.max_draft_width,
+                }
+                counter.reset()
+                trace_offset = len(cache_trace.start_positions)
+                measurement_rows = _token_rows(
+                    llm,
+                    [measurement_request],
+                    sampling_params=measurement_sampling,
+                    max_tokens=HISTORICAL_TARGET_MAX_TOKENS,
+                )
+                measurement_drafts = {
+                    "draft_requests": counter.draft_requests,
+                    "draft_tokens": counter.draft_tokens,
+                    "max_draft_width": counter.max_draft_width,
+                }
+    measurement_cache_hits = cache_trace.start_positions[trace_offset:]
+    if profile["enable_prefix_caching"]:
+        if not any(position > 0 for position in measurement_cache_hits):
+            raise DiagnosticError("measured sonnet-012 phase had no real paged prefix-cache hit")
+    elif any(position > 0 for position in measurement_cache_hits):
+        raise DiagnosticError("prefix-cache-disabled profile observed a cache hit")
+    if measurement_drafts is not None:
+        if not measurement_drafts["draft_requests"] or not measurement_drafts["draft_tokens"]:
+            raise DiagnosticError("pre-fallback candidate emitted no measured n-gram drafts")
+    result = {
+        "schema": CHILD_SCHEMA,
+        "status": "PASS",
+        "manifest_sha256": actual_manifest_sha256,
+        "arm": arm,
+        "repeat": repeat,
+        "runtime": runtime,
+        "engine_binding": engine_binding,
+        "measurement_cache_hit_start_positions": measurement_cache_hits,
+        "draft_activity": {
+            "history": history_drafts,
+            "measurement": measurement_drafts,
+        },
+        "outputs": {
+            "history": history,
+            "measurement": measurement_rows,
+        },
+    }
+    _write_new_json(args._child_output, result)
+    print(f"HISTORICAL_C1_CHILD_PASS arm={arm} repeat={repeat}", flush=True)
+    return 0
+
+
+def _child_env_expected(memory_fraction: float) -> dict[str, str]:
+    return {
+        "PYTHONHASHSEED": "0",
+        "VLLM_ENABLE_V1_MULTIPROCESSING": "0",
+        "VLLM_METAL_USE_PAGED_ATTENTION": "1",
+        "VLLM_METAL_MEMORY_FRACTION": str(memory_fraction),
+        "VLLM_PLUGINS": "metal",
+    }
+
