+# SPDX-License-Identifier: Apache-2.0
+"""Fast, model-free checks for the paired n-gram parity-gate protocol."""
+
+from __future__ import annotations
+
+import argparse
+import os
+from pathlib import Path
+import subprocess
+import sys
+import tempfile
+import unittest
+from unittest import mock
+
+from tools import spec_decode_paired_parity_gate as gate
+
+
+PINNED_REVISION = "a" * 40
+MAX_BATCHED_TOKENS = 1024
+MEMORY_FRACTION = 0.6
+
+
+def _write_requests(path: Path, prefix: str, count: int) -> None:
+    lines = [
+        f'{{"request_id":"{prefix}-{index}","prompt":"prompt {index}"}}'
+        for index in range(count)
+    ]
+    path.write_text("\n".join(lines) + "\n", encoding="utf-8")
+
+
+def _args(corpus: Path, *, history: str = "none", **overrides) -> argparse.Namespace:
+    values = {
+        "model": "Qwen/Qwen3-0.6B",
+        "model_revision": PINNED_REVISION,
+        "corpus": str(corpus),
+        "prefix_cache_history": history,
+        "concurrency": "1,16",
+        "ngram_k": "1,3",
+        "repeats": 2,
+        "max_tokens": 8,
+        "max_model_len": 512,
+        "max_num_batched_tokens": MAX_BATCHED_TOKENS,
+        "memory_fraction": MEMORY_FRACTION,
+        "prompt_lookup_min": 2,
+        "prompt_lookup_max": 3,
+        "timeout_seconds": 60,
+        "runtime_import_mode": "auto",
+    }
+    values.update(overrides)
+    return argparse.Namespace(**values)
+
+
+def _child(
+    *,
+    manifest_sha256: str,
+    arm: str,
+    repeat: int,
+    measurement_tokens: list[int],
+) -> dict:
+    return {
+        "schema": gate.CHILD_SCHEMA,
+        "status": "PASS",
+        "manifest_sha256": manifest_sha256,
+        "arm": arm,
+        "concurrency": 1,
+        "ngram_k": 1,
+        "repeat": repeat,
+        "runtime": {
+            "VLLM_ENABLE_V1_MULTIPROCESSING": "0",
+            "VLLM_METAL_USE_PAGED_ATTENTION": "1",
+            "VLLM_METAL_MEMORY_FRACTION": str(MEMORY_FRACTION),
+            "PYTHONHASHSEED": "0",
+            "runtime_import_mode": "installed_wheel",
+            "metal_artifact_mode": "installed_wheel_prebuilt",
+            "vllm_module_path": "/wheel/vllm/__init__.py",
+            "vllm_metal_module_path": "/wheel/vllm_metal/__init__.py",
+            "source_tree_sha256": None,
+            "vllm_distribution_record_sha256": "c" * 64,
+            "vllm_metal_distribution_record_sha256": "d" * 64,
+        },
+        "cache_hit_start_positions": [],
+        "engine_binding": {
+            "use_paged_attention": True,
+            "memory_fraction": MEMORY_FRACTION,
+            "paged_attention_runtime_installed": True,
+            "paged_attention_runtime_type": "vllm_metal.attention.runtime.MHAPagedAttentionRuntime",
+            "paged_block_size": 16,
+            "max_num_seqs": 1,
+            "max_num_batched_tokens": MAX_BATCHED_TOKENS,
+            "proposer_telemetry": (
+                None
+                if arm == "baseline"
+                else {
+                    "execution_mode": "ngram_enabled",
+                    "policy": "single_active_ngram_direct_only",
+                    "eligible_requests_bypassed": 0,
+                    "single_active_direct_fallbacks": 0,
+                    "draft_requests_emitted": 1,
+                    "draft_tokens_emitted": 3,
+                }
+            ),
+        },
+        "outputs": {
+            "history": [{"request_id": "history-0", "token_ids": [9, 8, 7]}],
+            "measurement": [
+                {"request_id": "measurement-0", "token_ids": measurement_tokens}
+            ],
+        },
+    }
+
+
+def _pair(manifest_sha256: str, repeat: int, tokens: list[int]) -> dict:
+    return {
+        "repeat": repeat,
+        "arm_order": ["baseline", "ngram"],
+        "baseline": _child(
+            manifest_sha256=manifest_sha256,
+            arm="baseline",
+            repeat=repeat,
+            measurement_tokens=tokens,
+        ),
+        "ngram": _child(
+            manifest_sha256=manifest_sha256,
+            arm="ngram",
+            repeat=repeat,
+            measurement_tokens=tokens,
+        ),
+    }
+
+
+class TestPairedNgramParityGate(unittest.TestCase):
+    def _validate(
+        self,
+        pairs: list[dict],
+        *,
+        prefix_cache_enabled: bool = False,
+    ) -> dict:
+        # Every helper invocation is a C1 cell.  The historical failure had
+        # prefix caching disabled, so the expected source behavior is direct
+        # fallback regardless of this optional cache-evidence fixture flag.
+        for pair in pairs:
+            telemetry = pair["ngram"]["engine_binding"]["proposer_telemetry"]
+            if telemetry["execution_mode"] == "ngram_enabled":
+                pair["ngram"]["engine_binding"]["proposer_telemetry"] = {
+                    "execution_mode": "direct_fallback_only",
+                    "policy": "single_active_ngram_direct_only",
+                    "eligible_requests_bypassed": 1,
+                    "single_active_direct_fallbacks": 1,
+                    "draft_requests_emitted": 0,
+                    "draft_tokens_emitted": 0,
+                }
+        return gate.validate_cell(
+            manifest_sha256="b" * 64,
+            concurrency=1,
+            ngram_k=1,
+            pairs=pairs,
+            expected_history_ids=["history-0"],
+            expected_measurement_ids=["measurement-0"],
+            max_tokens=3,
+            prefix_cache_enabled=prefix_cache_enabled,
+            memory_fraction=MEMORY_FRACTION,
+            max_num_batched_tokens=MAX_BATCHED_TOKENS,
+            runtime_import_mode="installed_wheel",
+            source_tree_sha256="e" * 64,
+        )
+
+    def test_build_manifest_binds_corpus_history_order_and_c_shapes(self) -> None:
+        with tempfile.TemporaryDirectory() as temporary:
+            temporary_path = Path(temporary)
+            corpus = temporary_path / "corpus.jsonl"
+            history = temporary_path / "history.jsonl"
+            _write_requests(corpus, "measurement", 16)
+            _write_requests(history, "history", 2)
+
+            manifest = gate.build_manifest(_args(corpus, history=str(history)))
+
+        self.assertEqual(manifest["model"]["revision"], PINNED_REVISION)
+        self.assertEqual(
+            manifest["corpus"]["request_order"],
+            [f"measurement-{index}" for index in range(16)],
+        )
+        self.assertTrue(manifest["prefix_cache"]["enabled"])
+        self.assertEqual(
+            manifest["prefix_cache"]["history_request_order"],
+            ["history-0", "history-1"],
+        )
+        self.assertEqual(
+            manifest["batch_plans"]["16"]["measurement"],
+            [[f"measurement-{index}" for index in range(16)]],
+        )
+        self.assertNotIn("inputs", gate._public_manifest(manifest))
+        self.assertIn(
+            manifest["engine"]["runtime_import_mode"],
+            {"source", "installed_wheel"},
+        )
+        self.assertIn(
+            manifest["engine"]["metal_artifact_mode"],
+            gate.METAL_ARTIFACT_MODES,
+        )
+        self.assertRegex(manifest["implementation"]["source_tree_sha256"], r"^[0-9a-f]{64}$")
+        self.assertEqual(
+            manifest["inputs"]["measurement_requests"][0]["prompt"], "prompt 0"
+        )
+
+    def test_build_manifest_rejects_nonstandard_shape_and_moving_revision(self) -> None:
+        with tempfile.TemporaryDirectory() as temporary:
+            corpus = Path(temporary) / "corpus.jsonl"
+            _write_requests(corpus, "measurement", 16)
+
+            with self.assertRaisesRegex(gate.GateError, "C1 and C16"):
+                gate.build_manifest(_args(corpus, concurrency="1"))
+            with self.assertRaisesRegex(gate.GateError, "full 40-character"):
+                gate.build_manifest(_args(corpus, model_revision="main"))
+
+    def test_runtime_mode_requires_complete_source_prebuilt_artifacts(self) -> None:
+        incomplete = gate._PrebuiltMetalArtifacts(
+            native_extension_available=True,
+            missing_metallibs=("gdn_kern",),
+        )
+        complete = gate._PrebuiltMetalArtifacts(
+            native_extension_available=True,
+            missing_metallibs=(),
+        )
+        self.assertEqual(
+            gate._resolve_runtime_selection(
+                "auto",
+                source_prebuilt_artifacts=incomplete,
+                source_build_requested=False,
+            ),
