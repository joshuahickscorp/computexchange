+#!/usr/bin/env python3
+# SPDX-License-Identifier: Apache-2.0
+"""Fail-closed HTTP replay of the recovered July C1/K3 server topology.
+
+This is a diagnostic-only companion to
+``reproduce_historical_c1_ngram_divergence.py``.  It intentionally uses a
+fresh *installed pre-fallback wheel* OpenAI server for every arm and sends the
+immutable Sonnet workload through ``POST /v1/completions`` one request at a
+time:
+
+``sonnet-000`` .. ``sonnet-011`` (150 tokens each), then ``sonnet-012``
+(93 tokens).  The recovered server profile is fixed here rather than exposed as
+a tuning surface:
+
+* ``max_num_seqs=32`` and ``max_num_batched_tokens=2048``;
+* Metal paged attention with memory fraction ``0.5``;
+* prefix caching disabled and synchronous scheduling;
+* V1 multiprocessing disabled (``VLLM_ENABLE_V1_MULTIPROCESSING=0``).
+
+The endpoint request adds ``return_token_ids=true`` solely so the diagnostic
+can inspect the known token-92 signature without trying to retokenize rendered
+text.  That response-only observability flag means this is a faithful server
+topology replay, not a claim that the original benchmark client bytes were
+identical.  The tool records no duration, latency, throughput, or speedup, and
+can never produce a promotion result.  A PASS only re-establishes the known
+unsafe pre-fallback behavior.
+
+The script is deliberately not executed by its unit tests.  When an operator
+executes it, it launches short-lived loopback servers and terminates every
+server before moving to the next ABBA arm.
+"""
+
+from __future__ import annotations
+
+import argparse
+import copy
+import hashlib
+import importlib.metadata
+import json
+import os
+from pathlib import Path
+import platform
+import signal
+import socket
+import subprocess
+import sys
+import tempfile
+import time
+from typing import Any, Iterator, Mapping, Sequence
+import urllib.error
+import urllib.request
+from contextlib import contextmanager
+import re
+
+
+SCHEMA = "cx.vllm_metal.historical_c1_k3_endpoint_diagnostic.v1"
+RUNTIME_SCHEMA = "cx.vllm_metal.historical_c1_k3_endpoint_runtime.v1"
+FIXTURE_SCHEMA = "cx.vllm_metal.sonnet_parity_fixture.v1"
+
+HISTORICAL_METAL_GIT_HEAD = "4c18ee0e6e3ce2b594ab114d0a53ca24eafb1d58"
+HISTORICAL_VLLM_METAL_VERSION = "0.3.0.dev20260713103604"
+HISTORICAL_VLLM_VERSION = "0.24.0+cpu"
+HISTORICAL_MODEL_REVISION = "08231374eeacb049a0eade7922910865b8fce912"
+HISTORICAL_HISTORY_COUNT = 12
+HISTORICAL_CORPUS_COUNT = 16
+HISTORICAL_HISTORY_IDS = tuple(f"sonnet-{index:03d}" for index in range(12))
+HISTORICAL_TARGET_ID = "sonnet-012"
+HISTORICAL_HISTORY_MAX_TOKENS = 150
+HISTORICAL_TARGET_MAX_TOKENS = 93
+HISTORICAL_DIVERGENCE_INDEX = 92
+HISTORICAL_BASELINE_TOKEN = 1875
+HISTORICAL_NGRAM_TOKEN = 702
+HISTORICAL_NGRAM_K = 3
+HISTORICAL_LOOKUP_MIN = 2
+HISTORICAL_LOOKUP_MAX = 4
+HISTORICAL_MAX_MODEL_LEN = 2048
+HISTORICAL_MAX_NUM_SEQS = 32
+HISTORICAL_MAX_NUM_BATCHED_TOKENS = 2048
+HISTORICAL_MEMORY_FRACTION = 0.5
+HISTORICAL_PREFIX_CACHING = False
+MIN_REPEATS = 2
+MAX_HTTP_BYTES = 8 << 20
+PIN_RE = re.compile(r"[0-9a-fA-F]{40}\Z")
+SHA256_RE = re.compile(r"[0-9a-f]{64}\Z")
+
+
+class EndpointDiagnosticError(RuntimeError):
+    """The endpoint replay cannot support a trustworthy finding."""
+
+
+class EndpointDiagnosticRunError(EndpointDiagnosticError):
+    """A run failure with only public, non-performance evidence attached."""
+
+    def __init__(
+        self,
+        message: str,
+        *,
+        manifest_sha256: str,
+        public_manifest: Mapping[str, Any],
+        observations: Sequence[Mapping[str, Any]],
+    ) -> None:
+        super().__init__(message)
+        self.manifest_sha256 = manifest_sha256
+        self.public_manifest = copy.deepcopy(dict(public_manifest))
+        self.observations = copy.deepcopy(list(observations))
+
+
+def _canonical_json(value: Any) -> bytes:
+    return json.dumps(
+        value, ensure_ascii=False, sort_keys=True, separators=(",", ":"), allow_nan=False
+    ).encode("utf-8")
+
+
+def _sha256_bytes(value: bytes) -> str:
+    return hashlib.sha256(value).hexdigest()
+
+
+def _sha256_file(path: Path) -> str:
+    digest = hashlib.sha256()
+    with path.open("rb") as handle:
+        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
+            digest.update(chunk)
+    return digest.hexdigest()
+
+
+def _tool_path() -> Path:
+    return Path(__file__).resolve()
+
+
+def _repo_root() -> Path:
+    return _tool_path().parents[1]
+
+
+def _source_metal_package_root() -> Path:
+    return _repo_root() / "vllm_metal"
+
+
+def _path_is_within(path: Path, parent: Path) -> bool:
+    try:
+        path.resolve().relative_to(parent.resolve())
+    except (OSError, ValueError):
+        return False
+    return True
+
+
+def _require_regular_file(value: str | Path, label: str) -> Path:
+    try:
+        path = Path(value).expanduser().resolve(strict=True)
+    except OSError as exc:
+        raise EndpointDiagnosticError(f"{label} does not resolve to a readable file") from exc
+    if not path.is_file():
+        raise EndpointDiagnosticError(f"{label} must be a regular file: {path}")
+    return path
+
+
+def _require_model_path(value: str) -> Path:
+    try:
+        path = Path(value).expanduser().resolve(strict=True)
+    except OSError as exc:
+        raise EndpointDiagnosticError("--model does not resolve to a local directory") from exc
+    if not path.is_dir():
+        raise EndpointDiagnosticError("--model must be the pinned local model directory")
+    return path
+
+
+def _unique_object(pairs: list[tuple[str, Any]]) -> dict[str, Any]:
+    value: dict[str, Any] = {}
+    for key, item in pairs:
+        if key in value:
+            raise EndpointDiagnosticError(f"duplicate JSON key {key!r}")
+        value[key] = item
+    return value
+
+
+def _read_json_object(path: Path, label: str) -> tuple[dict[str, Any], bytes]:
+    raw = path.read_bytes()
+    try:
+        value = json.loads(raw, object_pairs_hook=_unique_object)
+    except (UnicodeDecodeError, json.JSONDecodeError, EndpointDiagnosticError) as exc:
+        raise EndpointDiagnosticError(f"{label} is not a valid JSON object") from exc
+    if not isinstance(value, dict):
+        raise EndpointDiagnosticError(f"{label} must be a JSON object")
+    return value, raw
+
+
+def _read_requests(path: Path, label: str) -> tuple[list[dict[str, str]], str]:
+    raw = path.read_bytes()
+    try:
+        lines = raw.decode("utf-8").splitlines()
+    except UnicodeDecodeError as exc:
+        raise EndpointDiagnosticError(f"{label} must be UTF-8 JSONL") from exc
+    if not lines:
+        raise EndpointDiagnosticError(f"{label} must not be empty")
+    requests: list[dict[str, str]] = []
+    seen: set[str] = set()
+    for line_number, line in enumerate(lines, start=1):
+        if not line.strip():
+            raise EndpointDiagnosticError(f"{label} has a blank line at {line_number}")
+        try:
+            row = json.loads(line, object_pairs_hook=_unique_object)
+        except (json.JSONDecodeError, EndpointDiagnosticError) as exc:
+            raise EndpointDiagnosticError(f"{label} line {line_number} is invalid JSON") from exc
+        if not isinstance(row, dict) or set(row) != {"request_id", "prompt"}:
+            raise EndpointDiagnosticError(
+                f"{label} line {line_number} must contain only request_id and prompt"
+            )
+        request_id = row["request_id"]
+        prompt = row["prompt"]
+        if not isinstance(request_id, str) or not request_id or request_id in seen:
+            raise EndpointDiagnosticError(f"{label} line {line_number} has an invalid request_id")
+        if not isinstance(prompt, str) or not prompt:
+            raise EndpointDiagnosticError(f"{label} line {line_number} has an invalid prompt")
+        seen.add(request_id)
+        requests.append({"request_id": request_id, "prompt": prompt})
+    return requests, _sha256_bytes(raw)
+
+
+def _require_sha256(value: Any, label: str) -> str:
+    if not isinstance(value, str) or not SHA256_RE.fullmatch(value):
+        raise EndpointDiagnosticError(f"{label} must be a lowercase SHA-256")
+    return value
+
+
+def _fixture_section(
+    fixture: Mapping[str, Any], key: str, *, expected_count: int, expected_order: Sequence[str]
+) -> dict[str, Any]:
+    value = fixture.get(key)
+    if not isinstance(value, dict):
+        raise EndpointDiagnosticError(f"fixture {key} section is missing")
+    if value.get("request_count") != expected_count:
+        raise EndpointDiagnosticError(f"fixture {key} request_count is not historical")
+    if value.get("request_order") != list(expected_order):
+        raise EndpointDiagnosticError(f"fixture {key} request order is not historical")
+    _require_sha256(value.get("sha256"), f"fixture {key}.sha256")
+    return copy.deepcopy(value)
+
+
+def _validate_fixture(
+    fixture: Mapping[str, Any],
+    *,
+    history_sha256: str,
+    corpus_sha256: str,
+    model_path: Path,
+    model_revision: str,
+) -> dict[str, Any]:
+    if fixture.get("schema") != FIXTURE_SCHEMA:
+        raise EndpointDiagnosticError("fixture has an unsupported schema")
+    expected_corpus_ids = [
+        f"sonnet-{index:03d}" for index in range(12, 12 + HISTORICAL_CORPUS_COUNT)
+    ]
+    history = _fixture_section(
+        fixture,
+        "history",
+        expected_count=HISTORICAL_HISTORY_COUNT,
+        expected_order=HISTORICAL_HISTORY_IDS,
+    )
+    corpus = _fixture_section(
+        fixture,
+        "corpus",
+        expected_count=HISTORICAL_CORPUS_COUNT,
+        expected_order=expected_corpus_ids,
+    )
+    if history["sha256"] != history_sha256 or corpus["sha256"] != corpus_sha256:
+        raise EndpointDiagnosticError("fixture JSONL digest differs from the supplied input")
+    model = fixture.get("model")
+    if not isinstance(model, dict):
+        raise EndpointDiagnosticError("fixture model section is missing")
+    expected_path = model.get("path")
+    if not isinstance(expected_path, str) or model_path != Path(expected_path).expanduser().resolve():
+        raise EndpointDiagnosticError("--model differs from fixture's pinned local model path")
+    if model_revision != HISTORICAL_MODEL_REVISION:
+        raise EndpointDiagnosticError("--model-revision is not the historical pinned revision")
+    artifact_paths = {
+        "model_safetensors_sha256": model_path / "model.safetensors",
+        "tokenizer_json_sha256": model_path / "tokenizer.json",
+        "config_json_sha256": model_path / "config.json",
+    }
+    for key, path in artifact_paths.items():
+        expected = _require_sha256(model.get(key), f"fixture model.{key}")
+        if _sha256_file(_require_regular_file(path, key)) != expected:
+            raise EndpointDiagnosticError(f"pinned model artifact differs: {key}")
+    _require_sha256(model.get("chat_template_sha256"), "fixture model.chat_template_sha256")
+    return {"history": history, "corpus": corpus, "model": copy.deepcopy(model)}
+
+
+def _historical_pre_fallback_ngram_sha256() -> str:
+    try:
+        contents = subprocess.check_output(
+            [
+                "git",
+                "show",
+                f"{HISTORICAL_METAL_GIT_HEAD}:vllm_metal/v1/ngram_proposer.py",
+            ],
+            cwd=_repo_root(),
+            stderr=subprocess.DEVNULL,
+        )
+    except (OSError, subprocess.CalledProcessError) as exc:
+        raise EndpointDiagnosticError(
+            "the historical pre-fallback ngram proposer object is unavailable in git"
+        ) from exc
+    return _sha256_bytes(contents)
+
+
+def _write_new_json(path_text: str | Path, value: Mapping[str, Any]) -> Path:
+    path = Path(path_text).expanduser()
+    try:
+        parent = path.parent.resolve(strict=True)
+    except OSError as exc:
+        raise EndpointDiagnosticError(f"output parent does not exist: {path.parent}") from exc
+    target = parent / path.name
+    payload = _canonical_json(value) + b"\n"
+    try:
+        fd = os.open(target, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
+    except FileExistsError as exc:
+        raise EndpointDiagnosticError(f"refusing to overwrite existing output: {target}") from exc
+    try:
+        with os.fdopen(fd, "wb") as handle:
+            handle.write(payload)
+            handle.flush()
+            os.fsync(handle.fileno())
+    except BaseException:
+        target.unlink(missing_ok=True)
+        raise
+    return target
+
+
+def _public_manifest(manifest: Mapping[str, Any]) -> dict[str, Any]:
+    return {key: copy.deepcopy(value) for key, value in manifest.items() if key != "inputs"}
+
+
+def build_manifest(args: argparse.Namespace) -> dict[str, Any]:
+    """Bind all immutable inputs before any endpoint/server process starts."""
+    if not PIN_RE.fullmatch(args.model_revision or ""):
+        raise EndpointDiagnosticError("--model-revision must be a full 40-character SHA")
+    if args.repeats < MIN_REPEATS:
+        raise EndpointDiagnosticError(f"--repeats must be at least {MIN_REPEATS}")
+    if args.server_start_timeout_seconds <= 0 or args.request_timeout_seconds <= 0:
+        raise EndpointDiagnosticError("server and request timeouts must be positive")
+    model_path = _require_model_path(args.model)
+    fixture_path = _require_regular_file(args.fixture_manifest, "--fixture-manifest")
+    history_path = _require_regular_file(args.history, "--history")
+    corpus_path = _require_regular_file(args.corpus, "--corpus")
+    fixture, fixture_raw = _read_json_object(fixture_path, "fixture manifest")
+    history, history_sha256 = _read_requests(history_path, "history JSONL")
+    corpus, corpus_sha256 = _read_requests(corpus_path, "corpus JSONL")
+    if [row["request_id"] for row in history] != list(HISTORICAL_HISTORY_IDS):
+        raise EndpointDiagnosticError("history JSONL is not exactly sonnet-000 through sonnet-011")
+    expected_corpus_ids = [
+        f"sonnet-{index:03d}" for index in range(12, 12 + HISTORICAL_CORPUS_COUNT)
+    ]
+    if [row["request_id"] for row in corpus] != expected_corpus_ids:
+        raise EndpointDiagnosticError("corpus JSONL is not the complete historical sonnet-012..027 fixture")
+    revision = args.model_revision.lower()
+    fixture_binding = _validate_fixture(
+        fixture,
+        history_sha256=history_sha256,
+        corpus_sha256=corpus_sha256,
+        model_path=model_path,
+        model_revision=revision,
+    )
+    return {
+        "schema": SCHEMA,
+        "claim_scope": "diagnostic_only_no_speed_or_promotion_claim",
+        "timing_collected": False,
+        "implementation": {
+            "tool_path": str(_tool_path()),
+            "tool_sha256": _sha256_file(_tool_path()),
+            "historical_metal_git_head": HISTORICAL_METAL_GIT_HEAD,
+            "pre_fallback_ngram_proposer_sha256": _historical_pre_fallback_ngram_sha256(),
+        },
+        "fixture": {"path": str(fixture_path), "sha256": _sha256_bytes(fixture_raw), **fixture_binding},
+        "model": {"path": str(model_path), "revision": revision},
+        "recovered_server_profile": {
+            "name": "recovered_july_openai_server_c1_profile",
+            "historical_server_launch_recovered": True,
+            "historical_client_payload_byte_identical": False,
+            "endpoint": "/v1/completions",
+            "endpoint_transport": "loopback_http",
+            "max_model_len": HISTORICAL_MAX_MODEL_LEN,
+            "max_num_seqs": HISTORICAL_MAX_NUM_SEQS,
+            "max_num_batched_tokens": HISTORICAL_MAX_NUM_BATCHED_TOKENS,
+            "memory_fraction": HISTORICAL_MEMORY_FRACTION,
+            "enable_prefix_caching": HISTORICAL_PREFIX_CACHING,
+            "async_scheduling": False,
+            "v1_multiprocessing": False,
+            "paged_attention_required": True,
+            "response_observability": "return_token_ids_true",
+        },
+        "sampling": {
+            "temperature": 0.0,
+            "top_p": 1.0,
+            "top_k": -1,
+            "ignore_eos": True,
+            "seed": 0,
+            "n": 1,
+            "logprobs": 0,
+            "stream": False,
+            "history_max_tokens": HISTORICAL_HISTORY_MAX_TOKENS,
+            "measurement_max_tokens": HISTORICAL_TARGET_MAX_TOKENS,
+        },
+        "candidate": {
+            "method": "ngram",
+            "ngram_k": HISTORICAL_NGRAM_K,
+            "prompt_lookup_min": HISTORICAL_LOOKUP_MIN,
+            "prompt_lookup_max": HISTORICAL_LOOKUP_MAX,
+            "pre_fallback_installed_wheel_required": True,
+        },
+        "expected_signature": {
+            "request_id": HISTORICAL_TARGET_ID,
+            "first_divergence_zero_based_output_index": HISTORICAL_DIVERGENCE_INDEX,
+            "baseline_token_id": HISTORICAL_BASELINE_TOKEN,
+            "ngram_token_id": HISTORICAL_NGRAM_TOKEN,
+        },
+        "repeats": args.repeats,
+        "timeouts": {
+            "server_start_seconds": args.server_start_timeout_seconds,
+            "request_seconds": args.request_timeout_seconds,
+        },
+        "inputs": {"history_requests": history, "measurement_request": corpus[0]},
+    }
+
+
+def _server_env() -> dict[str, str]:
+    """Return the only environment used by both runtime probe and server."""
+    env = os.environ.copy()
+    env.update(
+        {
+            "PYTHONHASHSEED": "0",
+            "VLLM_ENABLE_V1_MULTIPROCESSING": "0",
+            "VLLM_METAL_USE_PAGED_ATTENTION": "1",
+            "VLLM_METAL_MEMORY_FRACTION": str(HISTORICAL_MEMORY_FRACTION),
+            "VLLM_PLUGINS": "metal",
+        }
+    )
+    env.pop("VLLM_METAL_BUILD_FROM_SOURCE", None)
+    root = _repo_root().resolve()
+    retained: list[str] = []
+    for entry in env.get("PYTHONPATH", "").split(os.pathsep):
+        if not entry:
+            continue
+        try:
+            resolved = Path(entry).expanduser().resolve()
+        except OSError:
+            resolved = None
+        if resolved is None or not _path_is_within(resolved, root):
+            retained.append(entry)
+    if retained:
+        env["PYTHONPATH"] = os.pathsep.join(retained)
+    else:
+        env.pop("PYTHONPATH", None)
+    return env
+
+
+def _expected_environment() -> dict[str, str | None]:
+    return {
+        "PYTHONHASHSEED": "0",
+        "VLLM_ENABLE_V1_MULTIPROCESSING": "0",
+        "VLLM_METAL_USE_PAGED_ATTENTION": "1",
+        "VLLM_METAL_MEMORY_FRACTION": str(HISTORICAL_MEMORY_FRACTION),
+        "VLLM_PLUGINS": "metal",
+        "VLLM_METAL_BUILD_FROM_SOURCE": None,
+    }
+
+
+def _distribution_record_sha256(name: str) -> str:
+    try:
+        distribution = importlib.metadata.distribution(name)
+        record = distribution._path / "RECORD"  # type: ignore[attr-defined]
+        return _sha256_file(record)
+    except (importlib.metadata.PackageNotFoundError, OSError, AttributeError) as exc:
+        raise EndpointDiagnosticError(f"unable to bind installed distribution {name!r}") from exc
+
+
+def _runtime_probe_payload(expected_ngram_sha256: str) -> dict[str, Any]:
+    """Run only in the isolated probe child; it never creates an engine."""
+    import vllm  # noqa: PLC0415
+    import vllm_metal  # noqa: PLC0415
+
+    metal_path = Path(vllm_metal.__file__).resolve()
+    vllm_path = Path(vllm.__file__).resolve()
+    ngram_path = metal_path.parent / "v1" / "ngram_proposer.py"
+    extensions = sorted((metal_path.parent / "metal").glob("_paged_ops*.so"))
+    if _path_is_within(metal_path, _source_metal_package_root()) or "site-packages" not in metal_path.parts:
+        raise EndpointDiagnosticError("runtime probe imported source Metal code, not an installed wheel")
+    if "site-packages" not in vllm_path.parts:
+        raise EndpointDiagnosticError("runtime probe did not import an installed vLLM wheel")
+    if not extensions:
+        raise EndpointDiagnosticError("installed Metal wheel lacks a paged-attention extension")
+    actual_ngram = _sha256_file(_require_regular_file(ngram_path, "wheel ngram proposer"))
+    if actual_ngram != expected_ngram_sha256:
+        raise EndpointDiagnosticError("installed wheel ngram proposer is not the pre-fallback object")
+    return {
+        "schema": RUNTIME_SCHEMA,
+        "runtime_import_mode": "installed_wheel_pre_fallback_only",
+        "python_executable": str(Path(sys.executable).resolve()),
+        "python_executable_sha256": _sha256_file(Path(sys.executable).resolve()),
+        "environment": {key: os.environ.get(key) for key in _expected_environment()},
+        "vllm_module_path": str(vllm_path),
+        "vllm_metal_module_path": str(metal_path),
+        "vllm_version": importlib.metadata.version("vllm"),
+        "vllm_metal_version": importlib.metadata.version("vllm-metal"),
+        "vllm_distribution_record_sha256": _distribution_record_sha256("vllm"),
+        "vllm_metal_distribution_record_sha256": _distribution_record_sha256("vllm-metal"),
+        "ngram_proposer_path": str(ngram_path),
+        "ngram_proposer_sha256": actual_ngram,
+        "paged_extensions": [
+            {"path": str(path.resolve()), "sha256": _sha256_file(path)} for path in extensions
+        ],
+        "platform": platform.platform(),
+        "machine": platform.machine(),
+    }
+
+
+def _runtime_probe_main(args: argparse.Namespace) -> int:
+    if not args._runtime_probe_output or not args._runtime_probe_expected_ngram_sha256:
+        raise EndpointDiagnosticError("internal runtime probe invocation is incomplete")
+    expected = _require_sha256(args._runtime_probe_expected_ngram_sha256, "runtime probe hash")
+    _write_new_json(args._runtime_probe_output, _runtime_probe_payload(expected))
+    return 0
+
+
+def _read_runtime_probe(path: Path) -> dict[str, Any]:
+    value, _ = _read_json_object(path, "runtime probe result")
+    return value
+
+
+def _validate_runtime_probe(value: Mapping[str, Any], expected_ngram_sha256: str) -> dict[str, Any]:
+    if value.get("schema") != RUNTIME_SCHEMA:
+        raise EndpointDiagnosticError("runtime probe has an unsupported schema")
+    if value.get("runtime_import_mode") != "installed_wheel_pre_fallback_only":
+        raise EndpointDiagnosticError("runtime probe did not use installed pre-fallback wheel mode")
+    if value.get("vllm_version") != HISTORICAL_VLLM_VERSION:
+        raise EndpointDiagnosticError("runtime probe vLLM version differs from historical wheel")
+    if value.get("vllm_metal_version") != HISTORICAL_VLLM_METAL_VERSION:
+        raise EndpointDiagnosticError("runtime probe Metal version differs from historical wheel")
+    if value.get("ngram_proposer_sha256") != expected_ngram_sha256:
+        raise EndpointDiagnosticError("runtime probe ngram proposer differs from historical object")
+    for key, expected in _expected_environment().items():
+        environment = value.get("environment")
+        if not isinstance(environment, dict) or environment.get(key) != expected:
+            raise EndpointDiagnosticError(f"runtime probe environment differs for {key}")
+    for key in (
+        "python_executable_sha256",
+        "vllm_distribution_record_sha256",
+        "vllm_metal_distribution_record_sha256",
+    ):
+        _require_sha256(value.get(key), f"runtime probe {key}")
+    for path_key in ("vllm_module_path", "vllm_metal_module_path", "ngram_proposer_path"):
+        path_value = value.get(path_key)
+        if not isinstance(path_value, str) or not path_value:
+            raise EndpointDiagnosticError(f"runtime probe {path_key} is malformed")
+    metal_path = Path(str(value["vllm_metal_module_path"]))
+    vllm_path = Path(str(value["vllm_module_path"]))
+    if _path_is_within(metal_path, _source_metal_package_root()) or "site-packages" not in metal_path.parts:
+        raise EndpointDiagnosticError("runtime probe classified a source package as an installed wheel")
+    if "site-packages" not in vllm_path.parts:
+        raise EndpointDiagnosticError("runtime probe classified a source vLLM package as an installed wheel")
+    extensions = value.get("paged_extensions")
+    if not isinstance(extensions, list) or not extensions:
+        raise EndpointDiagnosticError("runtime probe has no paged extension binding")
+    for extension in extensions:
+        if not isinstance(extension, dict) or not isinstance(extension.get("path"), str):
+            raise EndpointDiagnosticError("runtime probe paged extension binding is malformed")
+        _require_sha256(extension.get("sha256"), "runtime probe paged extension SHA-256")
+    return copy.deepcopy(dict(value))
+
+
+def _run_runtime_probe(work_dir: Path, expected_ngram_sha256: str, name: str) -> dict[str, Any]:
+    output = work_dir / f"runtime-{name}.json"
+    command = [
+        sys.executable,
+        "-B",
+        str(_tool_path()),
+        "--_runtime-probe",
+        "--_runtime-probe-expected-ngram-sha256",
+        expected_ngram_sha256,
+        "--_runtime-probe-output",
+        str(output),
+    ]
+    try:
+        completed = subprocess.run(
+            command,
+            cwd=work_dir,
+            env=_server_env(),
+            capture_output=True,
+            text=True,
+            timeout=60,
+            check=False,
+        )
+    except subprocess.TimeoutExpired as exc:
+        raise EndpointDiagnosticError("runtime probe exceeded 60 seconds") from exc
+    if completed.returncode != 0 or not output.exists():
+        raise EndpointDiagnosticError("runtime probe failed before an endpoint server could start")
+    return _validate_runtime_probe(_read_runtime_probe(output), expected_ngram_sha256)
+
+
+def _server_command(manifest: Mapping[str, Any], arm: str, port: int) -> list[str]:
+    if arm not in {"baseline", "ngram"}:
+        raise EndpointDiagnosticError("server arm is invalid")
+    profile = manifest["recovered_server_profile"]
+    command = [
+        sys.executable,
+        "-B",
+        "-m",
+        "vllm.entrypoints.cli.main",
+        "serve",
+        str(manifest["model"]["path"]),
+        "--revision",
+        str(manifest["model"]["revision"]),
+        "--host",
+        "127.0.0.1",
+        "--port",
+        str(port),
+        "--max-model-len",
+        str(profile["max_model_len"]),
+        "--max-num-seqs",
+        str(profile["max_num_seqs"]),
+        "--max-num-batched-tokens",
+        str(profile["max_num_batched_tokens"]),
+        "--no-enable-prefix-caching",
+        "--no-async-scheduling",
+    ]
+    if arm == "ngram":
+        candidate = manifest["candidate"]
+        command.extend(
+            [
+                "--speculative-config",
+                _canonical_json(
+                    {
+                        "method": "ngram",
+                        "num_speculative_tokens": candidate["ngram_k"],
+                        "prompt_lookup_min": candidate["prompt_lookup_min"],
+                        "prompt_lookup_max": candidate["prompt_lookup_max"],
+                    }
+                ).decode("utf-8"),
+            ]
+        )
+    return command
+
+
+def _server_launch_projection(manifest: Mapping[str, Any], arm: str) -> dict[str, Any]:
+    profile = manifest["recovered_server_profile"]
+    candidate = manifest["candidate"]
+    return {
+        "entrypoint": "python -m vllm.entrypoints.cli.main serve",
+        "loopback_host": "127.0.0.1",
+        "ephemeral_port": True,
+        "max_model_len": profile["max_model_len"],
+        "max_num_seqs": profile["max_num_seqs"],
+        "max_num_batched_tokens": profile["max_num_batched_tokens"],
+        "enable_prefix_caching": profile["enable_prefix_caching"],
+        "async_scheduling": profile["async_scheduling"],
+        "environment": _expected_environment(),
+        "speculative_config": (
+            None
+            if arm == "baseline"
+            else {
+                "method": "ngram",
+                "num_speculative_tokens": candidate["ngram_k"],
+                "prompt_lookup_min": candidate["prompt_lookup_min"],
+                "prompt_lookup_max": candidate["prompt_lookup_max"],
+            }
+        ),
+    }
+
+
+def _reserve_loopback_port() -> int:
+    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
+        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
+        sock.bind(("127.0.0.1", 0))
+        return int(sock.getsockname()[1])
+
+
+def _request_json(url: str, body: Mapping[str, Any], timeout_seconds: int) -> dict[str, Any]:
+    request = urllib.request.Request(
+        url,
+        data=_canonical_json(dict(body)),
+        headers={"Content-Type": "application/json", "Accept": "application/json"},
+        method="POST",
+    )
+    try:
+        with urllib.request.build_opener(_NoRedirect()).open(request, timeout=timeout_seconds) as response:
+            raw = response.read(MAX_HTTP_BYTES + 1)
+            status = response.status
+    except urllib.error.HTTPError as exc:
+        raise EndpointDiagnosticError(f"OpenAI endpoint returned HTTP {exc.code}") from exc
+    except (urllib.error.URLError, TimeoutError, OSError) as exc:
+        raise EndpointDiagnosticError("OpenAI endpoint request failed") from exc
+    if not 200 <= status < 300 or len(raw) > MAX_HTTP_BYTES:
+        raise EndpointDiagnosticError("OpenAI endpoint returned an invalid response size/status")
+    try:
+        value = json.loads(raw, object_pairs_hook=_unique_object)
+    except (UnicodeDecodeError, json.JSONDecodeError, EndpointDiagnosticError) as exc:
+        raise EndpointDiagnosticError("OpenAI endpoint returned invalid JSON") from exc
+    if not isinstance(value, dict):
+        raise EndpointDiagnosticError("OpenAI endpoint response must be an object")
+    return value
+
+
+class _NoRedirect(urllib.request.HTTPRedirectHandler):
+    def redirect_request(self, *_args: Any, **_kwargs: Any) -> None:
+        return None
+
+
+def _wait_for_health(process: subprocess.Popen[Any], base_url: str, timeout_seconds: int) -> None:
+    deadline = time.monotonic() + timeout_seconds
+    while time.monotonic() < deadline:
+        if process.poll() is not None:
+            raise EndpointDiagnosticError("endpoint server exited before becoming healthy")
+        try:
+            with urllib.request.build_opener(_NoRedirect()).open(
+                f"{base_url}/health", timeout=2
+            ) as response:
+                if response.status == 200:
+                    return
+        except (urllib.error.URLError, TimeoutError, OSError):
+            pass
+        time.sleep(0.25)
+    raise EndpointDiagnosticError("endpoint server did not become healthy before deadline")
+
+
+def _terminate_server(process: subprocess.Popen[Any]) -> None:
+    if process.poll() is not None:
+        return
+    try:
+        os.killpg(process.pid, signal.SIGTERM)
+    except (OSError, ProcessLookupError):
+        process.terminate()
+    try:
+        process.wait(timeout=30)
+    except subprocess.TimeoutExpired:
+        try:
+            os.killpg(process.pid, signal.SIGKILL)
+        except (OSError, ProcessLookupError):
+            process.kill()
+        process.wait(timeout=10)
+
+
+@contextmanager
+def _launched_server(
+    command: Sequence[str], *, env: Mapping[str, str], work_dir: Path, log_path: Path
+) -> Iterator[tuple[subprocess.Popen[Any], str]]:
+    with log_path.open("xb") as log_handle:
+        process = subprocess.Popen(
+            list(command),
+            cwd=work_dir,
+            env=dict(env),
+            stdin=subprocess.DEVNULL,
+            stdout=log_handle,
+            stderr=subprocess.STDOUT,
+            start_new_session=True,
+        )
+        try:
+            port_index = list(command).index("--port") + 1
+            base_url = f"http://127.0.0.1:{command[port_index]}"
+            yield process, base_url
+        finally:
+            _terminate_server(process)
+
+
+def _completion_body(manifest: Mapping[str, Any], prompt: str, request_id: str, max_tokens: int) -> dict[str, Any]:
+    sampling = manifest["sampling"]
+    return {
+        "model": manifest["model"]["path"],
+        "prompt": prompt,
+        "max_tokens": max_tokens,
+        "temperature": sampling["temperature"],
+        "top_p": sampling["top_p"],
+        "top_k": sampling["top_k"],
+        "ignore_eos": sampling["ignore_eos"],
+        "seed": sampling["seed"],
+        "n": sampling["n"],
+        "logprobs": sampling["logprobs"],
+        "stream": sampling["stream"],
+        "stop": [],
+        "return_token_ids": True,
+        "request_id": request_id,
+    }
+
+
+def _completion_token_ids(response: Mapping[str, Any], expected_count: int) -> list[int]:
+    choices = response.get("choices")
+    if not isinstance(choices, list) or len(choices) != 1 or not isinstance(choices[0], dict):
+        raise EndpointDiagnosticError("OpenAI endpoint response must contain exactly one choice")
+    choice = choices[0]
+    if choice.get("index") != 0 or not isinstance(choice.get("text"), str):
+        raise EndpointDiagnosticError("OpenAI endpoint choice is malformed")
+    token_ids = choice.get("token_ids")
+    if not isinstance(token_ids, list) or not all(type(token) is int and token >= 0 for token in token_ids):
+        raise EndpointDiagnosticError("OpenAI endpoint did not return integer token_ids")
+    if len(token_ids) != expected_count:
+        raise EndpointDiagnosticError(
+            f"OpenAI endpoint returned {len(token_ids)} tokens; expected {expected_count}"
+        )
+    usage = response.get("usage")
+    if isinstance(usage, dict) and "completion_tokens" in usage:
+        if usage["completion_tokens"] != len(token_ids):
+            raise EndpointDiagnosticError("endpoint usage disagrees with returned token_ids")
+    return list(token_ids)
+
+
+def _run_arm(
+    manifest: Mapping[str, Any], *, arm: str, repeat: int, work_dir: Path
+) -> dict[str, Any]:
+    expected_ngram = str(manifest["implementation"]["pre_fallback_ngram_proposer_sha256"])
+    runtime = _run_runtime_probe(work_dir, expected_ngram, f"{arm}-{repeat}")
+    port = _reserve_loopback_port()
+    command = _server_command(manifest, arm, port)
+    base_url = f"http://127.0.0.1:{port}"
+    profile = manifest["recovered_server_profile"]
+    inputs = manifest["inputs"]
+    history_requests = inputs["history_requests"]
+    measurement_request = inputs["measurement_request"]
+    if not isinstance(history_requests, list) or not isinstance(measurement_request, dict):
+        raise EndpointDiagnosticError("bound inputs are malformed")
+    rows: list[dict[str, Any]] = []
+    with _launched_server(
+        command,
+        env=_server_env(),
+        work_dir=work_dir,
+        log_path=work_dir / f"server-{arm}-{repeat}.log",
+    ) as (process, launched_url):
+        if launched_url != base_url:
+            raise EndpointDiagnosticError("server URL binding changed unexpectedly")
+        _wait_for_health(process, base_url, int(manifest["timeouts"]["server_start_seconds"]))
+        ordered = [
+            (request, HISTORICAL_HISTORY_MAX_TOKENS) for request in history_requests
+        ] + [(measurement_request, HISTORICAL_TARGET_MAX_TOKENS)]
+        for sequence_index, (request, max_tokens) in enumerate(ordered):
+            if not isinstance(request, dict) or not isinstance(request.get("request_id"), str):
+                raise EndpointDiagnosticError("bound request is malformed")
+            body = _completion_body(
+                manifest,
+                str(request["prompt"]),
+                f"cx-historical-{arm}-{repeat}-{sequence_index:02d}",
+                max_tokens,
+            )
+            response = _request_json(
+                f"{base_url}/v1/completions",
+                body,
+                int(manifest["timeouts"]["request_seconds"]),
+            )
+            rows.append(
+                {"request_id": request["request_id"], "token_ids": _completion_token_ids(response, max_tokens)}
+            )
+    expected_order = [*HISTORICAL_HISTORY_IDS, HISTORICAL_TARGET_ID]
+    if [row["request_id"] for row in rows] != expected_order:
+        raise EndpointDiagnosticError("endpoint request order changed from the immutable C1 replay")
+    return {
+        "arm": arm,
+        "repeat": repeat,
+        "runtime": runtime,
+        "server_launch": _server_launch_projection(manifest, arm),
+        "endpoint_profile": {
+            "path": profile["endpoint"],
+            "calls_are_sequential": True,
+            "history_request_ids": list(HISTORICAL_HISTORY_IDS),
+            "measurement_request_id": HISTORICAL_TARGET_ID,
+        },
+        "outputs": rows,
+    }
+
+
+def _assert_arm(
+    arm_result: Mapping[str, Any], *, manifest: Mapping[str, Any], arm: str, repeat: int
+) -> tuple[list[list[int]], list[int]]:
+    if arm_result.get("arm") != arm or arm_result.get("repeat") != repeat:
+        raise EndpointDiagnosticError("arm receipt binding differs")
+    _validate_runtime_probe(
+        arm_result.get("runtime") if isinstance(arm_result.get("runtime"), dict) else {},
+        str(manifest["implementation"]["pre_fallback_ngram_proposer_sha256"]),
+    )
+    outputs = arm_result.get("outputs")
+    if not isinstance(outputs, list) or len(outputs) != HISTORICAL_HISTORY_COUNT + 1:
+        raise EndpointDiagnosticError("arm endpoint output count differs from historical replay")
+    expected_ids = [*HISTORICAL_HISTORY_IDS, HISTORICAL_TARGET_ID]
+    if [row.get("request_id") if isinstance(row, dict) else None for row in outputs] != expected_ids:
+        raise EndpointDiagnosticError("arm endpoint output order differs from historical replay")
+    normalized: list[list[int]] = []
+    for index, row in enumerate(outputs):
+        if not isinstance(row, dict) or not isinstance(row.get("token_ids"), list):
+            raise EndpointDiagnosticError("arm endpoint token output is malformed")
+        token_ids = row["token_ids"]
+        if not all(type(token) is int and token >= 0 for token in token_ids):
+            raise EndpointDiagnosticError("arm endpoint emitted non-integer token IDs")
+        expected_count = HISTORICAL_HISTORY_MAX_TOKENS if index < HISTORICAL_HISTORY_COUNT else HISTORICAL_TARGET_MAX_TOKENS
+        if len(token_ids) != expected_count:
+            raise EndpointDiagnosticError("arm endpoint logical token work differs")
+        normalized.append(list(token_ids))
+    return normalized[:HISTORICAL_HISTORY_COUNT], normalized[-1]
+
+
+def _first_difference(left: Sequence[int], right: Sequence[int]) -> int | None:
+    for index, (left_token, right_token) in enumerate(zip(left, right, strict=True)):
+        if left_token != right_token:
+            return index
+    return None
+
+
+def _public_arm_observation(arm_result: Mapping[str, Any]) -> dict[str, Any]:
+    outputs = arm_result.get("outputs")
+    if not isinstance(outputs, list):
+        return {"status": "unverified"}
+    rows: list[dict[str, Any]] = []
+    for row in outputs:
+        if not isinstance(row, dict) or not isinstance(row.get("request_id"), str) or not isinstance(row.get("token_ids"), list):
+            return {"status": "unverified"}
+        tokens = row["token_ids"]
+        if not all(type(token) is int for token in tokens):
+            return {"status": "unverified"}
+        rows.append(
+            {
+                "request_id": row["request_id"],
+                "token_count": len(tokens),
+                "token_ids_sha256": _sha256_bytes(_canonical_json(tokens)),
+            }
+        )
+    target = outputs[-1]["token_ids"]
+    return {
+        "status": "validated_shape_only",
+        "arm": arm_result.get("arm"),
+        "repeat": arm_result.get("repeat"),
+        "runtime": copy.deepcopy(arm_result.get("runtime")),
+        "server_launch": copy.deepcopy(arm_result.get("server_launch")),
+        "endpoint_profile": copy.deepcopy(arm_result.get("endpoint_profile")),
+        "outputs": rows,
+        "target_token_at_historical_signature_index": (
+            target[HISTORICAL_DIVERGENCE_INDEX]
+            if isinstance(target, list) and len(target) > HISTORICAL_DIVERGENCE_INDEX
+            else None
+        ),
+    }
+
+
+def validate_reproduction(manifest: Mapping[str, Any], pairs: Sequence[Mapping[str, Any]]) -> dict[str, Any]:
+    if len(pairs) < MIN_REPEATS:
+        raise EndpointDiagnosticError("insufficient ABBA pairs for endpoint diagnostic")
+    baseline_targets: list[list[int]] = []
+    ngram_targets: list[list[int]] = []
+    public_pairs: list[dict[str, Any]] = []
+    for repeat, pair in enumerate(pairs):
+        expected_order = ["baseline", "ngram"] if repeat % 2 == 0 else ["ngram", "baseline"]
+        if pair.get("arm_order") != expected_order:
+            raise EndpointDiagnosticError("endpoint ABBA arm order differs")
+        baseline = pair.get("baseline")
+        ngram = pair.get("ngram")
+        if not isinstance(baseline, dict) or not isinstance(ngram, dict):
+            raise EndpointDiagnosticError("endpoint pair is incomplete")
+        baseline_history, baseline_target = _assert_arm(
+            baseline, manifest=manifest, arm="baseline", repeat=repeat
+        )
+        ngram_history, ngram_target = _assert_arm(ngram, manifest=manifest, arm="ngram", repeat=repeat)
+        if baseline_history != ngram_history:
+            raise EndpointDiagnosticError("history outputs diverged before measured sonnet-012")
+        difference = _first_difference(baseline_target, ngram_target)
+        if difference != HISTORICAL_DIVERGENCE_INDEX:
+            raise EndpointDiagnosticError(
+                "endpoint replay did not reproduce the first historical target divergence at token 92"
+            )
+        if (
+            baseline_target[HISTORICAL_DIVERGENCE_INDEX] != HISTORICAL_BASELINE_TOKEN
+            or ngram_target[HISTORICAL_DIVERGENCE_INDEX] != HISTORICAL_NGRAM_TOKEN
+        ):
+            raise EndpointDiagnosticError("endpoint replay reproduced a different token-92 signature")
+        baseline_targets.append(baseline_target)
+        ngram_targets.append(ngram_target)
+        public_pairs.append(
+            {
+                "repeat": repeat,
+                "arm_order": expected_order,
+                "baseline": _public_arm_observation(baseline),
+                "ngram": _public_arm_observation(ngram),
+                "first_divergence_zero_based_output_index": difference,
+            }
+        )
+    if any(target != baseline_targets[0] for target in baseline_targets[1:]):
+        raise EndpointDiagnosticError("endpoint baseline target is not repeat-stable")
+    if any(target != ngram_targets[0] for target in ngram_targets[1:]):
+        raise EndpointDiagnosticError("endpoint ngram target is not repeat-stable")
+    return {
+        "result": "historical_c1_k3_endpoint_signature_reproduced",
+        "baseline_repeat_stable": True,
+        "ngram_repeat_stable": True,
+        "pairs": public_pairs,
+    }
+
+
+def _run_parent(args: argparse.Namespace) -> int:
+    manifest = build_manifest(args)
+    manifest_sha256 = _sha256_bytes(_canonical_json(manifest))
+    pairs: list[dict[str, Any]] = []
+    with tempfile.TemporaryDirectory(prefix="cx-historical-http-") as temporary:
+        work_dir = Path(temporary)
+        for repeat in range(int(manifest["repeats"])):
+            order = ["baseline", "ngram"] if repeat % 2 == 0 else ["ngram", "baseline"]
+            pair: dict[str, Any] = {"repeat": repeat, "arm_order": order}
+            try:
+                for arm in order:
+                    pair[arm] = _run_arm(manifest, arm=arm, repeat=repeat, work_dir=work_dir)
+            except EndpointDiagnosticError as exc:
+                completed = [
+                    {
+                        "repeat": item["repeat"],
+                        "arm_order": item["arm_order"],
+                        **{
+                            arm: _public_arm_observation(item[arm])
+                            for arm in ("baseline", "ngram")
+                            if arm in item
+                        },
+                    }
+                    for item in [*pairs, pair]
+                ]
+                raise EndpointDiagnosticRunError(
+                    str(exc),
+                    manifest_sha256=manifest_sha256,
+                    public_manifest=_public_manifest(manifest),
+                    observations=completed,
+                ) from exc
+            pairs.append(pair)
+    try:
+        result = validate_reproduction(manifest, pairs)
+    except EndpointDiagnosticError as exc:
+        observations = [
+            {
+                "repeat": pair["repeat"],
+                "arm_order": pair["arm_order"],
+                "baseline": _public_arm_observation(pair["baseline"]),
+                "ngram": _public_arm_observation(pair["ngram"]),
+            }
+            for pair in pairs
+        ]
+        raise EndpointDiagnosticRunError(
+            str(exc),
+            manifest_sha256=manifest_sha256,
+            public_manifest=_public_manifest(manifest),
+            observations=observations,
+        ) from exc
+    receipt = {
+        "schema": SCHEMA,
+        "status": "PASS",
+        "claim_scope": "diagnostic_only_no_speed_or_promotion_claim",
+        "timing_collected": False,
+        "manifest_sha256": manifest_sha256,
+        "manifest": _public_manifest(manifest),
+        "validation": result,
+    }
+    _write_new_json(args.output_json, receipt)
+    print("HISTORICAL_C1_ENDPOINT_DIAGNOSTIC_PASS", flush=True)
+    return 0
+
+
+def _write_failure_receipt(args: argparse.Namespace, error: Exception) -> None:
+    if not getattr(args, "output_json", None):
+        return
+    receipt: dict[str, Any] = {
+        "schema": SCHEMA,
+        "status": "FAIL",
+        "claim_scope": "diagnostic_only_no_speed_or_promotion_claim",
+        "timing_collected": False,
+        "error": str(error),
+    }
+    if isinstance(error, EndpointDiagnosticRunError):
+        receipt.update(
+            {
+                "manifest_sha256": error.manifest_sha256,
+                "manifest": error.public_manifest,
+                "observations": error.observations,
+            }
+        )
+    try:
+        _write_new_json(args.output_json, receipt)
+    except EndpointDiagnosticError:
+        pass
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--model")
+    parser.add_argument("--model-revision")
+    parser.add_argument("--fixture-manifest")
+    parser.add_argument("--history")
+    parser.add_argument("--corpus")
+    parser.add_argument("--output-json")
+    parser.add_argument("--repeats", type=int, default=MIN_REPEATS)
+    parser.add_argument("--server-start-timeout-seconds", type=int, default=600)
+    parser.add_argument("--request-timeout-seconds", type=int, default=600)
+    parser.add_argument("--_runtime-probe", action="store_true", help=argparse.SUPPRESS)
+    parser.add_argument("--_runtime-probe-expected-ngram-sha256", help=argparse.SUPPRESS)
+    parser.add_argument("--_runtime-probe-output", help=argparse.SUPPRESS)
+    return parser
+
+
+def _validate_parent_args(args: argparse.Namespace) -> None:
+    required = ("model", "model_revision", "fixture_manifest", "history", "corpus", "output_json")
+    missing = [f"--{field.replace('_', '-')}" for field in required if not getattr(args, field)]
+    if missing:
+        raise EndpointDiagnosticError(f"missing required arguments: {', '.join(missing)}")
+
+
+def main(argv: Sequence[str] | None = None) -> int:
+    args = build_parser().parse_args(argv)
+    try:
+        if args._runtime_probe:
+            return _runtime_probe_main(args)
+        _validate_parent_args(args)
+        return _run_parent(args)
+    except EndpointDiagnosticError as exc:
+        _write_failure_receipt(args, exc)
+        print(f"HISTORICAL_C1_ENDPOINT_DIAGNOSTIC_FAIL: {exc}", file=sys.stderr)
+        return 2
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
