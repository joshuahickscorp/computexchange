+#!/usr/bin/env python3
+# SPDX-License-Identifier: Apache-2.0
+"""Bounded, non-promotion replay of the July 2026 Metal C1/K3 divergence.
+
+This is deliberately *not* the production parity gate.  The production gate
+tests the repaired source fork across C1/C16 and K1/K3.  This diagnostic instead
+loads the pre-fallback release wheel in isolated child processes and asks one
+narrow historical question:
+
+* after the immutable Sonnet requests 000..011 have been replayed at C1, does
+  the pre-fallback K=3 prompt-lookup engine choose token 702 at zero-based
+  output position 92 for request 012 while target-only greedy chooses 1875?
+
+It keeps the historical 150-token continuations for all twelve history
+requests, but caps the measured request at 93 tokens: position 92 is the first
+known divergence, so that is the minimum target work that can establish the
+signature.  It records no timing and can never produce a promotion or speed
+claim.  A preserved launch transcript later recovered the server's engine
+shape: ``max_num_seqs=32``, ``max_num_batched_tokens=2048``, Metal memory
+fraction ``0.5``, synchronous single-process scheduling, and *prefix caching
+disabled*.  This direct-LLM harness binds that recovered engine profile, but
+does not claim to reproduce the historical OpenAI endpoint or its two client
+warmups byte-for-byte.
+
+Run it only with the pinned fixture and the prebuilt vLLM-Metal wheel:
+
+    PYTHONDONTWRITEBYTECODE=1 \
+      .venv-vllm-metal/bin/python -B \
+      tools/reproduce_historical_c1_ngram_divergence.py \
+      --model /absolute/path/to/pinned/model \
+      --model-revision 08231374eeacb049a0eade7922910865b8fce912 \
+      --fixture-manifest .artifacts/cx-inference/sonnet-c1-regression/fixture.json \
+      --history .artifacts/cx-inference/sonnet-c1-regression/history.jsonl \
+      --corpus .artifacts/cx-inference/sonnet-c1-regression/corpus.jsonl \
+      --output-json /absolute/path/new-c1-k3-diagnostic.json
+
+The diagnostic fails if source-fork code shadows the installed wheel, if its
+wheel code differs from the historical pre-fallback git object, or if the
+signature is absent.  A PASS means only that this known failure was reproduced;
+it is evidence *against* enabling that old speculative topology.
+"""
+
+from __future__ import annotations
+
+import argparse
+import copy
+import datetime as dt
+import hashlib
+import importlib.metadata
+import json
+import math
+import os
+from pathlib import Path
+import platform
+import re
+import subprocess
+import sys
+import tempfile
+from typing import Any, Iterable, Mapping, Sequence
+
+
+SCHEMA = "cx.vllm_metal.historical_c1_k3_divergence_diagnostic.v1"
+CHILD_SCHEMA = "cx.vllm_metal.historical_c1_k3_divergence_diagnostic.child.v1"
+FIXTURE_SCHEMA = "cx.vllm_metal.sonnet_parity_fixture.v1"
+
+HISTORICAL_METAL_GIT_HEAD = "4c18ee0e6e3ce2b594ab114d0a53ca24eafb1d58"
+HISTORICAL_VLLM_METAL_VERSION = "0.3.0.dev20260713103604"
+HISTORICAL_VLLM_VERSION = "0.24.0+cpu"
+HISTORICAL_HISTORY_COUNT = 12
+HISTORICAL_CORPUS_COUNT = 16
+HISTORICAL_HISTORY_IDS = tuple(f"sonnet-{index:03d}" for index in range(12))
+HISTORICAL_TARGET_ID = "sonnet-012"
+HISTORICAL_HISTORY_MAX_TOKENS = 150
+HISTORICAL_TARGET_MAX_TOKENS = 93
+HISTORICAL_DIVERGENCE_INDEX = 92
+HISTORICAL_BASELINE_TOKEN = 1875
+HISTORICAL_NGRAM_TOKEN = 702
+HISTORICAL_NGRAM_K = 3
+HISTORICAL_LOOKUP_MIN = 2
+HISTORICAL_LOOKUP_MAX = 4
+HISTORICAL_MAX_MODEL_LEN = 2048
+# Recovered verbatim from the retained July M3 server launch, not inferred from
+# current defaults.  C1 is the client active-request shape; the server itself
+# was configured to hold 32 sequences.
+CONTROLLED_MAX_NUM_BATCHED_TOKENS = 2048
+CONTROLLED_MEMORY_FRACTION = 0.5
+CONTROLLED_MAX_NUM_SEQS = 32
+CONTROLLED_PREFIX_CACHING = False
+MIN_REPEATS = 2
+PIN_RE = re.compile(r"[0-9a-fA-F]{40}\Z")
+SHA256_RE = re.compile(r"[0-9a-f]{64}\Z")
+MAX_CHILD_LOG_CHARS = 8_000
+
+
+class DiagnosticError(RuntimeError):
+    """The diagnostic cannot make a trustworthy historical observation."""
+
+
+class DiagnosticRunError(DiagnosticError):
+    """A parent-run failure paired with hash-only completed-run evidence.
+
+    The parent deliberately retains no child artifact paths: its temporary work
+    directory is removed before the public failure receipt is written.  This
+    exception carries only the immutable public manifest and summaries derived
+    from children that independently pass the normal child-binding checks.
+    """
+
+    def __init__(
+        self,
+        message: str,
+        *,
+        manifest_sha256: str,
+        public_manifest: Mapping[str, Any],
+        observed_evidence: Mapping[str, Any],
+    ) -> None:
+        super().__init__(message)
+        self.manifest_sha256 = manifest_sha256
+        self.public_manifest = copy.deepcopy(dict(public_manifest))
+        self.observed_evidence = copy.deepcopy(dict(observed_evidence))
+
+
+def _canonical_json(value: Any) -> bytes:
+    return json.dumps(
+        value, ensure_ascii=False, sort_keys=True, separators=(",", ":")
+    ).encode("utf-8")
+
+
+def _sha256_bytes(value: bytes) -> str:
+    return hashlib.sha256(value).hexdigest()
+
+
+def _sha256_file(path: Path) -> str:
+    digest = hashlib.sha256()
+    with path.open("rb") as handle:
+        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
+            digest.update(chunk)
+    return digest.hexdigest()
+
+
+def _tool_path() -> Path:
+    return Path(__file__).resolve()
+
+
+def _repo_root() -> Path:
+    return _tool_path().parents[1]
+
+
+def _source_metal_package_root() -> Path:
+    return _repo_root() / "vllm_metal"
+
+
+def _path_is_within(path: Path, parent: Path) -> bool:
+    try:
+        path.resolve().relative_to(parent.resolve())
+    except (OSError, ValueError):
+        return False
+    return True
+
+
+def _require_regular_file(value: str | Path, label: str) -> Path:
+    try:
+        path = Path(value).expanduser().resolve(strict=True)
+    except OSError as exc:
+        raise DiagnosticError(f"{label} does not resolve to a readable file: {value!r}") from exc
+    if not path.is_file():
+        raise DiagnosticError(f"{label} must be a regular file: {path}")
+    return path
+
+
+def _require_model_path(value: str) -> Path:
+    try:
+        path = Path(value).expanduser().resolve(strict=True)
+    except OSError as exc:
+        raise DiagnosticError(f"--model does not resolve: {value!r}") from exc
+    if not path.is_dir():
+        raise DiagnosticError("--model must be the pinned local model directory")
+    return path
+
+
+def _read_json_object(path: Path, label: str) -> tuple[dict[str, Any], bytes]:
+    raw = path.read_bytes()
+    try:
+        value = json.loads(raw)
+    except json.JSONDecodeError as exc:
+        raise DiagnosticError(f"{label} is not JSON: {path}") from exc
+    if not isinstance(value, dict):
+        raise DiagnosticError(f"{label} must be a JSON object: {path}")
+    return value, raw
+
+
+def _read_requests(path: Path, label: str) -> tuple[list[dict[str, str]], str]:
+    raw = path.read_bytes()
+    try:
+        lines = raw.decode("utf-8").splitlines()
+    except UnicodeDecodeError as exc:
+        raise DiagnosticError(f"{label} must be UTF-8 JSONL") from exc
+    if not lines:
+        raise DiagnosticError(f"{label} must not be empty")
+    rows: list[dict[str, str]] = []
+    ids: set[str] = set()
+    for line_number, line in enumerate(lines, start=1):
+        if not line.strip():
+            raise DiagnosticError(f"{label} has a blank line at {line_number}")
+        try:
+            value = json.loads(line)
+        except json.JSONDecodeError as exc:
+            raise DiagnosticError(f"{label} line {line_number} is not JSON") from exc
+        if not isinstance(value, dict) or set(value) != {"request_id", "prompt"}:
+            raise DiagnosticError(
+                f"{label} line {line_number} must contain only request_id and prompt"
+            )
+        request_id = value["request_id"]
+        prompt = value["prompt"]
+        if not isinstance(request_id, str) or not request_id:
+            raise DiagnosticError(f"{label} line {line_number} has invalid request_id")
+        if request_id in ids:
+            raise DiagnosticError(f"{label} repeats request_id {request_id!r}")
+        if not isinstance(prompt, str) or not prompt:
+            raise DiagnosticError(f"{label} line {line_number} has invalid prompt")
+        ids.add(request_id)
+        rows.append({"request_id": request_id, "prompt": prompt})
+    return rows, _sha256_bytes(raw)
+
+
+def _require_sha256(value: Any, label: str) -> str:
+    if not isinstance(value, str) or not SHA256_RE.fullmatch(value):
+        raise DiagnosticError(f"{label} must be a lowercase SHA-256")
+    return value
+
+
+def _fixture_section(
+    fixture: Mapping[str, Any], key: str, *, expected_count: int, expected_order: Sequence[str]
+) -> dict[str, Any]:
+    value = fixture.get(key)
+    if not isinstance(value, dict):
+        raise DiagnosticError(f"fixture {key} section is missing")
+    if value.get("request_count") != expected_count:
+        raise DiagnosticError(f"fixture {key} request_count is not historical")
+    if value.get("request_order") != list(expected_order):
+        raise DiagnosticError(f"fixture {key} request order is not historical")
+    _require_sha256(value.get("sha256"), f"fixture {key}.sha256")
+    return value
+
+
+def _validate_fixture(
+    fixture: Mapping[str, Any],
+    *,
+    history_sha256: str,
+    corpus_sha256: str,
+    model_path: Path,
+    model_revision: str,
+) -> dict[str, Any]:
+    """Validate the immutable historical inputs before a child can launch."""
+    if fixture.get("schema") != FIXTURE_SCHEMA:
+        raise DiagnosticError("fixture has an unsupported schema")
+    expected_corpus_order = [
+        f"sonnet-{index:03d}" for index in range(12, 12 + HISTORICAL_CORPUS_COUNT)
+    ]
+    history = _fixture_section(
+        fixture,
+        "history",
+        expected_count=HISTORICAL_HISTORY_COUNT,
+        expected_order=HISTORICAL_HISTORY_IDS,
+    )
+    corpus = _fixture_section(
+        fixture,
+        "corpus",
+        expected_count=HISTORICAL_CORPUS_COUNT,
+        expected_order=expected_corpus_order,
+    )
+    if history["sha256"] != history_sha256:
+        raise DiagnosticError("history JSONL SHA-256 does not match fixture")
+    if corpus["sha256"] != corpus_sha256:
+        raise DiagnosticError("corpus JSONL SHA-256 does not match fixture")
+
+    model = fixture.get("model")
+    if not isinstance(model, dict):
+        raise DiagnosticError("fixture model section is missing")
+    expected_path = model.get("path")
+    if not isinstance(expected_path, str) or not expected_path:
+        raise DiagnosticError("fixture model path is malformed")
+    if model_path != Path(expected_path).expanduser().resolve():
+        raise DiagnosticError("--model differs from fixture's pinned local model path")
+    if model_revision != "08231374eeacb049a0eade7922910865b8fce912":
+        raise DiagnosticError("--model-revision is not the historical pinned revision")
+    files = {
+        "model_safetensors_sha256": model_path / "model.safetensors",
+        "tokenizer_json_sha256": model_path / "tokenizer.json",
+        "config_json_sha256": model_path / "config.json",
+    }
+    for key, path in files.items():
+        expected = _require_sha256(model.get(key), f"fixture model.{key}")
+        actual = _sha256_file(_require_regular_file(path, key))
+        if actual != expected:
+            raise DiagnosticError(f"pinned model artifact differs: {key}")
+    for key in ("chat_template_sha256",):
+        _require_sha256(model.get(key), f"fixture model.{key}")
+    return {
+        "history": copy.deepcopy(history),
+        "corpus": copy.deepcopy(corpus),
+        "model": copy.deepcopy(model),
+    }
+
+
+def _historical_pre_fallback_ngram_sha256() -> str:
+    """Hash the exact source object that the diagnostic expects in the wheel."""
+    try:
+        contents = subprocess.check_output(
+            [
+                "git",
+                "show",
+                f"{HISTORICAL_METAL_GIT_HEAD}:vllm_metal/v1/ngram_proposer.py",
+            ],
+            cwd=_repo_root(),
+            stderr=subprocess.DEVNULL,
+        )
+    except (OSError, subprocess.CalledProcessError) as exc:
+        raise DiagnosticError(
+            "the historical pre-fallback ngram proposer object is unavailable in git"
+        ) from exc
+    return _sha256_bytes(contents)
+
+
+def _distribution_record_sha256(name: str) -> str:
+    try:
+        distribution = importlib.metadata.distribution(name)
+        record = distribution._path / "RECORD"  # type: ignore[attr-defined]
+        return _sha256_file(record)
+    except (importlib.metadata.PackageNotFoundError, OSError, AttributeError) as exc:
+        raise DiagnosticError(f"unable to bind installed distribution {name!r}") from exc
+
+
+def _write_new_json(path_text: str, value: Mapping[str, Any]) -> Path:
+    path = Path(path_text).expanduser()
+    try:
+        parent = path.parent.resolve(strict=True)
+    except OSError as exc:
+        raise DiagnosticError(f"output parent does not exist: {path.parent}") from exc
+    target = parent / path.name
+    payload = _canonical_json(value) + b"\n"
+    try:
+        fd = os.open(target, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
+    except FileExistsError as exc:
+        raise DiagnosticError(f"refusing to overwrite existing output: {target}") from exc
+    try:
+        with os.fdopen(fd, "wb") as handle:
+            handle.write(payload)
+            handle.flush()
+            os.fsync(handle.fileno())
+    except BaseException:
+        target.unlink(missing_ok=True)
+        raise
+    return target
+
+
+def _public_manifest(manifest: Mapping[str, Any]) -> dict[str, Any]:
+    return {key: value for key, value in manifest.items() if key != "inputs"}
+
+
+def build_manifest(args: argparse.Namespace) -> dict[str, Any]:
+    """Bind the fixed diagnostic workload before starting child processes."""
+    if not PIN_RE.fullmatch(args.model_revision or ""):
+        raise DiagnosticError("--model-revision must be a full 40-character SHA")
+    model_revision = args.model_revision.lower()
+    if args.repeats < MIN_REPEATS:
+        raise DiagnosticError(f"--repeats must be at least {MIN_REPEATS}")
+    if args.timeout_seconds <= 0:
+        raise DiagnosticError("--timeout-seconds must be positive")
+    if args.max_model_len != HISTORICAL_MAX_MODEL_LEN:
+        raise DiagnosticError(
+            f"--max-model-len must be historical value {HISTORICAL_MAX_MODEL_LEN}"
+        )
+    if args.max_num_batched_tokens != CONTROLLED_MAX_NUM_BATCHED_TOKENS:
+        raise DiagnosticError(
+            "--max-num-batched-tokens must equal the recovered historical value "
+            f"{CONTROLLED_MAX_NUM_BATCHED_TOKENS}"
+        )
+    if not math.isclose(
+        args.memory_fraction, CONTROLLED_MEMORY_FRACTION, rel_tol=0.0, abs_tol=1e-12
+    ):
+        raise DiagnosticError(
+            "--memory-fraction must equal the recovered historical value "
+            f"{CONTROLLED_MEMORY_FRACTION}"
+        )
+
+    model_path = _require_model_path(args.model)
+    fixture_path = _require_regular_file(args.fixture_manifest, "--fixture-manifest")
+    history_path = _require_regular_file(args.history, "--history")
+    corpus_path = _require_regular_file(args.corpus, "--corpus")
+    fixture, fixture_raw = _read_json_object(fixture_path, "fixture manifest")
+    history_requests, history_sha256 = _read_requests(history_path, "history JSONL")
+    corpus_requests, corpus_sha256 = _read_requests(corpus_path, "corpus JSONL")
+    if [row["request_id"] for row in history_requests] != list(HISTORICAL_HISTORY_IDS):
+        raise DiagnosticError("history JSONL is not exactly sonnet-000 through sonnet-011")
+    expected_corpus_ids = [
+        f"sonnet-{index:03d}" for index in range(12, 12 + HISTORICAL_CORPUS_COUNT)
+    ]
+    if [row["request_id"] for row in corpus_requests] != expected_corpus_ids:
+        raise DiagnosticError("corpus JSONL is not the complete historical sonnet-012..027 fixture")
+    fixture_binding = _validate_fixture(
+        fixture,
+        history_sha256=history_sha256,
+        corpus_sha256=corpus_sha256,
+        model_path=model_path,
+        model_revision=model_revision,
+    )
+    target = corpus_requests[0]
+    return {
+        "schema": SCHEMA,
+        "claim_scope": "diagnostic_only_no_speed_or_promotion_claim",
+        "implementation": {
+            "tool_path": str(_tool_path()),
+            "tool_sha256": _sha256_file(_tool_path()),
+            "historical_metal_git_head": HISTORICAL_METAL_GIT_HEAD,
+            "pre_fallback_ngram_proposer_sha256": _historical_pre_fallback_ngram_sha256(),
+        },
+        "fixture": {
+            "path": str(fixture_path),
+            "sha256": _sha256_bytes(fixture_raw),
+            **fixture_binding,
+        },
+        "model": {
+            "path": str(model_path),
+            "revision": model_revision,
+        },
+        "controlled_engine_profile": {
+            "name": "recovered_c1_server_engine_profile_direct_llm_replay",
+            "historical_server_launch_recovered": True,
+            "historical_openai_endpoint_reproduced": False,
+            "historical_client_warmups_reproduced": False,
+            "max_model_len": args.max_model_len,
+            "max_num_batched_tokens": args.max_num_batched_tokens,
+            "max_num_seqs": CONTROLLED_MAX_NUM_SEQS,
+            "memory_fraction": args.memory_fraction,
+            "enable_prefix_caching": CONTROLLED_PREFIX_CACHING,
+            "async_scheduling": False,
+            "v1_multiprocessing": False,
+            "paged_attention_required": True,
+        },
+        "sampling": {
+            "temperature": 0.0,
+            "top_p": 1.0,
+            "top_k": -1,
+            "ignore_eos": True,
+            "seed": 0,
+            "history_max_tokens": HISTORICAL_HISTORY_MAX_TOKENS,
+            "measurement_max_tokens": HISTORICAL_TARGET_MAX_TOKENS,
+        },
+        "candidate": {
+            "method": "ngram",
+            "ngram_k": HISTORICAL_NGRAM_K,
+            "prompt_lookup_min": HISTORICAL_LOOKUP_MIN,
+            "prompt_lookup_max": HISTORICAL_LOOKUP_MAX,
+            "pre_fallback_installed_wheel_required": True,
+        },
+        "expected_signature": {
+            "request_id": HISTORICAL_TARGET_ID,
+            "first_divergence_zero_based_output_index": HISTORICAL_DIVERGENCE_INDEX,
+            "baseline_token_id": HISTORICAL_BASELINE_TOKEN,
+            "ngram_token_id": HISTORICAL_NGRAM_TOKEN,
+        },
+        "repeats": args.repeats,
+        "inputs": {
+            "history_requests": history_requests,
+            "measurement_request": target,
+        },
+    }
+
