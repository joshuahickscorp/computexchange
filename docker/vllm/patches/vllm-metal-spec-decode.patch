@@ -0,0 +1,289 @@
+# SPDX-License-Identifier: Apache-2.0
+"""Model-free contract tests for the bounded historical C1/K3 diagnostic."""
+
+from __future__ import annotations
+
+import argparse
+import hashlib
+import json
+from pathlib import Path
+import tempfile
+import unittest
+from unittest import mock
+
+from tools import reproduce_historical_c1_ngram_divergence as repro
+
+
+def _sha(value: bytes) -> str:
+    return hashlib.sha256(value).hexdigest()
+
+
+def _write_jsonl(path: Path, rows: list[dict[str, str]]) -> str:
+    raw = b"".join(
+        json.dumps(row, sort_keys=True, separators=(",", ":")).encode("utf-8") + b"\n"
+        for row in rows
+    )
+    path.write_bytes(raw)
+    return _sha(raw)
+
+
+def _rows(prefix: str, start: int, count: int) -> list[dict[str, str]]:
+    return [
+        {"request_id": f"{prefix}-{index:03d}", "prompt": f"prompt {index}"}
+        for index in range(start, start + count)
+    ]
+
+
+def _fixture_paths(root: Path) -> tuple[argparse.Namespace, dict]:
+    model = root / "model"
+    model.mkdir()
+    artifacts = {
+        "model.safetensors": b"model-weights",
+        "tokenizer.json": b"tokenizer",
+        "config.json": b"config",
+    }
+    for name, contents in artifacts.items():
+        (model / name).write_bytes(contents)
+    history_rows = _rows("sonnet", 0, repro.HISTORICAL_HISTORY_COUNT)
+    corpus_rows = _rows("sonnet", 12, repro.HISTORICAL_CORPUS_COUNT)
+    history = root / "history.jsonl"
+    corpus = root / "corpus.jsonl"
+    history_sha = _write_jsonl(history, history_rows)
+    corpus_sha = _write_jsonl(corpus, corpus_rows)
+    fixture = {
+        "schema": repro.FIXTURE_SCHEMA,
+        "model": {
+            "path": str(model.resolve()),
+            "model_safetensors_sha256": _sha(artifacts["model.safetensors"]),
+            "tokenizer_json_sha256": _sha(artifacts["tokenizer.json"]),
+            "config_json_sha256": _sha(artifacts["config.json"]),
+            "chat_template_sha256": "a" * 64,
+        },
+        "history": {
+            "request_count": len(history_rows),
+            "request_order": [row["request_id"] for row in history_rows],
+            "sha256": history_sha,
+        },
+        "corpus": {
+            "request_count": len(corpus_rows),
+            "request_order": [row["request_id"] for row in corpus_rows],
+            "sha256": corpus_sha,
+        },
+    }
+    fixture_path = root / "fixture.json"
+    fixture_path.write_text(json.dumps(fixture), encoding="utf-8")
+    args = argparse.Namespace(
+        model=str(model),
+        model_revision="08231374eeacb049a0eade7922910865b8fce912",
+        fixture_manifest=str(fixture_path),
+        history=str(history),
+        corpus=str(corpus),
+        repeats=2,
+        max_model_len=repro.HISTORICAL_MAX_MODEL_LEN,
+        max_num_batched_tokens=repro.CONTROLLED_MAX_NUM_BATCHED_TOKENS,
+        memory_fraction=repro.CONTROLLED_MEMORY_FRACTION,
+        timeout_seconds=60,
+    )
+    return args, fixture
+
+
+def _manifest() -> dict:
+    return {
+        "implementation": {"pre_fallback_ngram_proposer_sha256": "b" * 64},
+        "controlled_engine_profile": {
+            "max_model_len": repro.HISTORICAL_MAX_MODEL_LEN,
+            "max_num_seqs": repro.CONTROLLED_MAX_NUM_SEQS,
+            "max_num_batched_tokens": repro.CONTROLLED_MAX_NUM_BATCHED_TOKENS,
+            "memory_fraction": repro.CONTROLLED_MEMORY_FRACTION,
+            "enable_prefix_caching": repro.CONTROLLED_PREFIX_CACHING,
+        },
+    }
+
+
+def _child(
+    *,
+    arm: str,
+    repeat: int,
+    measurement: list[int],
+) -> dict:
+    history = [
+        {"request_id": request_id, "token_ids": [index] * repro.HISTORICAL_HISTORY_MAX_TOKENS}
+        for index, request_id in enumerate(repro.HISTORICAL_HISTORY_IDS)
+    ]
+    return {
+        "schema": repro.CHILD_SCHEMA,
+        "status": "PASS",
+        "manifest_sha256": "c" * 64,
+        "arm": arm,
+        "repeat": repeat,
+        "runtime": {
+            "runtime_import_mode": "installed_wheel_pre_fallback_only",
+            "environment": repro._child_env_expected(repro.CONTROLLED_MEMORY_FRACTION),
+            "vllm_version": repro.HISTORICAL_VLLM_VERSION,
+            "vllm_metal_version": repro.HISTORICAL_VLLM_METAL_VERSION,
+            "ngram_proposer_sha256": "b" * 64,
+            "vllm_metal_module_path": "/wheel/site-packages/vllm_metal/__init__.py",
+            "vllm_distribution_record_sha256": "d" * 64,
+            "vllm_metal_distribution_record_sha256": "e" * 64,
+            "paged_extensions": [
+                {"path": "/wheel/site-packages/vllm_metal/metal/_paged_ops.so", "sha256": "f" * 64}
+            ],
+        },
+        "engine_binding": {
+            "use_paged_attention": True,
+            "enable_prefix_caching": repro.CONTROLLED_PREFIX_CACHING,
+            "memory_fraction": repro.CONTROLLED_MEMORY_FRACTION,
+            "max_num_seqs": repro.CONTROLLED_MAX_NUM_SEQS,
+            "max_num_batched_tokens": repro.CONTROLLED_MAX_NUM_BATCHED_TOKENS,
+            "max_model_len": repro.HISTORICAL_MAX_MODEL_LEN,
+        },
+        "measurement_cache_hit_start_positions": [],
+        "draft_activity": (
+            {"history": None, "measurement": None}
+            if arm == "baseline"
+            else {
+                "history": {"draft_requests": 1, "draft_tokens": 3},
+                "measurement": {"draft_requests": 1, "draft_tokens": 3, "max_draft_width": 3},
+            }
+        ),
+        "outputs": {
+            "history": history,
+            "measurement": [{"request_id": repro.HISTORICAL_TARGET_ID, "token_ids": measurement}],
+        },
+    }
+
+
+def _pair(repeat: int, baseline: list[int], ngram: list[int]) -> dict:
+    return {
+        "repeat": repeat,
+        "arm_order": ["baseline", "ngram"] if repeat % 2 == 0 else ["ngram", "baseline"],
+        "baseline": _child(arm="baseline", repeat=repeat, measurement=baseline),
+        "ngram": _child(arm="ngram", repeat=repeat, measurement=ngram),
+    }
+
+
+class TestHistoricalC1K3Diagnostic(unittest.TestCase):
+    def test_build_manifest_binds_full_fixture_but_measures_only_sonnet_012(self) -> None:
+        with tempfile.TemporaryDirectory() as temporary:
+            args, _ = _fixture_paths(Path(temporary))
+            with mock.patch.object(repro, "_historical_pre_fallback_ngram_sha256", return_value="b" * 64):
+                manifest = repro.build_manifest(args)
+
+        self.assertEqual(manifest["claim_scope"], "diagnostic_only_no_speed_or_promotion_claim")
+        self.assertEqual(len(manifest["inputs"]["history_requests"]), 12)
+        self.assertEqual(manifest["inputs"]["measurement_request"]["request_id"], "sonnet-012")
+        self.assertEqual(manifest["sampling"]["history_max_tokens"], 150)
+        self.assertEqual(manifest["sampling"]["measurement_max_tokens"], 93)
+        self.assertEqual(manifest["candidate"]["ngram_k"], 3)
+        self.assertEqual(manifest["candidate"]["prompt_lookup_max"], 4)
+
+    def test_build_manifest_refuses_a_truncated_or_reordered_fixture(self) -> None:
+        with tempfile.TemporaryDirectory() as temporary:
+            root = Path(temporary)
+            args, _ = _fixture_paths(root)
+            rows = [json.loads(line) for line in Path(args.corpus).read_text().splitlines()]
+            rows[1]["request_id"] = "wrong-id"
+            _write_jsonl(Path(args.corpus), rows)
+            with mock.patch.object(repro, "_historical_pre_fallback_ngram_sha256", return_value="b" * 64):
+                with self.assertRaisesRegex(repro.DiagnosticError, "complete historical"):
+                    repro.build_manifest(args)
+
+    def test_validate_reproduction_accepts_the_exact_stable_historical_signature(self) -> None:
+        baseline = list(range(repro.HISTORICAL_DIVERGENCE_INDEX)) + [repro.HISTORICAL_BASELINE_TOKEN]
+        ngram = list(range(repro.HISTORICAL_DIVERGENCE_INDEX)) + [repro.HISTORICAL_NGRAM_TOKEN]
+        result = repro.validate_reproduction(
+            manifest_sha256="c" * 64,
+            manifest=_manifest(),
+            pairs=[_pair(0, baseline, ngram), _pair(1, baseline, ngram)],
+        )
+
+        self.assertEqual(result["result"], "historical_c1_k3_signature_reproduced")
+        self.assertTrue(result["repeated_baseline_stable"])
+        self.assertEqual(result["pairs"][0]["first_divergence_zero_based_output_index"], 92)
+
+    def test_validate_reproduction_rejects_the_wrong_first_divergence_or_inert_drafter(self) -> None:
+        baseline = list(range(repro.HISTORICAL_DIVERGENCE_INDEX)) + [repro.HISTORICAL_BASELINE_TOKEN]
+        bad_ngram = list(range(repro.HISTORICAL_DIVERGENCE_INDEX - 1)) + [999, repro.HISTORICAL_NGRAM_TOKEN]
+        with self.assertRaisesRegex(repro.DiagnosticError, "first divergence"):
+            repro.validate_reproduction(
+                manifest_sha256="c" * 64,
+                manifest=_manifest(),
+                pairs=[_pair(0, baseline, bad_ngram), _pair(1, baseline, bad_ngram)],
+            )
+
+        ngram = list(range(repro.HISTORICAL_DIVERGENCE_INDEX)) + [repro.HISTORICAL_NGRAM_TOKEN]
+        pair = _pair(0, baseline, ngram)
+        pair["ngram"]["draft_activity"]["measurement"] = {
+            "draft_requests": 0,
+            "draft_tokens": 0,
+            "max_draft_width": 0,
+        }
+        with self.assertRaisesRegex(repro.DiagnosticError, "did not emit measured drafts"):
+            repro.validate_reproduction(
+                manifest_sha256="c" * 64,
+                manifest=_manifest(),
+                pairs=[pair, _pair(1, baseline, ngram)],
+            )
+
+    def test_parent_failure_receipt_preserves_hash_only_absent_signature_evidence(self) -> None:
+        no_divergence = list(range(repro.HISTORICAL_TARGET_MAX_TOKENS))
+        manifest = _manifest()
+        manifest["repeats"] = repro.MIN_REPEATS
+        manifest_sha256 = repro._sha256_bytes(repro._canonical_json(manifest))
+
+        def completed_child(
+            _manifest_path: Path,
+            child_manifest_sha256: str,
+            *,
+            arm: str,
+            repeat: int,
+            **_kwargs: object,
+        ) -> dict:
+            child = _child(arm=arm, repeat=repeat, measurement=no_divergence)
+            child["manifest_sha256"] = child_manifest_sha256
+            return child
+
+        with tempfile.TemporaryDirectory() as temporary:
+            output = Path(temporary) / "failure.json"
+            args = argparse.Namespace(timeout_seconds=60, output_json=str(output))
+            with mock.patch.object(repro, "build_manifest", return_value=manifest), mock.patch.object(
+                repro, "_run_child", side_effect=completed_child
+            ):
+                with self.assertRaises(repro.DiagnosticRunError) as raised:
+                    repro._run_parent(args)
+
+            error = raised.exception
+            self.assertEqual(error.manifest_sha256, manifest_sha256)
+            evidence = error.observed_evidence
+            self.assertEqual(evidence["scope"], "validated_child_hashes_and_signature_tokens_only")
+            self.assertEqual(evidence["completed_pair_count"], repro.MIN_REPEATS)
+            comparison = evidence["pairs"][0]["comparison"]
+            self.assertEqual(comparison["finding"], "no_target_output_divergence_observed")
