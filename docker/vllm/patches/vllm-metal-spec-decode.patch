+def _run_child(
+    manifest_path: Path,
+    manifest_sha256: str,
+    *,
+    arm: str,
+    repeat: int,
+    timeout_seconds: int,
+    memory_fraction: float,
+    work_dir: Path,
+) -> dict[str, Any]:
+    output = work_dir / f"{arm}-repeat-{repeat}.json"
+    command = [
+        sys.executable,
+        "-B",
+        str(_tool_path()),
+        "--_child-arm",
+        arm,
+        "--_child-manifest",
+        str(manifest_path),
+        "--_child-manifest-sha256",
+        manifest_sha256,
+        "--_child-output",
+        str(output),
+        "--_child-repeat",
+        str(repeat),
+    ]
+    try:
+        completed = subprocess.run(
+            command,
+            cwd=work_dir,
+            env=_child_env(memory_fraction),
+            capture_output=True,
+            text=True,
+            timeout=timeout_seconds,
+            check=False,
+        )
+    except subprocess.TimeoutExpired as exc:
+        raise DiagnosticError(f"{arm} repeat {repeat} exceeded {timeout_seconds}s") from exc
+    if completed.returncode != 0:
+        logs = (completed.stdout + "\n" + completed.stderr)[-MAX_CHILD_LOG_CHARS:]
+        raise DiagnosticError(
+            f"child {arm} repeat {repeat} failed with exit code {completed.returncode}; "
+            f"tail follows:\n{logs}"
+        )
+    if not output.exists():
+        raise DiagnosticError(f"child {arm} repeat {repeat} exited without a receipt")
+    return _read_child(output)
+
+
+def _trace_rows(value: Any, phase: str) -> list[dict[str, Any]]:
+    if not isinstance(value, dict):
+        raise DiagnosticError("child has no outputs object")
+    rows = value.get(phase)
+    if not isinstance(rows, list):
+        raise DiagnosticError(f"child {phase} outputs are malformed")
+    normalized: list[dict[str, Any]] = []
+    for row in rows:
+        if not isinstance(row, dict):
+            raise DiagnosticError(f"child {phase} row is malformed")
+        request_id = row.get("request_id")
+        tokens = row.get("token_ids")
+        if not isinstance(request_id, str) or not isinstance(tokens, list):
+            raise DiagnosticError(f"child {phase} row fields are malformed")
+        if not all(type(token) is int for token in tokens):
+            raise DiagnosticError(f"child {phase} row has non-integer tokens")
+        normalized.append({"request_id": request_id, "token_ids": tokens})
+    return normalized
+
+
+def _assert_child(
+    child: Mapping[str, Any],
+    *,
+    manifest_sha256: str,
+    arm: str,
+    repeat: int,
+    manifest: Mapping[str, Any],
+) -> tuple[list[dict[str, Any]], list[int]]:
+    if child.get("schema") != CHILD_SCHEMA or child.get("status") != "PASS":
+        raise DiagnosticError("child receipt has an unsupported status/schema")
+    expected = {
+        "manifest_sha256": manifest_sha256,
+        "arm": arm,
+        "repeat": repeat,
+    }
+    for key, value in expected.items():
+        if child.get(key) != value:
+            raise DiagnosticError(f"child binding mismatch for {key}")
+    runtime = child.get("runtime")
+    if not isinstance(runtime, dict):
+        raise DiagnosticError("child has no runtime binding")
+    if runtime.get("runtime_import_mode") != "installed_wheel_pre_fallback_only":
+        raise DiagnosticError("child did not use installed pre-fallback wheel mode")
+    if runtime.get("vllm_version") != HISTORICAL_VLLM_VERSION:
+        raise DiagnosticError("child vLLM version does not match historical runtime")
+    if runtime.get("vllm_metal_version") != HISTORICAL_VLLM_METAL_VERSION:
+        raise DiagnosticError("child Metal wheel version does not match historical runtime")
+    if runtime.get("ngram_proposer_sha256") != manifest["implementation"]["pre_fallback_ngram_proposer_sha256"]:
+        raise DiagnosticError("child pre-fallback proposer hash differs")
+    for key in (
+        "vllm_distribution_record_sha256",
+        "vllm_metal_distribution_record_sha256",
+    ):
+        _require_sha256(runtime.get(key), f"child runtime {key}")
+    extensions = runtime.get("paged_extensions")
+    if not isinstance(extensions, list) or not extensions:
+        raise DiagnosticError("child runtime has no bound paged extension")
+    for extension in extensions:
+        if not isinstance(extension, dict) or not isinstance(extension.get("path"), str):
+            raise DiagnosticError("child paged extension binding is malformed")
+        _require_sha256(extension.get("sha256"), "child paged extension SHA-256")
+    metal_path = runtime.get("vllm_metal_module_path")
+    if not isinstance(metal_path, str) or _path_is_within(Path(metal_path), _source_metal_package_root()):
+        raise DiagnosticError("child imported source Metal package")
+    environment = runtime.get("environment")
+    if not isinstance(environment, dict):
+        raise DiagnosticError("child has no runtime environment binding")
+    for key, value in _child_env_expected(manifest["controlled_engine_profile"]["memory_fraction"]).items():
+        # The child records the values at import time in a nested runtime block
+        # only when they are explicitly added below.  Keep the environment check
+        # fail-closed in a uniform location.
+        if environment.get(key) != value:
+            raise DiagnosticError(f"child environment binding differs for {key}")
+    engine = child.get("engine_binding")
+    if not isinstance(engine, dict) or engine.get("use_paged_attention") is not True:
+        raise DiagnosticError("child did not resolve paged Metal engine")
+    profile = manifest["controlled_engine_profile"]
+    for key in ("max_num_seqs", "max_num_batched_tokens", "max_model_len"):
+        expected_value = profile[key]
+        if engine.get(key) != expected_value:
+            raise DiagnosticError(f"child engine differs for {key}")
+    if engine.get("enable_prefix_caching") is not profile["enable_prefix_caching"]:
+        raise DiagnosticError("child engine prefix-cache setting differs")
+    if not math.isclose(
+        float(engine.get("memory_fraction", -1)),
+        float(profile["memory_fraction"]),
+        rel_tol=0.0,
+        abs_tol=1e-12,
+    ):
+        raise DiagnosticError("child engine memory fraction differs")
+    hits = child.get("measurement_cache_hit_start_positions")
+    if not isinstance(hits, list) or not all(type(hit) is int and hit >= 0 for hit in hits):
+        raise DiagnosticError("child measured cache-trace positions are malformed")
+    if profile["enable_prefix_caching"]:
+        if not any(hit > 0 for hit in hits):
+            raise DiagnosticError("child measured phase lacks a paged prefix-cache hit")
+    elif any(hit > 0 for hit in hits):
+        raise DiagnosticError("prefix-cache-disabled child observed a cache hit")
+    drafts = child.get("draft_activity")
+    if arm == "ngram":
+        if not isinstance(drafts, dict) or not isinstance(drafts.get("measurement"), dict):
+            raise DiagnosticError("candidate has no measured draft activity")
+        if not drafts["measurement"].get("draft_requests") or not drafts["measurement"].get("draft_tokens"):
+            raise DiagnosticError("candidate did not emit measured drafts")
+        if drafts["measurement"].get("max_draft_width") != HISTORICAL_NGRAM_K:
+            raise DiagnosticError("candidate did not emit a measured K=3 proposal")
+    elif drafts != {"history": None, "measurement": None}:
+        raise DiagnosticError("baseline unexpectedly reports draft activity")
+    outputs = child.get("outputs")
+    history = _trace_rows(outputs, "history")
+    measurement = _trace_rows(outputs, "measurement")
+    if [row["request_id"] for row in history] != list(HISTORICAL_HISTORY_IDS):
+        raise DiagnosticError("child history order differs")
+    if len(measurement) != 1 or measurement[0]["request_id"] != HISTORICAL_TARGET_ID:
+        raise DiagnosticError("child measurement target differs")
+    if any(len(row["token_ids"]) != HISTORICAL_HISTORY_MAX_TOKENS for row in history):
+        raise DiagnosticError("child history logical work differs")
+    tokens = measurement[0]["token_ids"]
+    if len(tokens) != HISTORICAL_TARGET_MAX_TOKENS:
+        raise DiagnosticError("child target logical work differs")
+    return history, tokens
+
+
+def _first_difference(left: Sequence[int], right: Sequence[int]) -> int | None:
+    for index, (left_token, right_token) in enumerate(zip(left, right, strict=True)):
+        if left_token != right_token:
+            return index
+    return None
+
+
+def _trace_sha256(rows: Sequence[Mapping[str, Any]]) -> str:
+    return _sha256_bytes(_canonical_json(list(rows)))
+
+
+def _runtime_identity(child: Mapping[str, Any]) -> dict[str, Any]:
+    runtime = child.get("runtime")
+    if not isinstance(runtime, dict):
+        raise DiagnosticError("child has no runtime identity")
+    keys = (
+        "runtime_import_mode",
+        "vllm_version",
+        "vllm_metal_version",
+        "vllm_distribution_record_sha256",
+        "vllm_metal_distribution_record_sha256",
+        "ngram_proposer_sha256",
+        "paged_extensions",
+        "machine",
+        "platform",
+    )
+    return {key: copy.deepcopy(runtime.get(key)) for key in keys}
+
+
+def _safe_child_observation(
+    child: Mapping[str, Any],
+    *,
+    manifest_sha256: str,
+    manifest: Mapping[str, Any],
+    arm: str,
+    repeat: int,
+) -> tuple[dict[str, Any], tuple[list[dict[str, Any]], list[int]] | None]:
+    """Return hash-only evidence after the ordinary child checks pass.
+
+    This is intentionally not a second, looser validation path.  A child that
+    fails ``_assert_child`` contributes only an unverified finding; no output
+    token hashes or tokens from it are published in the parent failure receipt.
+    """
+    try:
+        history, tokens = _assert_child(
+            child,
+            manifest_sha256=manifest_sha256,
+            arm=arm,
+            repeat=repeat,
+            manifest=manifest,
+        )
+    except DiagnosticError as exc:
+        return {
+            "status": "unverified",
+            "finding": "child_binding_or_logical_work_check_failed",
+            "error": str(exc),
+        }, None
+
+    hits = child["measurement_cache_hit_start_positions"]
+    assert isinstance(hits, list)
+    integer_hits = [hit for hit in hits if isinstance(hit, int)]
+    prefix_cache_enabled = bool(manifest["controlled_engine_profile"]["enable_prefix_caching"])
+    observation = {
+        "status": "validated",
+        "history_trace_sha256": _trace_sha256(history),
+        "target_token_ids_sha256": _sha256_bytes(_canonical_json(tokens)),
+        "target_token_count": len(tokens),
+        "token_id_at_historical_signature_index": tokens[HISTORICAL_DIVERGENCE_INDEX],
+        "measurement_prefix_cache_enabled": prefix_cache_enabled,
+        "measurement_prefix_cache_hit_count": (
+            len(integer_hits) if prefix_cache_enabled else 0
+        ),
+        "measurement_prefix_cache_max_start_position": (
+            max(integer_hits) if integer_hits else None
+        ),
+        "draft_activity": copy.deepcopy(child["draft_activity"]),
+        "runtime_identity_sha256": _sha256_bytes(
+            _canonical_json(_runtime_identity(child))
+        ),
+    }
+    return observation, (history, tokens)
+
+
+def _observed_failure_evidence(
+    *,
+    manifest_sha256: str,
+    manifest: Mapping[str, Any],
+    pairs: Sequence[Mapping[str, Any]],
+) -> dict[str, Any]:
+    """Summarize completed child work safely when the diagnostic fails.
+
+    The result deliberately contains no prompts, complete output token arrays,
+    child artifact paths, or timing.  It makes an absent or different historical
+    signature distinguishable from a child-binding failure without turning a
+    failed replay into a speed or production claim.
+    """
+    pair_summaries: list[dict[str, Any]] = []
+    for expected_repeat, pair in enumerate(pairs):
+        expected_order = (
+            ["baseline", "ngram"]
+            if expected_repeat % 2 == 0
+            else ["ngram", "baseline"]
+        )
+        summary: dict[str, Any] = {
+            "repeat": pair.get("repeat"),
+            "expected_arm_order": expected_order,
+            "observed_arm_order": copy.deepcopy(pair.get("arm_order")),
+            "arms": {},
+        }
+        validated: dict[str, tuple[list[dict[str, Any]], list[int]]] = {}
+        arms = summary["arms"]
+        assert isinstance(arms, dict)
+        for arm in ("baseline", "ngram"):
+            child = pair.get(arm)
+            if child is None:
+                arms[arm] = {
+                    "status": "not_completed",
+                    "finding": "child_did_not_return_a_receipt",
+                }
+                continue
+            if not isinstance(child, Mapping):
+                arms[arm] = {
+                    "status": "unverified",
+                    "finding": "child_receipt_is_not_an_object",
+                }
+                continue
+            observation, trace = _safe_child_observation(
+                child,
+                manifest_sha256=manifest_sha256,
+                manifest=manifest,
+                arm=arm,
+                repeat=expected_repeat,
+            )
+            arms[arm] = observation
+            if trace is not None:
+                validated[arm] = trace
+
+        if set(validated) == {"baseline", "ngram"}:
+            baseline_history, baseline_tokens = validated["baseline"]
+            ngram_history, ngram_tokens = validated["ngram"]
+            history_equal = baseline_history == ngram_history
+            difference = _first_difference(baseline_tokens, ngram_tokens)
+            comparison: dict[str, Any] = {
+                "history_outputs_equal": history_equal,
+                "first_target_divergence_zero_based_output_index": difference,
+                "expected_first_target_divergence_zero_based_output_index": (
+                    HISTORICAL_DIVERGENCE_INDEX
+                ),
+            }
+            if difference is not None:
+                comparison["baseline_token_id_at_first_target_divergence"] = (
+                    baseline_tokens[difference]
+                )
+                comparison["ngram_token_id_at_first_target_divergence"] = ngram_tokens[
+                    difference
+                ]
+            signature_observed = (
+                history_equal
+                and difference == HISTORICAL_DIVERGENCE_INDEX
+                and baseline_tokens[HISTORICAL_DIVERGENCE_INDEX]
+                == HISTORICAL_BASELINE_TOKEN
+                and ngram_tokens[HISTORICAL_DIVERGENCE_INDEX]
+                == HISTORICAL_NGRAM_TOKEN
+            )
+            comparison["historical_signature_observed"] = signature_observed
+            if not history_equal:
+                comparison["finding"] = "history_outputs_diverged_before_measurement"
+            elif difference is None:
+                comparison["finding"] = "no_target_output_divergence_observed"
+            elif signature_observed:
+                comparison["finding"] = "historical_signature_observed"
+            else:
+                comparison["finding"] = "different_target_divergence_observed"
+            summary["comparison"] = comparison
+        pair_summaries.append(summary)
+
+    return {
+        "scope": "validated_child_hashes_and_signature_tokens_only",
+        "completed_pair_count": len(pair_summaries),
+        "expected_signature": {
+            "first_divergence_zero_based_output_index": HISTORICAL_DIVERGENCE_INDEX,
+            "baseline_token_id": HISTORICAL_BASELINE_TOKEN,
+            "ngram_token_id": HISTORICAL_NGRAM_TOKEN,
+        },
+        "pairs": pair_summaries,
+    }
+
+
+def validate_reproduction(
+    *,
+    manifest_sha256: str,
+    manifest: Mapping[str, Any],
+    pairs: Sequence[Mapping[str, Any]],
+) -> dict[str, Any]:
+    """Fail closed unless every repeated pair reproduces the exact old signature."""
+    if len(pairs) < MIN_REPEATS:
+        raise DiagnosticError(f"historical diagnostic needs at least {MIN_REPEATS} repeats")
+    baseline_reference: tuple[list[dict[str, Any]], list[int]] | None = None
+    ngram_reference: tuple[list[dict[str, Any]], list[int]] | None = None
+    runtime_reference: dict[str, Any] | None = None
+    summaries: list[dict[str, Any]] = []
+    for repeat, pair in enumerate(pairs):
+        if pair.get("repeat") != repeat:
+            raise DiagnosticError("pair repeat order is not bound")
+        expected_order = ["baseline", "ngram"] if repeat % 2 == 0 else ["ngram", "baseline"]
+        if pair.get("arm_order") != expected_order:
+            raise DiagnosticError("pair arm order is not ABBA-alternated")
+        baseline_history, baseline_tokens = _assert_child(
+            pair.get("baseline"),
+            manifest_sha256=manifest_sha256,
+            arm="baseline",
+            repeat=repeat,
+            manifest=manifest,
+        )
+        ngram_history, ngram_tokens = _assert_child(
+            pair.get("ngram"),
+            manifest_sha256=manifest_sha256,
+            arm="ngram",
+            repeat=repeat,
+            manifest=manifest,
+        )
+        baseline_runtime = _runtime_identity(pair["baseline"])
+        ngram_runtime = _runtime_identity(pair["ngram"])
+        if baseline_runtime != ngram_runtime:
+            raise DiagnosticError("baseline and n-gram used different runtime identities")
+        if runtime_reference is None:
+            runtime_reference = baseline_runtime
+        elif runtime_reference != baseline_runtime:
+            raise DiagnosticError("runtime identity changed between repeats")
+        if baseline_history != ngram_history:
+            raise DiagnosticError("baseline and n-gram history outputs diverge before sonnet-012")
+        difference = _first_difference(baseline_tokens, ngram_tokens)
+        if difference != HISTORICAL_DIVERGENCE_INDEX:
+            raise DiagnosticError(
+                "pre-fallback run did not reproduce first divergence at "
+                f"zero-based token {HISTORICAL_DIVERGENCE_INDEX}: got {difference!r}"
+            )
+        if baseline_tokens[difference] != HISTORICAL_BASELINE_TOKEN:
+            raise DiagnosticError("baseline divergence token is not historical token 1875")
+        if ngram_tokens[difference] != HISTORICAL_NGRAM_TOKEN:
+            raise DiagnosticError("n-gram divergence token is not historical token 702")
+        current_baseline = (baseline_history, baseline_tokens)
+        current_ngram = (ngram_history, ngram_tokens)
+        if baseline_reference is None:
+            baseline_reference = current_baseline
+            ngram_reference = current_ngram
+        else:
+            if baseline_reference != current_baseline:
+                raise DiagnosticError("baseline is not repeat-stable")
+            if ngram_reference != current_ngram:
+                raise DiagnosticError("pre-fallback n-gram candidate is not repeat-stable")
+        summaries.append(
+            {
+                "repeat": repeat,
+                "arm_order": expected_order,
+                "history_trace_sha256": _trace_sha256(baseline_history),
+                "common_target_prefix_sha256": _sha256_bytes(
+                    _canonical_json(baseline_tokens[:HISTORICAL_DIVERGENCE_INDEX])
+                ),
+                "baseline_target_sha256": _sha256_bytes(_canonical_json(baseline_tokens)),
+                "ngram_target_sha256": _sha256_bytes(_canonical_json(ngram_tokens)),
+                "first_divergence_zero_based_output_index": difference,
+                "baseline_token_id": baseline_tokens[difference],
+                "ngram_token_id": ngram_tokens[difference],
+                "runtime": baseline_runtime,
+            }
+        )
+    return {
+        "result": "historical_c1_k3_signature_reproduced",
+        "repeated_baseline_stable": True,
+        "repeated_ngram_stable": True,
+        "pairs": summaries,
+    }
+
+
+def _run_parent(args: argparse.Namespace) -> int:
+    manifest = build_manifest(args)
+    manifest_sha256 = _sha256_bytes(_canonical_json(manifest))
+    pairs: list[dict[str, Any]] = []
+    try:
+        with tempfile.TemporaryDirectory(prefix="cx-historical-c1-k3-") as temporary:
+            work_dir = Path(temporary)
+            manifest_path = work_dir / "bound_manifest.json"
+            manifest_path.write_bytes(_canonical_json(manifest))
+            for repeat in range(manifest["repeats"]):
+                arm_order = (
+                    ["baseline", "ngram"]
+                    if repeat % 2 == 0
+                    else ["ngram", "baseline"]
+                )
+                pair: dict[str, Any] = {
+                    "repeat": repeat,
+                    "arm_order": arm_order,
+                }
+                # Store each successful child immediately, so a later child
+                # failure can retain a hash-only observation of prior work.
+                pairs.append(pair)
+                for arm in arm_order:
+                    pair[arm] = _run_child(
+                        manifest_path,
+                        manifest_sha256,
+                        arm=arm,
+                        repeat=repeat,
+                        timeout_seconds=args.timeout_seconds,
+                        memory_fraction=manifest["controlled_engine_profile"][
+                            "memory_fraction"
+                        ],
+                        work_dir=work_dir,
+                    )
+        verification = validate_reproduction(
+            manifest_sha256=manifest_sha256,
+            manifest=manifest,
+            pairs=pairs,
+        )
+    except Exception as exc:
+        try:
+            observed_evidence = _observed_failure_evidence(
+                manifest_sha256=manifest_sha256,
+                manifest=manifest,
+                pairs=pairs,
+            )
+        except Exception as evidence_exc:  # pragma: no cover - fail-closed fallback
+            observed_evidence = {
+                "scope": "unavailable",
+                "finding": "could_not_safely_summarize_completed_child_work",
+                "error": f"{type(evidence_exc).__name__}: {evidence_exc}",
+            }
+        raise DiagnosticRunError(
+            str(exc),
+            manifest_sha256=manifest_sha256,
+            public_manifest=_public_manifest(manifest),
+            observed_evidence=observed_evidence,
+        ) from exc
+    receipt = {
+        "schema": SCHEMA,
+        "status": "PASS",
+        "completed_at_utc": dt.datetime.now(dt.UTC).isoformat(),
+        "claim_scope": "diagnostic_only_no_speed_or_promotion_claim",
+        "speed_claim": "none",
+        "production_enablement": "forbidden_pre_fallback_failure_reproduced",
+        "manifest_sha256": manifest_sha256,
+        "manifest": _public_manifest(manifest),
+        "verification": verification,
+    }
+    _write_new_json(args.output_json, receipt)
+    print(
+        "HISTORICAL_C1_K3_REPRODUCED "
+        f"manifest_sha256={manifest_sha256} receipt={Path(args.output_json).expanduser()}",
+        flush=True,
+    )
+    return 0
+
+
+def _write_failure_receipt(args: argparse.Namespace, error: Exception) -> None:
+    if not args.output_json:
+        return
+    try:
+        receipt: dict[str, Any] = {
+            "schema": SCHEMA,
+            "status": "FAIL",
+            "completed_at_utc": dt.datetime.now(dt.UTC).isoformat(),
+            "claim_scope": "diagnostic_only_no_speed_or_promotion_claim",
+            "speed_claim": "none",
+            "production_enablement": "forbidden",
+            "error": str(error),
+        }
+        if isinstance(error, DiagnosticRunError):
+            receipt.update(
+                {
+                    "manifest_sha256": error.manifest_sha256,
+                    "manifest": error.public_manifest,
+                    "observed_evidence": error.observed_evidence,
+                }
+            )
+        _write_new_json(args.output_json, receipt)
+    except DiagnosticError:
+        return
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--model")
+    parser.add_argument("--model-revision")
+    parser.add_argument("--fixture-manifest")
+    parser.add_argument("--history")
+    parser.add_argument("--corpus")
+    parser.add_argument("--repeats", type=int, default=MIN_REPEATS)
+    parser.add_argument("--max-model-len", type=int, default=HISTORICAL_MAX_MODEL_LEN)
+    parser.add_argument(
+        "--max-num-batched-tokens", type=int, default=CONTROLLED_MAX_NUM_BATCHED_TOKENS
+    )
+    parser.add_argument("--memory-fraction", type=float, default=CONTROLLED_MEMORY_FRACTION)
+    parser.add_argument("--timeout-seconds", type=int, default=240)
+    parser.add_argument("--output-json")
+    # Internal child protocol.  Parent creation of the immutable manifest is
+    # required for any receipt to be trusted.
+    parser.add_argument("--_child-arm", choices=("baseline", "ngram"), help=argparse.SUPPRESS)
+    parser.add_argument("--_child-manifest", help=argparse.SUPPRESS)
+    parser.add_argument("--_child-manifest-sha256", help=argparse.SUPPRESS)
+    parser.add_argument("--_child-output", help=argparse.SUPPRESS)
+    parser.add_argument("--_child-repeat", type=int, help=argparse.SUPPRESS)
+    return parser
+
+
+def _validate_parent_args(args: argparse.Namespace) -> None:
+    missing = [
+        flag
+        for flag, value in (
+            ("--model", args.model),
+            ("--model-revision", args.model_revision),
+            ("--fixture-manifest", args.fixture_manifest),
+            ("--history", args.history),
+            ("--corpus", args.corpus),
+            ("--output-json", args.output_json),
+        )
+        if not value
+    ]
+    if missing:
+        raise DiagnosticError("parent invocation requires " + ", ".join(missing))
+    child_values: Iterable[Any] = (
+        args._child_manifest,
+        args._child_manifest_sha256,
+        args._child_output,
+        args._child_repeat,
+    )
+    if any(value is not None for value in child_values):
+        raise DiagnosticError("internal child flags require --_child-arm")
+
+
+def main(argv: Sequence[str] | None = None) -> int:
+    args = build_parser().parse_args(argv)
+    try:
+        if args._child_arm:
+            return _run_child_main(args)
+        _validate_parent_args(args)
+        return _run_parent(args)
+    except DiagnosticError as exc:
+        if not args._child_arm:
+            _write_failure_receipt(args, exc)
+        prefix = "HISTORICAL_C1_CHILD_FAIL" if args._child_arm else "HISTORICAL_C1_REPRO_FAIL"
+        print(f"{prefix}: {exc}", file=sys.stderr, flush=True)
+        return 1
+    except Exception as exc:  # pragma: no cover - final fail-closed boundary
+        if not args._child_arm:
+            _write_failure_receipt(args, exc)
+        prefix = "HISTORICAL_C1_CHILD_FAIL" if args._child_arm else "HISTORICAL_C1_REPRO_FAIL"
+        print(
+            f"{prefix}: unexpected {type(exc).__name__}: {exc}",
+            file=sys.stderr,
+            flush=True,
+        )
+        return 1
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
