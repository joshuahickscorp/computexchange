+
+
+def _sha(value: bytes) -> str:
+    return hashlib.sha256(value).hexdigest()
+
+
+def _write_jsonl(path: Path, rows: list[dict[str, str]]) -> str:
+    raw = b"".join(
+        json.dumps(row, sort_keys=True, separators=(",", ":")).encode("utf-8") + b"\n"
+        for row in rows
+    )
+    path.write_bytes(raw)
+    return _sha(raw)
+
+
+def _fixture_args(root: Path) -> argparse.Namespace:
+    model = root / "model"
+    model.mkdir()
+    artifacts = {
+        "model.safetensors": b"weights",
+        "tokenizer.json": b"tokenizer",
+        "config.json": b"config",
+    }
+    for name, contents in artifacts.items():
+        (model / name).write_bytes(contents)
+    history_rows = [
+        {"request_id": request_id, "prompt": f"prompt {index}"}
+        for index, request_id in enumerate(endpoint.HISTORICAL_HISTORY_IDS)
+    ]
+    corpus_rows = [
+        {"request_id": f"sonnet-{index:03d}", "prompt": f"prompt {index}"}
+        for index in range(12, 12 + endpoint.HISTORICAL_CORPUS_COUNT)
+    ]
+    history = root / "history.jsonl"
+    corpus = root / "corpus.jsonl"
+    fixture = root / "fixture.json"
+    fixture.write_text(
+        json.dumps(
+            {
+                "schema": endpoint.FIXTURE_SCHEMA,
+                "model": {
+                    "path": str(model.resolve()),
+                    "model_safetensors_sha256": _sha(artifacts["model.safetensors"]),
+                    "tokenizer_json_sha256": _sha(artifacts["tokenizer.json"]),
+                    "config_json_sha256": _sha(artifacts["config.json"]),
+                    "chat_template_sha256": "a" * 64,
+                },
+                "history": {
+                    "request_count": len(history_rows),
+                    "request_order": [row["request_id"] for row in history_rows],
+                    "sha256": _write_jsonl(history, history_rows),
+                },
+                "corpus": {
+                    "request_count": len(corpus_rows),
+                    "request_order": [row["request_id"] for row in corpus_rows],
+                    "sha256": _write_jsonl(corpus, corpus_rows),
+                },
+            }
+        ),
+        encoding="utf-8",
+    )
+    return argparse.Namespace(
+        model=str(model),
