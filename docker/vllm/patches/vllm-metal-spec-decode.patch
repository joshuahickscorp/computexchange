+#!/usr/bin/env python3
+# SPDX-License-Identifier: Apache-2.0
+"""Build the deterministic Sonnet fixture for the Metal n-gram parity gate.
+
+The July 2026 C1 divergence was observed after a deterministic vLLM ``sonnet``
+workload: the Llama 3.2 chat template, 550-token input budget, 200-token shared
+prefix, Python seed zero, and a 150-token greedy continuation.  Benchmark
+captures retained output hashes but not the source prompts.  This utility
+reconstructs that workload from a pinned Sonnet text file and a local, pinned
+tokenizer without consulting the network.
+
+It writes two strict JSONL inputs for ``spec_decode_paired_parity_gate.py``:
+
+* a history containing requests 0..11; and
+* a measured corpus containing requests 12..27 (so the first measured request
+  is the historical failing position).
+
+The accompanying manifest binds source-text, model/tokenizer artifacts,
+generator source, request order, and JSONL digests.  Outputs are write-once;
+reruns never overwrite a fixture or its provenance.
+"""
+
+from __future__ import annotations
+
+import argparse
+import hashlib
+import json
+import os
+from pathlib import Path
+import random
+import sys
+from typing import Any, Protocol, Sequence
+
+
+SCHEMA = "cx.vllm_metal.sonnet_parity_fixture.v1"
+BASE_PROMPT = "Pick as many lines as you can from these poem lines:\n"
+DEFAULT_INPUT_LEN = 550
+DEFAULT_PREFIX_LEN = 200
+DEFAULT_SEED = 0
+DEFAULT_HISTORY_COUNT = 12
+DEFAULT_CORPUS_COUNT = 16
+
+
+class FixtureError(ValueError):
+    """The source inputs cannot safely produce a reproducible fixture."""
+
+
+class _Encoded(Protocol):
+    input_ids: Sequence[int]
+
+
+class _Tokenizer(Protocol):
+    chat_template: str | None
+
+    def __call__(self, value: str) -> _Encoded: ...
+
+    def apply_chat_template(
+        self,
+        messages: list[dict[str, str]],
+        *,
+        add_generation_prompt: bool,
+        tokenize: bool,
+    ) -> str: ...
+
+
+def _canonical_json(value: Any) -> bytes:
+    return json.dumps(
+        value, ensure_ascii=False, sort_keys=True, separators=(",", ":")
+    ).encode("utf-8")
+
+
+def _sha256_bytes(value: bytes) -> str:
+    return hashlib.sha256(value).hexdigest()
+
+
+def _sha256_file(path: Path) -> str:
+    digest = hashlib.sha256()
+    with path.open("rb") as handle:
+        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
+            digest.update(chunk)
+    return digest.hexdigest()
+
+
+def _token_ids(tokenizer: _Tokenizer, text: str, context: str) -> list[int]:
+    try:
+        value = tokenizer(text).input_ids
+    except Exception as exc:  # pragma: no cover - tokenizer implementation boundary
+        raise FixtureError(f"tokenizer failed while encoding {context}") from exc
+    if not isinstance(value, Sequence) or isinstance(value, (str, bytes)):
+        raise FixtureError(f"tokenizer returned malformed IDs for {context}")
+    if not all(isinstance(token, int) for token in value):
+        raise FixtureError(f"tokenizer returned non-integer IDs for {context}")
+    return list(value)
+
+
+def _format_prompt(tokenizer: _Tokenizer, prompt: str, context: str) -> str:
+    try:
+        formatted = tokenizer.apply_chat_template(
+            [{"role": "user", "content": prompt}],
+            add_generation_prompt=True,
+            tokenize=False,
+        )
+    except Exception as exc:  # pragma: no cover - tokenizer implementation boundary
+        raise FixtureError(f"tokenizer failed while formatting {context}") from exc
+    if not isinstance(formatted, str) or not formatted:
+        raise FixtureError(f"tokenizer returned malformed chat text for {context}")
+    return formatted
+
+
+def build_requests(
+    lines: Sequence[str],
+    tokenizer: _Tokenizer,
+    *,
+    input_len: int = DEFAULT_INPUT_LEN,
+    prefix_len: int = DEFAULT_PREFIX_LEN,
+    seed: int = DEFAULT_SEED,
+    count: int = DEFAULT_HISTORY_COUNT + DEFAULT_CORPUS_COUNT,
+) -> tuple[list[dict[str, str]], list[int], dict[str, int | float]]:
+    """Reimplement the pinned vLLM Sonnet sampling algorithm deterministically."""
+
+    if not lines or not all(isinstance(line, str) and line for line in lines):
+        raise FixtureError("Sonnet source must contain non-empty text lines")
+    if input_len <= 0 or prefix_len < 0 or count <= 0:
+        raise FixtureError("input/prefix lengths and count are invalid")
+
+    line_lengths = [_token_ids(tokenizer, line, f"source line {index}") for index, line in enumerate(lines)]
+    average_line_len = sum(len(ids) for ids in line_lengths) / len(line_lengths)
+    if average_line_len <= 0:
+        raise FixtureError("Sonnet source tokenizes to no tokens")
+    base_formatted = _format_prompt(tokenizer, BASE_PROMPT, "base prompt")
+    base_offset = len(_token_ids(tokenizer, base_formatted, "base chat prompt"))
+    if input_len <= base_offset:
+        raise FixtureError(
+            f"input length {input_len} must exceed formatted base length {base_offset}"
+        )
+
+    source_line_count = round((input_len - base_offset) / average_line_len)
+    prefix_line_count = max(round((prefix_len - base_offset) / average_line_len), 0)
+    extra_line_count = source_line_count - prefix_line_count
+    if source_line_count <= 0 or extra_line_count < 0:
+        raise FixtureError("derived Sonnet line counts are invalid")
+    prefix_lines = list(lines[:prefix_line_count])
+    random_source = random.Random(seed)
+    requests: list[dict[str, str]] = []
+    lengths: list[int] = []
+    attempts = 0
+    maximum_attempts = count * 1_000
+    while len(requests) < count:
+        attempts += 1
+        if attempts > maximum_attempts:
+            raise FixtureError("unable to construct enough prompts within the input budget")
+        extra_lines = random_source.choices(lines, k=extra_line_count)
+        prompt = BASE_PROMPT + "".join(prefix_lines + extra_lines)
+        formatted = _format_prompt(tokenizer, prompt, f"request {len(requests)}")
+        prompt_length = len(_token_ids(tokenizer, formatted, f"request {len(requests)}"))
+        if prompt_length > input_len:
+            continue
+        request_index = len(requests)
+        requests.append(
+            {
+                "request_id": f"sonnet-{request_index:03d}",
+                "prompt": formatted,
+            }
+        )
+        lengths.append(prompt_length)
+
+    return requests, lengths, {
+        "average_source_line_tokens": average_line_len,
+        "base_prompt_tokens": base_offset,
+        "source_line_count": source_line_count,
+        "prefix_line_count": prefix_line_count,
+        "extra_line_count": extra_line_count,
+    }
+
+
+def _jsonl_bytes(requests: Sequence[dict[str, str]]) -> bytes:
+    return b"".join(_canonical_json(request) + b"\n" for request in requests)
+
+
+def _write_new(path_value: str | Path, contents: bytes) -> Path:
+    path = Path(path_value).expanduser()
+    try:
+        parent = path.parent.resolve(strict=True)
+    except OSError as exc:
+        raise FixtureError(f"output parent does not exist: {path.parent}") from exc
+    target = parent / path.name
+    try:
+        fd = os.open(target, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
+    except FileExistsError as exc:
+        raise FixtureError(f"refusing to overwrite existing output: {target}") from exc
+    try:
+        with os.fdopen(fd, "wb") as handle:
+            handle.write(contents)
+            handle.flush()
+            os.fsync(handle.fileno())
+    except BaseException:
+        try:
+            target.unlink(missing_ok=True)
+        finally:
+            raise
+    return target
+
+
+def _regular_file(path: Path, label: str) -> Path:
+    try:
+        resolved = path.expanduser().resolve(strict=True)
+    except OSError as exc:
+        raise FixtureError(f"{label} does not exist: {path}") from exc
+    if not resolved.is_file():
+        raise FixtureError(f"{label} must be a regular file: {resolved}")
+    return resolved
+
+
+def _model_artifacts(model_path: Path) -> dict[str, str]:
+    files = {
+        "model_safetensors_sha256": model_path / "model.safetensors",
+        "tokenizer_json_sha256": model_path / "tokenizer.json",
+        "config_json_sha256": model_path / "config.json",
+    }
+    result: dict[str, str] = {}
+    for key, path in files.items():
+        result[key] = _sha256_file(_regular_file(path, key))
+    return result
+
+
+def create_fixture(args: argparse.Namespace) -> dict[str, Any]:
+    sonnet_path = _regular_file(Path(args.sonnet_text), "--sonnet-text")
+    try:
+        model_path = Path(args.model_path).expanduser().resolve(strict=True)
+    except OSError as exc:
+        raise FixtureError(f"--model-path does not exist: {args.model_path}") from exc
+    if not model_path.is_dir():
+        raise FixtureError("--model-path must be a local model directory")
+    output_paths = [
+        Path(args.history_output).expanduser(),
+        Path(args.corpus_output).expanduser(),
+        Path(args.manifest_output).expanduser(),
+    ]
+    if len({path.resolve() for path in output_paths}) != len(output_paths):
+        raise FixtureError("history, corpus, and manifest outputs must differ")
+    if any(path.exists() for path in output_paths):
+        existing = next(path for path in output_paths if path.exists())
+        raise FixtureError(f"refusing to overwrite existing output: {existing}")
+
+    try:
+        from transformers import AutoTokenizer
+    except ImportError as exc:
+        raise FixtureError("this utility requires transformers in the selected environment") from exc
+    tokenizer = AutoTokenizer.from_pretrained(str(model_path), local_files_only=True)
+    lines = sonnet_path.read_text(encoding="utf-8").splitlines(keepends=True)
+    history_count = args.history_count
+    corpus_count = args.corpus_count
+    requests, prompt_lengths, sampler = build_requests(
+        lines,
+        tokenizer,
+        input_len=args.input_len,
+        prefix_len=args.prefix_len,
+        seed=args.seed,
+        count=history_count + corpus_count,
+    )
+    history = requests[:history_count]
+    corpus = requests[history_count:]
+    history_bytes = _jsonl_bytes(history)
+    corpus_bytes = _jsonl_bytes(corpus)
+    manifest = {
+        "schema": SCHEMA,
+        "generator": {
+            "path": str(Path(__file__).resolve()),
+            "sha256": _sha256_file(Path(__file__).resolve()),
+        },
+        "source": {
+            "sonnet_text_path": str(sonnet_path),
+            "sonnet_text_sha256": _sha256_file(sonnet_path),
+        },
+        "model": {
+            "path": str(model_path),
+            **_model_artifacts(model_path),
+            "tokenizer_class": type(tokenizer).__module__ + "." + type(tokenizer).__qualname__,
+            "chat_template_sha256": _sha256_bytes(
+                (tokenizer.chat_template or "").encode("utf-8")
+            ),
+        },
+        "sampler": {
+            "algorithm": "vllm_sonnet_v1_random_choices",
+            "base_prompt_sha256": _sha256_bytes(BASE_PROMPT.encode("utf-8")),
+            "input_len": args.input_len,
+            "prefix_len": args.prefix_len,
+            "seed": args.seed,
+            **sampler,
+        },
+        "history": {
+            "request_count": len(history),
+            "request_order": [request["request_id"] for request in history],
+            "sha256": _sha256_bytes(history_bytes),
+        },
+        "corpus": {
+            "request_count": len(corpus),
+            "request_order": [request["request_id"] for request in corpus],
+            "sha256": _sha256_bytes(corpus_bytes),
+            "prompt_token_lengths": prompt_lengths[history_count:],
+        },
+    }
+    _write_new(args.history_output, history_bytes)
+    _write_new(args.corpus_output, corpus_bytes)
+    _write_new(args.manifest_output, _canonical_json(manifest) + b"\n")
+    return manifest
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--sonnet-text", required=True)
+    parser.add_argument("--model-path", required=True)
+    parser.add_argument("--history-output", required=True)
+    parser.add_argument("--corpus-output", required=True)
+    parser.add_argument("--manifest-output", required=True)
+    parser.add_argument("--input-len", type=int, default=DEFAULT_INPUT_LEN)
+    parser.add_argument("--prefix-len", type=int, default=DEFAULT_PREFIX_LEN)
+    parser.add_argument("--seed", type=int, default=DEFAULT_SEED)
+    parser.add_argument("--history-count", type=int, default=DEFAULT_HISTORY_COUNT)
+    parser.add_argument("--corpus-count", type=int, default=DEFAULT_CORPUS_COUNT)
+    return parser
+
+
+def main(argv: Sequence[str] | None = None) -> int:
+    args = build_parser().parse_args(argv)
+    try:
+        if args.history_count <= 0 or args.corpus_count <= 0:
+            raise FixtureError("history and corpus counts must be positive")
+        manifest = create_fixture(args)
+    except FixtureError as exc:
+        print(f"SONNET_FIXTURE_FAIL: {exc}", file=sys.stderr)
+        return 1
+    print(
+        "SONNET_FIXTURE_PASS "
+        f"history_sha256={manifest['history']['sha256']} "
+        f"corpus_sha256={manifest['corpus']['sha256']}",
+        flush=True,
+    )
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
