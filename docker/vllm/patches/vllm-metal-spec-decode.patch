+def _child_env(memory_fraction: float) -> dict[str, str]:
+    """Force child imports to the installed wheel, never the patched source fork."""
+    env = os.environ.copy()
+    env["PYTHONHASHSEED"] = "0"
+    env["VLLM_ENABLE_V1_MULTIPROCESSING"] = "0"
+    env["VLLM_METAL_USE_PAGED_ATTENTION"] = "1"
+    env["VLLM_METAL_MEMORY_FRACTION"] = str(memory_fraction)
+    env["VLLM_PLUGINS"] = "metal"
+    # A source-build request must not turn an installed-wheel diagnosis into a
+    # different binary identity.
+    env.pop("VLLM_METAL_BUILD_FROM_SOURCE", None)
+    source_root = _repo_root().resolve()
+    entries: list[str] = []
+    for entry in env.get("PYTHONPATH", "").split(os.pathsep):
+        if not entry:
+            continue
+        try:
+            resolved = Path(entry).expanduser().resolve()
+        except OSError:
+            resolved = None
+        if resolved is not None and _path_is_within(resolved, source_root):
+            continue
+        entries.append(entry)
+    if entries:
+        env["PYTHONPATH"] = os.pathsep.join(entries)
+    else:
+        env.pop("PYTHONPATH", None)
+    return env
+
+
+def _child_runtime_binding(expected_ngram_sha256: str) -> dict[str, Any]:
+    """Prove that this child is the historical release-wheel implementation."""
+    import vllm  # noqa: PLC0415 - child-only heavy runtime import
+    import vllm_metal  # noqa: PLC0415 - child-only heavy runtime import
+
+    metal_path = Path(vllm_metal.__file__).resolve()
+    vllm_path = Path(vllm.__file__).resolve()
+    if _path_is_within(metal_path, _source_metal_package_root()):
+        raise DiagnosticError("diagnostic child imported local source Metal code")
+    if "site-packages" not in metal_path.parts:
+        raise DiagnosticError("diagnostic child did not import an installed Metal wheel")
+    metal_version = importlib.metadata.version("vllm-metal")
+    vllm_version = importlib.metadata.version("vllm")
+    if metal_version != HISTORICAL_VLLM_METAL_VERSION:
+        raise DiagnosticError(
+            f"installed vllm-metal version differs: {metal_version!r}"
+        )
+    if vllm_version != HISTORICAL_VLLM_VERSION:
+        raise DiagnosticError(f"installed vLLM version differs: {vllm_version!r}")
+    ngram_path = metal_path.parent / "v1" / "ngram_proposer.py"
+    actual_ngram_sha256 = _sha256_file(_require_regular_file(ngram_path, "wheel ngram proposer"))
+    if actual_ngram_sha256 != expected_ngram_sha256:
+        raise DiagnosticError("installed wheel ngram proposer is not the historical pre-fallback code")
+    extensions = list((metal_path.parent / "metal").glob("_paged_ops*.so"))
+    if not extensions:
+        raise DiagnosticError("installed Metal wheel lacks a paged-attention extension")
+    return {
+        "runtime_import_mode": "installed_wheel_pre_fallback_only",
+        "environment": {
+            key: os.environ.get(key)
+            for key in (
+                "PYTHONHASHSEED",
+                "VLLM_ENABLE_V1_MULTIPROCESSING",
+                "VLLM_METAL_USE_PAGED_ATTENTION",
+                "VLLM_METAL_MEMORY_FRACTION",
+                "VLLM_PLUGINS",
+            )
+        },
+        "vllm_module_path": str(vllm_path),
+        "vllm_metal_module_path": str(metal_path),
+        "vllm_version": vllm_version,
+        "vllm_metal_version": metal_version,
+        "vllm_distribution_record_sha256": _distribution_record_sha256("vllm"),
+        "vllm_metal_distribution_record_sha256": _distribution_record_sha256("vllm-metal"),
+        "ngram_proposer_path": str(ngram_path),
+        "ngram_proposer_sha256": actual_ngram_sha256,
+        "paged_extensions": [
+            {"path": str(path.resolve()), "sha256": _sha256_file(path)}
+            for path in extensions
+        ],
+        "platform": platform.platform(),
+        "machine": platform.machine(),
+    }
+
