+#!/usr/bin/env python3
+# SPDX-License-Identifier: Apache-2.0
+"""Fail-closed, process-isolated parity gate for Metal n-gram speculation.
+
+This tool compares two *fresh* paged-attention greedy engines for every trial:
+
+* ``baseline``: target-only paged greedy decoding;
+* ``ngram``: the same target with the Metal n-gram proposer enabled.
+
+It deliberately records no timings and makes no speed claim.  Its only output
+is a pass/fail parity receipt after exact token-ID comparison.  A pass requires
+all of the following:
+
+* a pinned model revision (a full Hugging Face/git commit SHA);
+* a SHA-256-bound JSONL corpus and its exact request order;
+* an explicit prefix-cache history (disabled, or a SHA-256-bound replay file);
+* process isolation for every baseline/candidate arm and every repeat;
+* C1 and C16 shapes, including the K=1 n-gram control; and
+* exact baseline-vs-n-gram output equality plus repeat stability.
+
+The corpus and optional history files use this deliberately small, strict JSONL
+schema (one request per line):
+
+    {"request_id": "unique-id", "prompt": "text to generate from"}
+
+When ``--prefix-cache-history`` names a JSONL file, each fresh engine replays it
+once before the measured corpus with prefix caching enabled.  The gate then
+requires a real paged cache hit in the measured phase; merely enabling the
+setting is not enough.  ``--prefix-cache-history none`` binds an intentionally
+cold, cache-disabled run.
+
+Example (requires local model access and is intentionally not a quick test):
+
+    PYTHONPATH=$PWD python tools/spec_decode_paired_parity_gate.py \
+      --model Qwen/Qwen3-0.6B \
+      --model-revision 0123456789abcdef0123456789abcdef01234567 \
+      --corpus /absolute/path/pinned_requests.jsonl \
+      --prefix-cache-history /absolute/path/pinned_prefix_history.jsonl \
+      --concurrency 1,16 --ngram-k 1,3 --repeats 3 \
+      --output-json /absolute/path/paired_ngram_parity.json
+
+The child protocol is intentionally private.  Do not invoke ``--_child-arm``
+directly; the parent hashes and validates the full workload manifest before
+accepting a child result.
+"""
+
+from __future__ import annotations
+
+import argparse
+import copy
+import datetime as dt
+import hashlib
+import importlib.metadata
+import json
+import math
+import os
+from dataclasses import dataclass
+from pathlib import Path
+import re
+import subprocess
+import sys
+import tempfile
+from typing import Any, Iterable, Mapping, Sequence
+
+
+SCHEMA = "cx.vllm_metal.paired_ngram_paged_greedy.v1"
+CHILD_SCHEMA = "cx.vllm_metal.paired_ngram_paged_greedy.child.v1"
+PIN_RE = re.compile(r"[0-9a-fA-F]{40}\Z")
+SHA256_RE = re.compile(r"[0-9a-f]{64}\Z")
+REQUIRED_CONCURRENCY = frozenset((1, 16))
+REQUIRED_NGRAM_K = 1
+MAX_CHILD_LOG_CHARS = 4_000
+RUNTIME_IMPORT_MODES = frozenset(("auto", "source", "installed_wheel"))
+METAL_ARTIFACT_MODES = frozenset(
+    ("source_prebuilt", "source_build", "installed_wheel_prebuilt")
+)
+# Keep this deliberately local rather than importing ``vllm_metal.metal.build``
+# in the parent process. The parity protocol keeps all runtime imports inside
+# isolated children. This tuple mirrors build.METALLIB_NAMES and is a release
+# contract: a prebuilt runtime is not complete until every one is present.
+PREBUILT_METALLIB_NAMES = (
+    "paged_attention_v2_kern",
+    "gdn_kern",
+    "paged_mla_kern",
+)
+PROPOSER_TELEMETRY_FIELDS = frozenset(
+    (
+        "execution_mode",
+        "policy",
+        "eligible_requests_bypassed",
+        "single_active_direct_fallbacks",
+        "draft_requests_emitted",
+        "draft_tokens_emitted",
+    )
+)
+
+
+class GateError(RuntimeError):
+    """Raised for a condition that must make the parity gate fail closed."""
+
+
+@dataclass(frozen=True)
+class _PrebuiltMetalArtifacts:
+    """Filesystem verdict for a package's non-JIT Metal runtime."""
+
+    native_extension_available: bool
+    missing_metallibs: tuple[str, ...]
+
+    @property
+    def complete(self) -> bool:
+        return self.native_extension_available and not self.missing_metallibs
+
+
+@dataclass(frozen=True)
+class _RuntimeSelection:
+    """The import identity plus the exact Metal artifact policy it binds."""
+
+    import_mode: str
+    metal_artifact_mode: str
+
+
+def _canonical_json(value: Any) -> bytes:
+    return json.dumps(
+        value,
+        ensure_ascii=False,
+        sort_keys=True,
+        separators=(",", ":"),
+    ).encode("utf-8")
+
+
+def _sha256_bytes(value: bytes) -> str:
+    return hashlib.sha256(value).hexdigest()
+
+
+def _sha256_file(path: Path) -> str:
+    digest = hashlib.sha256()
+    with path.open("rb") as handle:
+        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
+            digest.update(chunk)
+    return digest.hexdigest()
+
+
+def _tool_path() -> Path:
+    return Path(__file__).resolve()
+
+
+def _repo_root() -> Path:
+    return _tool_path().parents[1]
+
+
+def _source_metal_package_root() -> Path:
+    """The importable source package, distinct from a venv below the repo."""
+    return _repo_root() / "vllm_metal"
+
+
+def _path_is_within(path: Path, parent: Path) -> bool:
+    try:
+        path.resolve().relative_to(parent.resolve())
+    except (OSError, ValueError):
+        return False
+    return True
+
+
+def _prebuilt_metal_artifacts(metal_dir: Path) -> _PrebuiltMetalArtifacts:
+    """Inspect every artifact required by the non-JIT Metal runtime.
+
+    A native extension by itself is not a usable prebuilt runtime: ``get_ops``
+    also loads three named ``.metallib`` files during engine startup. Keep this
+    check filesystem-only so parent preflight never imports or initialises MLX.
+    """
+    native_extension_available = any(
+        path.is_file() for path in metal_dir.glob("_paged_ops*.so")
+    )
+    missing_metallibs = tuple(
+        name
+        for name in PREBUILT_METALLIB_NAMES
+        if not (metal_dir / f"{name}.metallib").is_file()
+    )
+    return _PrebuiltMetalArtifacts(
+        native_extension_available=native_extension_available,
+        missing_metallibs=missing_metallibs,
+    )
+
+
+def _source_prebuilt_metal_artifacts() -> _PrebuiltMetalArtifacts:
+    """Return the local source fork's prebuilt Metal artifact verdict."""
+    return _prebuilt_metal_artifacts(_source_metal_package_root() / "metal")
+
+
+def _source_native_extension_available() -> bool:
+    """Whether the local source fork has its native extension at all.
+
+    Retained as a narrow diagnostic field for existing receipts. Runtime
+    selection must use :func:`_source_prebuilt_metal_artifacts` instead, since
+    this single predicate cannot establish that the prebuilt runtime will boot.
+    """
+    return _source_prebuilt_metal_artifacts().native_extension_available
+
+
+def _source_build_requested() -> bool:
+    """Whether the caller explicitly opted into JIT source-build semantics."""
+    return os.environ.get("VLLM_METAL_BUILD_FROM_SOURCE") == "1"
+
+
+def _describe_missing_prebuilt_artifacts(status: _PrebuiltMetalArtifacts) -> str:
+    missing: list[str] = []
+    if not status.native_extension_available:
+        missing.append("_paged_ops*.so")
+    missing.extend(f"{name}.metallib" for name in status.missing_metallibs)
+    return ", ".join(missing) if missing else "none"
+
+
+def _source_tree_sha256() -> str:
+    """Hash executable local Metal sources, including a built extension.
+
+    A Git HEAD cannot bind an intentional uncommitted proposer repair. This
+    digest instead covers every regular source-package file while excluding
+    interpreter caches, which are not part of the executable fork identity.
+    """
+    root = _source_metal_package_root()
+    if not root.is_dir():
+        raise GateError(f"source Metal package is unavailable: {root}")
+    rows: list[dict[str, str]] = []
+    for path in sorted(root.rglob("*")):
+        if not path.is_file() or path.is_symlink() or "__pycache__" in path.parts:
+            continue
+        if path.suffix == ".pyc" or path.name == ".DS_Store":
+            continue
+        rows.append(
+            {
+                "path": path.relative_to(root).as_posix(),
+                "sha256": _sha256_file(path),
+            }
+        )
+    if not rows:
+        raise GateError("source Metal package has no hashable files")
+    return _sha256_bytes(_canonical_json(rows))
+
+
+def _resolve_runtime_selection(
+    requested: str,
+    *,
+    source_prebuilt_artifacts: _PrebuiltMetalArtifacts | None = None,
+    source_build_requested: bool | None = None,
+) -> _RuntimeSelection:
+    """Resolve a runtime and its non-ambiguous Metal artifact policy.
+
+    ``source_prebuilt`` needs both the shared extension and every shader
+    library. ``source_build`` is allowed only through the explicit
+    ``VLLM_METAL_BUILD_FROM_SOURCE=1`` developer opt-in; it intentionally does
+    not claim prebuilt-artifact coverage. ``auto`` uses source only when one of
+    those two conditions holds, otherwise it selects the installed wheel.
+    """
+    if requested not in RUNTIME_IMPORT_MODES:
+        raise GateError(
+            "--runtime-import-mode must be one of: "
+            + ", ".join(sorted(RUNTIME_IMPORT_MODES))
+        )
+    artifacts = (
+        _source_prebuilt_metal_artifacts()
+        if source_prebuilt_artifacts is None
+        else source_prebuilt_artifacts
+    )
+    build_requested = (
+        _source_build_requested()
+        if source_build_requested is None
+        else source_build_requested
+    )
+    if build_requested:
+        source_selection = _RuntimeSelection("source", "source_build")
+    elif artifacts.complete:
+        source_selection = _RuntimeSelection("source", "source_prebuilt")
+    else:
+        source_selection = None
+
+    if requested == "auto":
+        return source_selection or _RuntimeSelection(
+            "installed_wheel", "installed_wheel_prebuilt"
+        )
+    if requested == "source" and source_selection is None:
+        raise GateError(
+            "--runtime-import-mode source requires a complete prebuilt source "
+            "Metal runtime, but the local fork is missing: "
+            f"{_describe_missing_prebuilt_artifacts(artifacts)}. Set "
+            "VLLM_METAL_BUILD_FROM_SOURCE=1 to explicitly compile the source "
+            "runtime, or use --runtime-import-mode installed_wheel (or auto)."
+        )
+    if requested == "source":
+        assert source_selection is not None
+        return source_selection
+    return _RuntimeSelection("installed_wheel", "installed_wheel_prebuilt")
+
+
+def _resolve_runtime_import_mode(
+    requested: str,
+    *,
+    source_native_extension_available: bool | None = None,
+    source_prebuilt_metallibs_available: bool | None = None,
+    source_build_requested: bool | None = None,
+) -> str:
+    """Compatibility wrapper returning only the import identity.
+
+    New callers should retain :func:`_resolve_runtime_selection`'s artifact
+    mode in their manifest. The optional bools exist for inexpensive unit
+    tests; production callers inspect the real source tree.
+    """
+    status: _PrebuiltMetalArtifacts | None = None
+    if (
+        source_native_extension_available is not None
+        or source_prebuilt_metallibs_available is not None
+    ):
+        real = _source_prebuilt_metal_artifacts()
+        status = _PrebuiltMetalArtifacts(
+            native_extension_available=(
+                real.native_extension_available
+                if source_native_extension_available is None
+                else source_native_extension_available
+            ),
+            missing_metallibs=(
+                real.missing_metallibs
+                if source_prebuilt_metallibs_available is None
+                else (() if source_prebuilt_metallibs_available else PREBUILT_METALLIB_NAMES)
+            ),
+        )
+    return _resolve_runtime_selection(
+        requested,
+        source_prebuilt_artifacts=status,
+        source_build_requested=source_build_requested,
+    ).import_mode
+
+
+def _git_head() -> str:
+    """Return the source fork revision without making Git a runtime dependency."""
+    try:
+        return subprocess.check_output(
+            ["git", "rev-parse", "HEAD"],
+            cwd=_repo_root(),
+            text=True,
+            stderr=subprocess.DEVNULL,
+        ).strip()
+    except (OSError, subprocess.CalledProcessError):
+        return "unavailable"
+
+
+def _positive_csv(value: str, label: str) -> list[int]:
+    if not value or not value.strip():
+        raise GateError(f"{label} must be a non-empty comma-separated integer list")
+    try:
+        parsed = [int(item.strip()) for item in value.split(",")]
+    except ValueError as exc:
+        raise GateError(f"{label} must contain only integers: {value!r}") from exc
+    if any(item <= 0 for item in parsed):
+        raise GateError(f"{label} values must be positive: {value!r}")
+    if len(set(parsed)) != len(parsed):
+        raise GateError(f"{label} cannot contain duplicates: {value!r}")
+    return parsed
+
+
+def _require_pinned_revision(value: str) -> str:
+    if not PIN_RE.fullmatch(value):
+        raise GateError(
+            "--model-revision must be a full 40-character Hugging Face/git "
+            "commit SHA; branch names and moving tags are not pinned"
+        )
+    return value.lower()
+
+
+def _read_request_jsonl(path_text: str, label: str) -> dict[str, Any]:
+    try:
+        path = Path(path_text).expanduser().resolve(strict=True)
+    except OSError as exc:
+        raise GateError(f"{label} does not resolve to a readable file: {path_text!r}") from exc
+    if not path.is_file():
+        raise GateError(f"{label} must be a regular file: {path}")
+
+    raw = path.read_bytes()
+    try:
+        lines = raw.decode("utf-8").splitlines()
+    except UnicodeDecodeError as exc:
+        raise GateError(f"{label} must be UTF-8 JSONL: {path}") from exc
+
+    requests: list[dict[str, str]] = []
+    request_ids: set[str] = set()
+    for line_number, line in enumerate(lines, start=1):
+        if not line.strip():
+            raise GateError(f"{label} has a blank line at {line_number}; input is ambiguous")
+        try:
+            record = json.loads(line)
+        except json.JSONDecodeError as exc:
+            raise GateError(f"{label} line {line_number} is not JSON") from exc
+        if not isinstance(record, dict) or set(record) != {"request_id", "prompt"}:
+            raise GateError(
+                f"{label} line {line_number} must contain exactly request_id and prompt"
+            )
+        request_id = record["request_id"]
+        prompt = record["prompt"]
+        if not isinstance(request_id, str) or not request_id:
+            raise GateError(f"{label} line {line_number} has an invalid request_id")
+        if request_id in request_ids:
+            raise GateError(f"{label} repeats request_id {request_id!r}")
+        if not isinstance(prompt, str) or not prompt:
+            raise GateError(f"{label} line {line_number} has an empty or invalid prompt")
+        request_ids.add(request_id)
+        requests.append({"request_id": request_id, "prompt": prompt})
+
+    if not requests:
+        raise GateError(f"{label} must contain at least one request")
+    return {
+        "source_path": str(path),
+        "sha256": _sha256_bytes(raw),
+        "requests": requests,
+        "request_order": [request["request_id"] for request in requests],
+    }
+
+
+def _batch_plan(requests: Sequence[dict[str, str]], concurrency: int) -> list[list[str]]:
+    return [
+        [request["request_id"] for request in requests[index : index + concurrency]]
+        for index in range(0, len(requests), concurrency)
+    ]
+
+
+def _public_manifest(manifest: dict[str, Any]) -> dict[str, Any]:
+    """Return the receipt-safe view; prompt text remains in the private manifest."""
+    return {key: value for key, value in manifest.items() if key != "inputs"}
+
+
+def build_manifest(args: argparse.Namespace) -> dict[str, Any]:
+    """Load and bind every input before any child process starts."""
+    model_revision = _require_pinned_revision(args.model_revision)
+    concurrency = _positive_csv(args.concurrency, "--concurrency")
+    ngram_k = _positive_csv(args.ngram_k, "--ngram-k")
+    if not REQUIRED_CONCURRENCY.issubset(concurrency):
+        raise GateError(
+            "the standard gate requires both C1 and C16; include --concurrency 1,16"
+        )
+    if REQUIRED_NGRAM_K not in ngram_k:
+        raise GateError("the standard gate requires the K=1 n-gram control")
+    if args.repeats < 2:
+        raise GateError("--repeats must be at least 2 to detect instability")
+    if args.max_tokens <= 0:
+        raise GateError("--max-tokens must be positive")
+    if args.max_model_len <= 0:
+        raise GateError("--max-model-len must be positive")
+    if args.max_num_batched_tokens <= 0:
+        raise GateError("--max-num-batched-tokens must be positive")
+    if args.max_num_batched_tokens < max(concurrency):
+        raise GateError("--max-num-batched-tokens must be at least the largest C shape")
+    if not 0.0 < args.memory_fraction <= 1.0:
+        raise GateError("--memory-fraction must be in (0, 1]")
+    if args.timeout_seconds <= 0:
+        raise GateError("--timeout-seconds must be positive")
+    if not 1 <= args.prompt_lookup_min <= args.prompt_lookup_max:
+        raise GateError("prompt lookup bounds must be positive and min must not exceed max")
+    source_prebuilt_artifacts = _source_prebuilt_metal_artifacts()
+    runtime_selection = _resolve_runtime_selection(
+        args.runtime_import_mode,
+        source_prebuilt_artifacts=source_prebuilt_artifacts,
+    )
+
+    corpus = _read_request_jsonl(args.corpus, "--corpus")
+    if len(corpus["requests"]) < max(concurrency):
+        raise GateError(
+            "the corpus must contain at least as many requests as the largest "
+            "concurrency shape so C16 is a real C16 workload"
+        )
+
+    if args.prefix_cache_history == "none":
+        prefix_cache = {
+            "enabled": False,
+            "history_mode": "disabled",
+            "history_source_path": None,
+            "history_sha256": None,
+            "history_request_count": 0,
+            "history_request_order": [],
+        }
+        history_requests: list[dict[str, str]] = []
+    else:
+        history = _read_request_jsonl(args.prefix_cache_history, "--prefix-cache-history")
+        prefix_cache = {
+            "enabled": True,
+            "history_mode": "replay_jsonl_once",
+            "history_source_path": history["source_path"],
+            "history_sha256": history["sha256"],
+            "history_request_count": len(history["requests"]),
+            "history_request_order": history["request_order"],
+        }
+        history_requests = history["requests"]
+
+    return {
+        "schema": SCHEMA,
+        "implementation": {
+            "tool_path": str(_tool_path()),
+            "tool_sha256": _sha256_file(_tool_path()),
+            "fork_git_head": _git_head(),
+            "source_tree_sha256": _source_tree_sha256(),
+        },
+        "model": {
+            "id": args.model,
+            "revision": model_revision,
+            "tokenizer_source": "model",
+            "tokenizer_revision": model_revision,
+        },
+        "corpus": {
+            "source_path": corpus["source_path"],
+            "sha256": corpus["sha256"],
+            "request_count": len(corpus["requests"]),
+            "request_order": corpus["request_order"],
+        },
+        "prefix_cache": prefix_cache,
+        "sampling": {
+            "temperature": 0.0,
+            "top_p": 1.0,
+            "top_k": -1,
+            "max_tokens": args.max_tokens,
+            "ignore_eos": True,
+            "seed": 0,
+        },
+        "engine": {
+            "paged_attention_required": True,
+            "v1_multiprocessing": False,
+            "async_scheduling": False,
+            "memory_fraction": args.memory_fraction,
+            "max_model_len": args.max_model_len,
+            "max_num_batched_tokens": args.max_num_batched_tokens,
+            "prompt_lookup_min": args.prompt_lookup_min,
+            "prompt_lookup_max": args.prompt_lookup_max,
+            "runtime_import_mode": runtime_selection.import_mode,
+            "metal_artifact_mode": runtime_selection.metal_artifact_mode,
+            "source_prebuilt_artifacts": {
+                "native_extension_available": (
+                    source_prebuilt_artifacts.native_extension_available
+                ),
+                "missing_metallibs": list(source_prebuilt_artifacts.missing_metallibs),
+                "complete": source_prebuilt_artifacts.complete,
+            },
+        },
+        "concurrency": concurrency,
+        "ngram_k": ngram_k,
+        "repeats": args.repeats,
+        "batch_plans": {
+            str(shape): {
+                "history": _batch_plan(history_requests, shape),
+                "measurement": _batch_plan(corpus["requests"], shape),
+            }
+            for shape in concurrency
+        },
+        "inputs": {
+            "history_requests": history_requests,
+            "measurement_requests": corpus["requests"],
+        },
+    }
+
+
+def _write_new_json(path_text: str, value: dict[str, Any]) -> None:
+    """Write a receipt once, refusing to overwrite a previous result."""
+    path = Path(path_text).expanduser()
+    try:
+        parent = path.parent.resolve(strict=True)
+    except OSError as exc:
+        raise GateError(f"output parent does not exist: {path.parent}") from exc
+    target = parent / path.name
+    encoded = _canonical_json(value) + b"\n"
+    try:
+        fd = os.open(target, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o600)
+    except FileExistsError as exc:
+        raise GateError(f"refusing to overwrite existing output: {target}") from exc
+    try:
+        with os.fdopen(fd, "wb") as handle:
+            handle.write(encoded)
+            handle.flush()
+            os.fsync(handle.fileno())
+    except BaseException:
+        try:
+            target.unlink(missing_ok=True)
+        finally:
+            raise
+
+
+def _read_json(path: Path, label: str) -> dict[str, Any]:
+    try:
+        value = json.loads(path.read_text(encoding="utf-8"))
+    except (OSError, json.JSONDecodeError) as exc:
+        raise GateError(f"{label} is missing or invalid JSON: {path}") from exc
+    if not isinstance(value, dict):
+        raise GateError(f"{label} must be a JSON object: {path}")
+    return value
+
+
+def _child_env(
+    memory_fraction: float,
+    runtime_import_mode: str,
+    metal_artifact_mode: str,
+) -> dict[str, str]:
+    """Make every arm fresh, paged, and bound to one Metal artifact policy."""
+    env = os.environ.copy()
+    env["PYTHONHASHSEED"] = "0"
+    env["VLLM_ENABLE_V1_MULTIPROCESSING"] = "0"
+    env["VLLM_METAL_USE_PAGED_ATTENTION"] = "1"
+    env["VLLM_METAL_MEMORY_FRACTION"] = str(memory_fraction)
+    source_root = _repo_root().resolve()
+    current_python_path = env.get("PYTHONPATH", "")
+    entries: list[str] = []
+    for entry in current_python_path.split(os.pathsep):
+        # An empty PYTHONPATH entry resolves to cwd, which is the source fork
+        # for children.  Remove it in installed-wheel mode for the same reason
+        # as an explicit source-root entry.
+        if not entry:
+            continue
+        try:
+            resolved = Path(entry).expanduser().resolve()
+        except OSError:
+            resolved = None
+        if resolved is not None and _path_is_within(resolved, source_root):
+            continue
+        entries.append(entry)
+    if runtime_import_mode == "source":
+        entries.insert(0, str(source_root))
+    elif runtime_import_mode != "installed_wheel":
+        raise GateError(f"unsupported resolved runtime mode {runtime_import_mode!r}")
+
+    if metal_artifact_mode == "source_build":
+        if runtime_import_mode != "source":
+            raise GateError("source-build Metal mode requires source runtime imports")
+        # Pin the child rather than relying on an inherited developer shell.
+        env["VLLM_METAL_BUILD_FROM_SOURCE"] = "1"
+    elif metal_artifact_mode == "source_prebuilt":
+        if runtime_import_mode != "source":
+            raise GateError("source-prebuilt Metal mode requires source runtime imports")
+        # A parent-shell opt-in must never turn a prebuilt receipt into a JIT one.
+        env.pop("VLLM_METAL_BUILD_FROM_SOURCE", None)
+    elif metal_artifact_mode == "installed_wheel_prebuilt":
+        if runtime_import_mode != "installed_wheel":
+            raise GateError(
+                "installed-wheel-prebuilt Metal mode requires installed-wheel imports"
+            )
+        # Do not let an explicit source-build shell setting silently compile a
+        # wheel-bound child from site-packages.
+        env.pop("VLLM_METAL_BUILD_FROM_SOURCE", None)
+    else:
+        raise GateError(f"unsupported Metal artifact mode {metal_artifact_mode!r}")
+    if entries:
+        env["PYTHONPATH"] = os.pathsep.join(entries)
+    else:
+        env.pop("PYTHONPATH", None)
+    return env
+
+
+def _run_child(
+    manifest_path: Path,
+    manifest_sha256: str,
+    *,
+    arm: str,
+    concurrency: int,
+    ngram_k: int,
+    repeat: int,
+    timeout_seconds: int,
+    memory_fraction: float,
+    runtime_import_mode: str,
+    metal_artifact_mode: str,
+    work_dir: Path,
+) -> dict[str, Any]:
+    result_path = work_dir / f"{arm}-c{concurrency}-k{ngram_k}-r{repeat}.json"
+    command = [
+        sys.executable,
+        str(_tool_path()),
+        "--_child-arm",
+        arm,
+        "--_child-manifest",
+        str(manifest_path),
+        "--_child-manifest-sha256",
+        manifest_sha256,
+        "--_child-output",
+        str(result_path),
+        "--_child-concurrency",
+        str(concurrency),
+        "--_child-ngram-k",
+        str(ngram_k),
+        "--_child-repeat",
+        str(repeat),
+    ]
+    try:
+        # In installed-wheel mode, ``cwd`` itself is an import search location
+        # on several Python launch paths.  Never run a wheel-bound child from
+        # the source fork or its unbuilt ``vllm_metal`` package can shadow the
+        # wheel even after PYTHONPATH was sanitized.
+        child_cwd = _repo_root() if runtime_import_mode == "source" else work_dir
+        completed = subprocess.run(
+            command,
+            cwd=child_cwd,
+            env=_child_env(
+                memory_fraction,
+                runtime_import_mode,
+                metal_artifact_mode,
+            ),
+            capture_output=True,
+            text=True,
+            timeout=timeout_seconds,
+            check=False,
+        )
+    except subprocess.TimeoutExpired as exc:
+        raise GateError(
+            f"{arm} C{concurrency} K{ngram_k} repeat {repeat} exceeded "
+            f"{timeout_seconds}s"
+        ) from exc
+
+    if completed.returncode != 0:
+        logs = (completed.stdout + "\n" + completed.stderr)[-MAX_CHILD_LOG_CHARS:]
+        raise GateError(
+            f"child {arm} C{concurrency} K{ngram_k} repeat {repeat} failed "
+            f"with exit code {completed.returncode}; tail follows:\n{logs}"
+        )
+    if not result_path.exists():
+        raise GateError(
+            f"child {arm} C{concurrency} K{ngram_k} repeat {repeat} exited "
+            "without a result"
+        )
+    return _read_json(result_path, "child result")
+
+
+def _trace(child_result: dict[str, Any]) -> dict[str, list[dict[str, Any]]]:
+    outputs = child_result.get("outputs")
+    if not isinstance(outputs, dict):
+        raise GateError("child result has no outputs object")
+    trace: dict[str, list[dict[str, Any]]] = {}
+    for phase in ("history", "measurement"):
+        rows = outputs.get(phase)
+        if not isinstance(rows, list):
+            raise GateError(f"child result {phase} outputs are malformed")
+        normalized_rows: list[dict[str, Any]] = []
+        for row in rows:
+            if not isinstance(row, dict):
+                raise GateError(f"child result {phase} row is malformed")
+            request_id = row.get("request_id")
+            token_ids = row.get("token_ids")
+            if not isinstance(request_id, str) or not isinstance(token_ids, list):
+                raise GateError(f"child result {phase} row has invalid fields")
+            if not all(isinstance(token_id, int) for token_id in token_ids):
+                raise GateError(f"child result {phase} has a non-integer token ID")
+            normalized_rows.append({"request_id": request_id, "token_ids": token_ids})
+        trace[phase] = normalized_rows
+    return trace
+
+
+def _trace_digest(child_result: dict[str, Any]) -> str:
+    return _sha256_bytes(_canonical_json(_trace(child_result)))
+
+
+def _validate_proposer_telemetry(
+    value: Any,
+    *,
+    concurrency: int,
+    prefix_cache_enabled: bool,
+) -> dict[str, int | str]:
+    """Validate whether a candidate actually drafted or safely fell back."""
+    if not isinstance(value, Mapping) or set(value) != PROPOSER_TELEMETRY_FIELDS:
+        raise GateError("candidate proposer telemetry is malformed")
+    execution_mode = value.get("execution_mode")
+    policy = value.get("policy")
+    if not isinstance(execution_mode, str) or not isinstance(policy, str):
+        raise GateError("candidate proposer telemetry has invalid mode fields")
+    counters: dict[str, int] = {}
+    for key in (
+        "eligible_requests_bypassed",
+        "single_active_direct_fallbacks",
+        "draft_requests_emitted",
+        "draft_tokens_emitted",
+    ):
+        counter = value.get(key)
+        if type(counter) is not int or counter < 0:
+            raise GateError(f"candidate proposer telemetry has invalid {key}")
+        counters[key] = counter
+    # The retained historical C1/K3 server explicitly disabled prefix caching,
+    # so C1 safety must not depend on that setting.  The source proposer uses
+    # the actual active target-forward shape rather than max_num_seqs.
+    direct_fallback_expected = concurrency == 1
+    if direct_fallback_expected:
+        if (
+            execution_mode != "direct_fallback_only"
+            or policy != "single_active_ngram_direct_only"
+        ):
+            raise GateError("C1 candidate did not use required direct fallback")
+        if counters["draft_requests_emitted"] or counters["draft_tokens_emitted"]:
+            raise GateError("C1 direct fallback emitted speculative drafts")
+        if not counters["single_active_direct_fallbacks"]:
+            raise GateError("C1 fallback did not record a single-active fallback")
+    else:
+        allowed_modes = {"ngram_enabled", "mixed_direct_fallback_and_ngram"}
+        if execution_mode not in allowed_modes or policy != "single_active_ngram_direct_only":
+            raise GateError("non-C1 candidate did not resolve n-gram mode")
+        # An enabled config that never emits a proposal is a target-only run in
+        # disguise.  It can be useful for engine smoke testing, but cannot
+        # validate the speculative proposer seam or support an acceleration
+        # conclusion for this cell.
+        if not counters["draft_requests_emitted"] or not counters["draft_tokens_emitted"]:
+            raise GateError("non-C1 candidate emitted no n-gram drafts")
+        if (
+            execution_mode == "mixed_direct_fallback_and_ngram"
+            and not counters["single_active_direct_fallbacks"]
+        ):
+            raise GateError("mixed fallback telemetry has no single-active fallback")
+    return {
+        "execution_mode": execution_mode,
+        "policy": policy,
+        **counters,
+    }
+
+
+def _first_trace_difference(
+    left: dict[str, list[dict[str, Any]]],
+    right: dict[str, list[dict[str, Any]]],
+) -> str | None:
+    for phase in ("history", "measurement"):
+        left_rows = left[phase]
+        right_rows = right[phase]
+        if len(left_rows) != len(right_rows):
+            return f"{phase} row count differs: {len(left_rows)} != {len(right_rows)}"
+        for row_index, (left_row, right_row) in enumerate(
+            zip(left_rows, right_rows, strict=True)
+        ):
+            if left_row["request_id"] != right_row["request_id"]:
+                return (
+                    f"{phase} request order differs at row {row_index}: "
+                    f"{left_row['request_id']!r} != {right_row['request_id']!r}"
+                )
+            left_tokens = left_row["token_ids"]
+            right_tokens = right_row["token_ids"]
+            if left_tokens != right_tokens:
+                for token_index, (left_token, right_token) in enumerate(
+                    zip(left_tokens, right_tokens, strict=False)
+                ):
+                    if left_token != right_token:
+                        return (
+                            f"{phase} request {left_row['request_id']!r} diverges "
+                            f"at token {token_index}: {left_token} != {right_token}"
+                        )
+                return (
+                    f"{phase} request {left_row['request_id']!r} token length differs: "
+                    f"{len(left_tokens)} != {len(right_tokens)}"
+                )
+    return None
+
+
+def _assert_child_binding(
+    child_result: dict[str, Any],
+    *,
+    manifest_sha256: str,
+    arm: str,
+    concurrency: int,
+    ngram_k: int,
+    repeat: int,
+    expected_history_ids: Sequence[str],
+    expected_measurement_ids: Sequence[str],
+    max_tokens: int,
+    prefix_cache_enabled: bool,
+    memory_fraction: float,
+    max_num_batched_tokens: int,
+    runtime_import_mode: str,
+    metal_artifact_mode: str,
+    source_tree_sha256: str,
+) -> None:
+    if child_result.get("schema") != CHILD_SCHEMA:
+        raise GateError("child result has an unexpected schema")
+    if child_result.get("status") != "PASS":
+        raise GateError("child result did not report PASS")
+    expected = {
+        "manifest_sha256": manifest_sha256,
+        "arm": arm,
+        "concurrency": concurrency,
+        "ngram_k": ngram_k,
+        "repeat": repeat,
+    }
+    for key, value in expected.items():
+        if child_result.get(key) != value:
+            raise GateError(
+                f"child result binding mismatch for {key}: "
+                f"{child_result.get(key)!r} != {value!r}"
+            )
+    runtime = child_result.get("runtime")
+    if not isinstance(runtime, dict):
+        raise GateError("child result has no runtime binding")
+    required_runtime = {
+        "VLLM_ENABLE_V1_MULTIPROCESSING": "0",
+        "VLLM_METAL_USE_PAGED_ATTENTION": "1",
+        "VLLM_METAL_MEMORY_FRACTION": str(memory_fraction),
+        "PYTHONHASHSEED": "0",
+    }
+    for key, value in required_runtime.items():
+        if runtime.get(key) != value:
+            raise GateError(
+                f"child runtime binding mismatch for {key}: "
+                f"{runtime.get(key)!r} != {value!r}"
+            )
+    if runtime.get("runtime_import_mode") != runtime_import_mode:
+        raise GateError("child runtime import mode differs from the manifest")
+    if runtime.get("metal_artifact_mode") != metal_artifact_mode:
+        raise GateError("child Metal artifact mode differs from the manifest")
+    for key in (
+        "vllm_distribution_record_sha256",
+        "vllm_metal_distribution_record_sha256",
+    ):
+        if not isinstance(runtime.get(key), str) or not SHA256_RE.fullmatch(
+            runtime[key]
+        ):
+            raise GateError(f"child runtime has an invalid {key}")
+    metal_module_path = runtime.get("vllm_metal_module_path")
+    if not isinstance(metal_module_path, str) or not metal_module_path:
+        raise GateError("child runtime has no vllm_metal module path")
+    metal_from_source = _path_is_within(
+        Path(metal_module_path), _source_metal_package_root()
+    )
+    if runtime_import_mode == "source" and not metal_from_source:
+        raise GateError("child did not import the requested source Metal runtime")
+    if runtime_import_mode == "installed_wheel" and metal_from_source:
+        raise GateError("child imported source Metal code in installed-wheel mode")
+    runtime_source_tree = runtime.get("source_tree_sha256")
+    if runtime_import_mode == "source":
+        if runtime_source_tree != source_tree_sha256:
+            raise GateError("child source Metal tree differs from the bound fork")
+    elif runtime_source_tree is not None:
+        raise GateError("installed-wheel child unexpectedly reports a source tree hash")
+    cache_hit_start_positions = child_result.get("cache_hit_start_positions")
+    if (
+        not isinstance(cache_hit_start_positions, list)
+        or not all(isinstance(position, int) for position in cache_hit_start_positions)
+    ):
+        raise GateError("child cache-hit trace is malformed")
+    if prefix_cache_enabled:
+        if not any(position > 0 for position in cache_hit_start_positions):
+            raise GateError("prefix-cache child result lacks a measured cache hit")
+    elif cache_hit_start_positions:
+        raise GateError("cache-disabled child result unexpectedly reports cache hits")
+    engine_binding = child_result.get("engine_binding")
+    if not isinstance(engine_binding, dict):
+        raise GateError("child result has no resolved Metal engine binding")
+    if engine_binding.get("use_paged_attention") is not True:
+        raise GateError("child did not resolve Metal paged attention")
+    if engine_binding.get("paged_attention_runtime_installed") is not True:
+        raise GateError("child has no installed paged-attention runtime")
+    if not isinstance(engine_binding.get("paged_block_size"), int) or (
+        engine_binding["paged_block_size"] <= 0
+    ):
+        raise GateError("child paged-attention block size is invalid")
+    if engine_binding.get("max_num_seqs") != concurrency:
+        raise GateError("child resolved max_num_seqs differs from the C shape")
+    if engine_binding.get("max_num_batched_tokens") != max_num_batched_tokens:
+        raise GateError("child resolved max_num_batched_tokens differs from the manifest")
+    actual_fraction = engine_binding.get("memory_fraction")
+    if not isinstance(actual_fraction, (float, int)) or not math.isclose(
+        float(actual_fraction), memory_fraction, rel_tol=0.0, abs_tol=1e-12
+    ):
+        raise GateError("child resolved Metal memory fraction differs from the manifest")
+    telemetry = engine_binding.get("proposer_telemetry")
+    if arm == "baseline":
+        if telemetry is not None:
+            raise GateError("baseline unexpectedly reports speculative proposer telemetry")
+    else:
+        _validate_proposer_telemetry(
+            telemetry,
+            concurrency=concurrency,
+            prefix_cache_enabled=prefix_cache_enabled,
+        )
+    trace = _trace(child_result)
+    actual_history_ids = [row["request_id"] for row in trace["history"]]
+    actual_measurement_ids = [row["request_id"] for row in trace["measurement"]]
+    if actual_history_ids != list(expected_history_ids):
+        raise GateError("child result history request order is not the bound order")
+    if actual_measurement_ids != list(expected_measurement_ids):
+        raise GateError("child result measurement request order is not the bound order")
+    for phase, rows in trace.items():
+        for row in rows:
+            if len(row["token_ids"]) != max_tokens:
+                raise GateError(
+                    f"child {phase} logical work differs for request "
+                    f"{row['request_id']!r}: expected {max_tokens} tokens"
+                )
+
+
+def validate_cell(
+    *,
+    manifest_sha256: str,
+    concurrency: int,
+    ngram_k: int,
+    pairs: Sequence[dict[str, Any]],
+    expected_history_ids: Sequence[str],
+    expected_measurement_ids: Sequence[str],
+    max_tokens: int,
+    prefix_cache_enabled: bool,
+    memory_fraction: float,
+    max_num_batched_tokens: int,
+    runtime_import_mode: str,
+    source_tree_sha256: str,
+    metal_artifact_mode: str = "installed_wheel_prebuilt",
+) -> dict[str, Any]:
+    """Validate paired equality and repeat stability for one C/K cell."""
+    if len(pairs) < 2:
+        raise GateError("a parity cell needs at least two repeats for stability")
+
+    baseline_reference: dict[str, list[dict[str, Any]]] | None = None
+    ngram_reference: dict[str, list[dict[str, Any]]] | None = None
+    summary_pairs: list[dict[str, Any]] = []
+    for pair in pairs:
+        repeat = pair["repeat"]
+        baseline = pair["baseline"]
+        ngram = pair["ngram"]
+        _assert_child_binding(
+            baseline,
+            manifest_sha256=manifest_sha256,
+            arm="baseline",
+            concurrency=concurrency,
+            ngram_k=ngram_k,
+            repeat=repeat,
+            expected_history_ids=expected_history_ids,
+            expected_measurement_ids=expected_measurement_ids,
+            max_tokens=max_tokens,
+            prefix_cache_enabled=prefix_cache_enabled,
+            memory_fraction=memory_fraction,
+            max_num_batched_tokens=max_num_batched_tokens,
+            runtime_import_mode=runtime_import_mode,
+            metal_artifact_mode=metal_artifact_mode,
+            source_tree_sha256=source_tree_sha256,
+        )
+        _assert_child_binding(
+            ngram,
+            manifest_sha256=manifest_sha256,
+            arm="ngram",
+            concurrency=concurrency,
+            ngram_k=ngram_k,
+            repeat=repeat,
+            expected_history_ids=expected_history_ids,
+            expected_measurement_ids=expected_measurement_ids,
+            max_tokens=max_tokens,
+            prefix_cache_enabled=prefix_cache_enabled,
+            memory_fraction=memory_fraction,
+            max_num_batched_tokens=max_num_batched_tokens,
+            runtime_import_mode=runtime_import_mode,
+            metal_artifact_mode=metal_artifact_mode,
+            source_tree_sha256=source_tree_sha256,
+        )
+        baseline_trace = _trace(baseline)
+        ngram_trace = _trace(ngram)
+        difference = _first_trace_difference(baseline_trace, ngram_trace)
+        if difference is not None:
+            raise GateError(
+                f"token divergence in C{concurrency} K{ngram_k} repeat {repeat}: "
+                f"{difference}"
+            )
+        if baseline_reference is None:
+            baseline_reference = baseline_trace
+            ngram_reference = ngram_trace
+        else:
+            baseline_difference = _first_trace_difference(
+                baseline_reference, baseline_trace
+            )
+            if baseline_difference is not None:
+                raise GateError(
+                    f"unstable baseline in C{concurrency} K{ngram_k} repeat {repeat}: "
+                    f"{baseline_difference}"
+                )
+            ngram_difference = _first_trace_difference(ngram_reference, ngram_trace)
+            if ngram_difference is not None:
+                raise GateError(
+                    f"unstable n-gram candidate in C{concurrency} K{ngram_k} "
+                    f"repeat {repeat}: {ngram_difference}"
+                )
+        summary_pairs.append(
+            {
+                "repeat": repeat,
+                "arm_order": pair["arm_order"],
+                "baseline_trace_sha256": _trace_digest(baseline),
+                "ngram_trace_sha256": _trace_digest(ngram),
+                "token_ids_equal": True,
+                "candidate_proposer_telemetry": copy.deepcopy(
+                    ngram["engine_binding"]["proposer_telemetry"]
+                ),
+            }
+        )
+
+    return {
+        "concurrency": concurrency,
+        "ngram_k": ngram_k,
+        "comparison": "exact_token_ids_in_bound_request_order",
+        "baseline_stable_across_repeats": True,
+        "ngram_stable_across_repeats": True,
+        "pairs": summary_pairs,
+    }
+
+
+def _child_runtime_binding() -> dict[str, str]:
+    required = {
+        "VLLM_ENABLE_V1_MULTIPROCESSING": "0",
+        "VLLM_METAL_USE_PAGED_ATTENTION": "1",
+    }
+    for key, expected in required.items():
+        actual = os.environ.get(key)
+        if actual != expected:
+            raise GateError(f"child requires {key}={expected!r}, got {actual!r}")
+    memory_fraction = os.environ.get("VLLM_METAL_MEMORY_FRACTION")
+    if memory_fraction is None:
+        raise GateError("child has no VLLM_METAL_MEMORY_FRACTION binding")
+    return {
+        **required,
+        "VLLM_METAL_MEMORY_FRACTION": memory_fraction,
+        "PYTHONHASHSEED": os.environ.get("PYTHONHASHSEED", ""),
+    }
+
+
+def _distribution_record_sha256(name: str) -> str:
+    try:
+        distribution = importlib.metadata.distribution(name)
+        record = distribution.read_text("RECORD")
+    except importlib.metadata.PackageNotFoundError as exc:
+        raise GateError(f"runtime distribution {name!r} is not installed") from exc
+    if not record:
+        raise GateError(f"runtime distribution {name!r} has no RECORD manifest")
+    return _sha256_bytes(record.encode("utf-8"))
+
+
+def _assert_metal_artifact_mode(
+    metal_dir: Path,
+    *,
+    runtime_import_mode: str,
+    metal_artifact_mode: str,
+    source_build_enabled: bool,
+) -> None:
+    """Reject an artifact/environment combination before an engine is created."""
+    if metal_artifact_mode not in METAL_ARTIFACT_MODES:
+        raise GateError(f"unsupported Metal artifact mode {metal_artifact_mode!r}")
+    expected_import_mode = (
+        "source" if metal_artifact_mode.startswith("source_") else "installed_wheel"
+    )
+    if runtime_import_mode != expected_import_mode:
+        raise GateError(
+            f"Metal artifact mode {metal_artifact_mode!r} conflicts with "
+            f"runtime import mode {runtime_import_mode!r}"
+        )
+    if metal_artifact_mode == "source_build":
+        if not source_build_enabled:
+            raise GateError(
+                "source-build runtime lost VLLM_METAL_BUILD_FROM_SOURCE=1 before "
+                "child preflight"
+            )
+        return
+    if source_build_enabled:
+        raise GateError(
+            f"prebuilt Metal artifact mode {metal_artifact_mode!r} unexpectedly "
+            "has VLLM_METAL_BUILD_FROM_SOURCE=1"
+        )
+    artifacts = _prebuilt_metal_artifacts(metal_dir)
+    if not artifacts.complete:
+        raise GateError(
+            f"{metal_artifact_mode} requires a complete prebuilt Metal runtime, "
+            f"but its package is missing: "
+            f"{_describe_missing_prebuilt_artifacts(artifacts)}"
+        )
+
+
+def _runtime_implementation_binding(
+    runtime_import_mode: str,
+    metal_artifact_mode: str,
+) -> dict[str, str | None]:
+    """Bind module origins and Metal artifact policy before engine startup."""
+    import vllm
+    import vllm_metal
+
+    vllm_path = Path(vllm.__file__ or "").resolve()
+    metal_path = Path(vllm_metal.__file__ or "").resolve()
+    if not vllm_path.is_file() or not metal_path.is_file():
+        raise GateError("runtime modules have no resolvable source files")
+    metal_from_source = _path_is_within(metal_path, _source_metal_package_root())
+    if runtime_import_mode == "source":
+        if not metal_from_source:
+            raise GateError("source runtime mode imported an installed Metal wheel")
+    elif runtime_import_mode == "installed_wheel":
+        if metal_from_source:
+            raise GateError("installed-wheel runtime mode imported local source Metal code")
+    else:
+        raise GateError(f"unsupported resolved runtime mode {runtime_import_mode!r}")
+    _assert_metal_artifact_mode(
+        metal_path.parent / "metal",
+        runtime_import_mode=runtime_import_mode,
+        metal_artifact_mode=metal_artifact_mode,
+        source_build_enabled=_source_build_requested(),
+    )
+    return {
+        "runtime_import_mode": runtime_import_mode,
+        "metal_artifact_mode": metal_artifact_mode,
+        "vllm_module_path": str(vllm_path),
+        "vllm_metal_module_path": str(metal_path),
+        "source_tree_sha256": (
+            _source_tree_sha256() if metal_from_source else None
+        ),
+        "vllm_distribution_record_sha256": _distribution_record_sha256("vllm"),
+        "vllm_metal_distribution_record_sha256": _distribution_record_sha256(
+            "vllm-metal"
+        ),
+    }
+
+
+class _PrefixCacheTrace:
+    """Record real paged prefill start positions while a history is replayed."""
+
+    def __init__(self) -> None:
+        self.start_positions: list[int] = []
+        self._context: Any = None
+        self._original: Any = None
+
+    def __enter__(self) -> "_PrefixCacheTrace":
+        # MetalModelRunner imports this symbol into its own module namespace, so
+        # patching attention.context.prepare_unified would miss real forwards.
+        # The runner global below is the call site used by paged target prefill
+        # and decode on this pinned fork.
+        from vllm_metal.v1 import model_runner
+
+        self._context = model_runner
+        self._original = model_runner.prepare_unified
+
+        def traced_prepare_unified(decode_requests, prefill_requests, block_size):
+            for prefill in prefill_requests:
+                try:
+                    _, _, start_position = prefill
+                except (TypeError, ValueError) as exc:
+                    raise GateError(
+                        "unexpected paged prefill request shape while tracing cache hits"
+                    ) from exc
+                self.start_positions.append(int(start_position))
+            return self._original(decode_requests, prefill_requests, block_size)
+
+        model_runner.prepare_unified = traced_prepare_unified
+        return self
+
+    def __exit__(self, exc_type, exc_value, traceback) -> bool:
+        assert self._context is not None and self._original is not None
+        self._context.prepare_unified = self._original
+        return False
+
+
+def _generate_phase(
+    llm: Any,
+    requests: Sequence[dict[str, str]],
+    *,
+    concurrency: int,
+    sampling_params: Any,
+    max_tokens: int,
+) -> list[dict[str, Any]]:
+    result: list[dict[str, Any]] = []
+    for start in range(0, len(requests), concurrency):
+        batch = requests[start : start + concurrency]
+        prompts = [request["prompt"] for request in batch]
+        outputs = llm.generate(prompts, sampling_params, use_tqdm=False)
+        if len(outputs) != len(batch):
+            raise GateError(
+                f"engine changed batch cardinality: expected {len(batch)}, got {len(outputs)}"
+            )
+        for request, output in zip(batch, outputs, strict=True):
+            if output.prompt != request["prompt"]:
+                raise GateError(
+                    f"engine changed output order for request {request['request_id']!r}"
+                )
+            if len(output.outputs) != 1:
+                raise GateError(
+                    f"engine returned {len(output.outputs)} completions for "
+                    f"request {request['request_id']!r}; expected one"
+                )
+            token_ids = [int(token_id) for token_id in output.outputs[0].token_ids]
+            if len(token_ids) != max_tokens:
+                raise GateError(
+                    f"request {request['request_id']!r} generated {len(token_ids)} "
+                    f"tokens; expected pinned logical work of {max_tokens}"
+                )
+            result.append({"request_id": request["request_id"], "token_ids": token_ids})
+    return result
+
+
+def _assert_engine_binding(
+    llm: Any,
+    *,
+    arm: str,
+    ngram_k: int,
+    prefix_cache_enabled: bool,
+    concurrency: int,
+    max_num_batched_tokens: int,
+    memory_fraction: float,
+) -> dict[str, Any]:
+    config = llm.llm_engine.vllm_config
+    if bool(config.cache_config.enable_prefix_caching) != prefix_cache_enabled:
+        raise GateError("engine prefix-cache setting differs from the bound manifest")
+    if config.scheduler_config.async_scheduling is not False:
+        raise GateError("engine has async scheduling enabled; paired order is not bound")
+    if config.scheduler_config.max_num_seqs != concurrency:
+        raise GateError("engine max_num_seqs differs from the bound C shape")
+    if config.scheduler_config.max_num_batched_tokens != max_num_batched_tokens:
+        raise GateError("engine max_num_batched_tokens differs from the manifest")
+    runner = llm.llm_engine.model_executor.driver_worker.model_runner
+    metal_config = getattr(runner, "metal_config", None)
+    if metal_config is None or metal_config.use_paged_attention is not True:
+        raise GateError("engine did not resolve Metal paged attention")
+    if not math.isclose(
+        float(metal_config.memory_fraction), memory_fraction, rel_tol=0.0, abs_tol=1e-12
+    ):
+        raise GateError("engine resolved a different Metal memory fraction")
+    paged_runtime = getattr(runner, "paged_attention_runtime", None)
+    if paged_runtime is None:
+        raise GateError("engine has no installed paged-attention runtime")
+    paged_block_size = getattr(runner, "_paged_block_size", 0)
+    if not isinstance(paged_block_size, int) or paged_block_size <= 0:
+        raise GateError("engine has an invalid paged-attention block size")
+    engine_binding = {
+        "use_paged_attention": True,
+        "memory_fraction": float(metal_config.memory_fraction),
+        "paged_attention_runtime_installed": True,
+        "paged_attention_runtime_type": (
+            f"{type(paged_runtime).__module__}.{type(paged_runtime).__qualname__}"
+        ),
+        "paged_block_size": paged_block_size,
+        "max_num_seqs": config.scheduler_config.max_num_seqs,
+        "max_num_batched_tokens": config.scheduler_config.max_num_batched_tokens,
+    }
+    speculative_config = config.speculative_config
+    if arm == "baseline":
+        if speculative_config is not None:
+            raise GateError("baseline unexpectedly has speculative decoding enabled")
+        engine_binding["proposer_telemetry"] = None
+        return engine_binding
+    if speculative_config is None or speculative_config.method != "ngram":
+        raise GateError("candidate did not resolve method=ngram")
+    if int(speculative_config.num_speculative_tokens) != ngram_k:
+        raise GateError("candidate K differs from the bound n-gram K")
+    from vllm_metal.v1.ngram_proposer import NgramProposer
+
+    if not isinstance(runner._drafter, NgramProposer):
+        raise GateError("candidate resolved n-gram config but did not install NgramProposer")
+    telemetry_snapshot = getattr(runner._drafter, "telemetry_snapshot", None)
+    if not callable(telemetry_snapshot):
+        raise GateError("candidate n-gram proposer has no parity telemetry")
+    # Snapshot only after history and measurement generation.  Capturing it at
+    # engine construction always yields zero and can make an inert candidate
+    # look like a tested speculative path.
+    engine_binding["proposer_telemetry"] = None
+    return engine_binding
+
+
+def _capture_candidate_proposer_telemetry(
+    llm: Any,
+    *,
+    arm: str,
+    concurrency: int,
+    prefix_cache_enabled: bool,
+) -> dict[str, int | str] | None:
+    """Read cumulative proposal counters only after bound work has completed."""
+    if arm == "baseline":
+        return None
+    runner = llm.llm_engine.model_executor.driver_worker.model_runner
+    from vllm_metal.v1.ngram_proposer import NgramProposer
+
+    if not isinstance(runner._drafter, NgramProposer):
+        raise GateError("candidate lost its Metal NgramProposer before telemetry capture")
+    snapshot = getattr(runner._drafter, "telemetry_snapshot", None)
+    if not callable(snapshot):
+        raise GateError("candidate n-gram proposer has no parity telemetry")
+    return _validate_proposer_telemetry(
+        snapshot(),
+        concurrency=concurrency,
+        prefix_cache_enabled=prefix_cache_enabled,
+    )
+
+
+def _run_child_main(args: argparse.Namespace) -> int:
+    if not all(
+        (
+            args._child_manifest,
+            args._child_manifest_sha256,
+            args._child_output,
+            args._child_concurrency,
+            args._child_ngram_k,
+            args._child_repeat is not None,
+        )
+    ):
+        raise GateError("child invocation is incomplete")
+    manifest_path = Path(args._child_manifest).resolve(strict=True)
+    manifest = _read_json(manifest_path, "child manifest")
+    actual_manifest_sha256 = _sha256_bytes(_canonical_json(manifest))
+    if actual_manifest_sha256 != args._child_manifest_sha256:
+        raise GateError("child manifest SHA-256 does not match the parent binding")
+    if manifest.get("schema") != SCHEMA:
+        raise GateError("child manifest schema is unsupported")
+    concurrency = args._child_concurrency
+    ngram_k = args._child_ngram_k
+    arm = args._child_arm
+    if concurrency not in manifest.get("concurrency", []):
+        raise GateError("child C shape is not in the parent manifest")
+    if ngram_k not in manifest.get("ngram_k", []):
+        raise GateError("child K shape is not in the parent manifest")
+    if not 0 <= args._child_repeat < manifest.get("repeats", 0):
+        raise GateError("child repeat is not in the parent manifest")
+
+    runtime = _child_runtime_binding()
+    # These imports must remain inside the child after its strict environment
+    # binding.  Importing vLLM in the parent would initialize process-global MLX
+    # state and invalidate the isolation guarantee.
+    from vllm import LLM, SamplingParams
+    import vllm
+
+    runtime_implementation = _runtime_implementation_binding(
+        manifest["engine"]["runtime_import_mode"],
+        manifest["engine"]["metal_artifact_mode"],
+    )
+
+    model = manifest["model"]
+    engine = manifest["engine"]
+    prefix_cache = manifest["prefix_cache"]
+    sampling = manifest["sampling"]
+    kwargs: dict[str, Any] = {
+        "model": model["id"],
+        "revision": model["revision"],
+        "tokenizer_revision": model["tokenizer_revision"],
+        "max_model_len": engine["max_model_len"],
+        "max_num_seqs": concurrency,
+        "max_num_batched_tokens": engine["max_num_batched_tokens"],
+        "enable_prefix_caching": prefix_cache["enabled"],
+        "async_scheduling": False,
+    }
+    if arm == "ngram":
+        kwargs["speculative_config"] = {
+            "method": "ngram",
+            "num_speculative_tokens": ngram_k,
+            "prompt_lookup_min": engine["prompt_lookup_min"],
+            "prompt_lookup_max": engine["prompt_lookup_max"],
+        }
+    llm = LLM(**kwargs)
+    engine_binding = _assert_engine_binding(
+        llm,
+        arm=arm,
+        ngram_k=ngram_k,
+        prefix_cache_enabled=prefix_cache["enabled"],
+        concurrency=concurrency,
+        max_num_batched_tokens=engine["max_num_batched_tokens"],
+        memory_fraction=engine["memory_fraction"],
+    )
+    sampling_params = SamplingParams(
+        temperature=sampling["temperature"],
+        top_p=sampling["top_p"],
+        top_k=sampling["top_k"],
+        max_tokens=sampling["max_tokens"],
+        ignore_eos=sampling["ignore_eos"],
+        seed=sampling["seed"],
+        detokenize=False,
+    )
+    inputs = manifest.get("inputs")
+    if not isinstance(inputs, dict):
+        raise GateError("child manifest lacks private input data")
+    history_requests = inputs.get("history_requests")
+    measurement_requests = inputs.get("measurement_requests")
+    if not isinstance(history_requests, list) or not isinstance(measurement_requests, list):
+        raise GateError("child manifest request data is malformed")
+    expected_plan = manifest.get("batch_plans", {}).get(str(concurrency))
+    actual_plan = {
+        "history": _batch_plan(history_requests, concurrency),
+        "measurement": _batch_plan(measurement_requests, concurrency),
+    }
+    if expected_plan != actual_plan:
+        raise GateError("child request batching differs from the bound manifest")
+
+    cache_hit_start_positions: list[int] = []
+    if prefix_cache["enabled"]:
+        with _PrefixCacheTrace() as trace:
+            history_outputs = _generate_phase(
+                llm,
+                history_requests,
+                concurrency=concurrency,
+                sampling_params=sampling_params,
+                max_tokens=sampling["max_tokens"],
+            )
+            measurement_trace_start = len(trace.start_positions)
+            measurement_outputs = _generate_phase(
+                llm,
+                measurement_requests,
+                concurrency=concurrency,
+                sampling_params=sampling_params,
+                max_tokens=sampling["max_tokens"],
+            )
+            cache_hit_start_positions = trace.start_positions[measurement_trace_start:]
+        if not any(start_position > 0 for start_position in cache_hit_start_positions):
+            raise GateError(
+                "bound prefix-cache history produced no measured paged cache hit; "
+                "refusing to treat it as a cache-history parity run"
+            )
+    else:
+        if history_requests:
+            raise GateError("cache-disabled manifest unexpectedly contains a history")
+        history_outputs = []
+        measurement_outputs = _generate_phase(
+            llm,
+            measurement_requests,
+            concurrency=concurrency,
+            sampling_params=sampling_params,
+            max_tokens=sampling["max_tokens"],
+        )
+
+    engine_binding["proposer_telemetry"] = _capture_candidate_proposer_telemetry(
+        llm,
+        arm=arm,
+        concurrency=concurrency,
+        prefix_cache_enabled=prefix_cache["enabled"],
+    )
+
+    result = {
+        "schema": CHILD_SCHEMA,
+        "status": "PASS",
+        "manifest_sha256": actual_manifest_sha256,
+        "arm": arm,
+        "concurrency": concurrency,
+        "ngram_k": ngram_k,
+        "repeat": args._child_repeat,
+        "runtime": {
+            **runtime,
+            **runtime_implementation,
+            "vllm_version": getattr(vllm, "__version__", "unknown"),
+        },
+        "cache_hit_start_positions": cache_hit_start_positions,
+        "engine_binding": engine_binding,
+        "outputs": {
+            "history": history_outputs,
+            "measurement": measurement_outputs,
+        },
+    }
+    _write_new_json(args._child_output, result)
+    print(
+        f"CHILD_PARITY_GATE_PASS arm={arm} C={concurrency} K={ngram_k} "
+        f"repeat={args._child_repeat}",
+        flush=True,
+    )
+    return 0
+
+
+def _run_parent(args: argparse.Namespace) -> int:
+    manifest = build_manifest(args)
+    manifest_sha256 = _sha256_bytes(_canonical_json(manifest))
+    expected_history_ids = manifest["prefix_cache"]["history_request_order"]
+    expected_measurement_ids = manifest["corpus"]["request_order"]
+    cell_summaries: list[dict[str, Any]] = []
+
+    with tempfile.TemporaryDirectory(prefix="cx-vllm-ngram-parity-") as temporary:
+        work_dir = Path(temporary)
+        manifest_path = work_dir / "bound_manifest.json"
+        manifest_path.write_bytes(_canonical_json(manifest) + b"\n")
+        for concurrency in manifest["concurrency"]:
+            for ngram_k in manifest["ngram_k"]:
+                pairs: list[dict[str, Any]] = []
+                for repeat in range(manifest["repeats"]):
+                    # Alternate launch order.  This is not a performance protocol;
+                    # it simply prevents one arm always seeing the same host phase.
+                    arm_order = (
+                        ("baseline", "ngram")
+                        if repeat % 2 == 0
+                        else ("ngram", "baseline")
+                    )
+                    outputs: dict[str, dict[str, Any]] = {}
+                    for arm in arm_order:
+                        outputs[arm] = _run_child(
+                            manifest_path,
+                            manifest_sha256,
+                            arm=arm,
+                            concurrency=concurrency,
+                            ngram_k=ngram_k,
+                            repeat=repeat,
+                            timeout_seconds=args.timeout_seconds,
+                            memory_fraction=manifest["engine"]["memory_fraction"],
+                            runtime_import_mode=manifest["engine"][
+                                "runtime_import_mode"
+                            ],
+                            metal_artifact_mode=manifest["engine"][
+                                "metal_artifact_mode"
+                            ],
+                            work_dir=work_dir,
+                        )
+                    pairs.append(
+                        {
+                            "repeat": repeat,
+                            "arm_order": list(arm_order),
+                            "baseline": outputs["baseline"],
+                            "ngram": outputs["ngram"],
+                        }
+                    )
+                cell_summaries.append(
+                    validate_cell(
+                        manifest_sha256=manifest_sha256,
+                        concurrency=concurrency,
+                        ngram_k=ngram_k,
+                        pairs=pairs,
+                        expected_history_ids=expected_history_ids,
+                        expected_measurement_ids=expected_measurement_ids,
+                        max_tokens=manifest["sampling"]["max_tokens"],
+                        prefix_cache_enabled=manifest["prefix_cache"]["enabled"],
+                        memory_fraction=manifest["engine"]["memory_fraction"],
+                        max_num_batched_tokens=manifest["engine"][
+                            "max_num_batched_tokens"
+                        ],
+                        runtime_import_mode=manifest["engine"]["runtime_import_mode"],
+                        source_tree_sha256=manifest["implementation"][
+                            "source_tree_sha256"
+                        ],
+                        metal_artifact_mode=manifest["engine"]["metal_artifact_mode"],
+                    )
+                )
+
+    receipt = {
+        "schema": SCHEMA,
+        "status": "PASS",
+        "completed_at_utc": dt.datetime.now(dt.UTC).isoformat(),
+        "manifest_sha256": manifest_sha256,
+        "manifest": _public_manifest(manifest),
+        "verification": {
+            "process_isolated_per_arm_and_repeat": True,
+            "comparison": "exact_token_ids",
+            "timing_collected": False,
+            "speed_claim": "none",
+            "cells": cell_summaries,
+        },
+    }
+    _write_new_json(args.output_json, receipt)
+    print(
+        "PARITY_GATE_PASS "
+        f"cells={len(cell_summaries)} manifest_sha256={manifest_sha256} "
+        f"receipt={Path(args.output_json).expanduser()}",
+        flush=True,
+    )
+    return 0
+
+
+def _write_failure_receipt(args: argparse.Namespace, error: Exception) -> None:
+    if not args.output_json:
+        return
+    try:
+        _write_new_json(
+            args.output_json,
+            {
+                "schema": SCHEMA,
+                "status": "FAIL",
+                "completed_at_utc": dt.datetime.now(dt.UTC).isoformat(),
+                "error": str(error),
+                "timing_collected": False,
+                "speed_claim": "none",
+            },
+        )
+    except GateError:
+        # Preserve the original gate failure; a pre-existing output must never
+        # be overwritten merely to record another failure.
+        return
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(
+        description=__doc__,
+        formatter_class=argparse.RawDescriptionHelpFormatter,
+    )
+    parser.add_argument("--model", help="Hugging Face model ID resolved at --model-revision")
+    parser.add_argument(
+        "--model-revision",
+        help="Required full immutable Hugging Face/git commit SHA",
+    )
+    parser.add_argument("--corpus", help="Strict request_id/prompt JSONL corpus")
+    parser.add_argument(
+        "--prefix-cache-history",
+        default="none",
+        help="Strict JSONL replay file, or literal 'none' for a cold cache-disabled run",
+    )
+    parser.add_argument(
+        "--concurrency",
+        default="1,16",
+        help="Comma-separated C shapes; standard gate requires C1 and C16 (default: 1,16)",
+    )
+    parser.add_argument(
+        "--ngram-k",
+        default="1,3",
+        help="Comma-separated n-gram K values; standard gate requires K=1 (default: 1,3)",
+    )
+    parser.add_argument(
+        "--repeats",
+        type=int,
+        default=3,
+        help="Fresh paired repeats per C/K cell; at least 2 (default: 3)",
+    )
+    parser.add_argument("--max-tokens", type=int, default=32)
+    parser.add_argument("--max-model-len", type=int, default=2048)
+    parser.add_argument("--max-num-batched-tokens", type=int, default=4096)
+    parser.add_argument("--memory-fraction", type=float, default=0.6)
+    parser.add_argument("--prompt-lookup-min", type=int, default=2)
+    parser.add_argument("--prompt-lookup-max", type=int, default=3)
+    parser.add_argument(
+        "--runtime-import-mode",
+        choices=sorted(RUNTIME_IMPORT_MODES),
+        default="auto",
+        help=(
+            "Metal implementation to bind: source requires a complete local "
+            "prebuilt runtime (.so plus all .metallib files), unless "
+            "VLLM_METAL_BUILD_FROM_SOURCE=1 explicitly selects source build; "
+            "auto uses the installed wheel when local prebuilt artifacts are partial"
+        ),
+    )
+    parser.add_argument(
+        "--timeout-seconds",
+        type=int,
+        default=1800,
+        help="Per fresh child process timeout (default: 1800)",
+    )
+    parser.add_argument(
+        "--output-json",
+        help="New receipt path; the gate refuses to overwrite an existing file",
+    )
+
+    # Internal-only child protocol.  Parent validation is what makes an arm a
+    # member of a particular immutable workload; direct child use is unsupported.
+    parser.add_argument("--_child-arm", choices=("baseline", "ngram"), help=argparse.SUPPRESS)
+    parser.add_argument("--_child-manifest", help=argparse.SUPPRESS)
+    parser.add_argument("--_child-manifest-sha256", help=argparse.SUPPRESS)
+    parser.add_argument("--_child-output", help=argparse.SUPPRESS)
+    parser.add_argument("--_child-concurrency", type=int, help=argparse.SUPPRESS)
+    parser.add_argument("--_child-ngram-k", type=int, help=argparse.SUPPRESS)
+    parser.add_argument("--_child-repeat", type=int, help=argparse.SUPPRESS)
+    return parser
+
+
+def _validate_parent_args(args: argparse.Namespace) -> None:
+    missing = [
+        flag
+        for flag, value in (
+            ("--model", args.model),
+            ("--model-revision", args.model_revision),
+            ("--corpus", args.corpus),
+            ("--output-json", args.output_json),
+        )
+        if not value
+    ]
+    if missing:
+        raise GateError(f"parent invocation requires {', '.join(missing)}")
+    child_values: Iterable[Any] = (
+        args._child_manifest,
+        args._child_manifest_sha256,
+        args._child_output,
+        args._child_concurrency,
+        args._child_ngram_k,
+        args._child_repeat,
+    )
+    if any(value is not None for value in child_values):
+        raise GateError("internal child flags require --_child-arm")
+
+
+def main(argv: Sequence[str] | None = None) -> int:
+    args = build_parser().parse_args(argv)
+    try:
+        if args._child_arm:
+            return _run_child_main(args)
+        _validate_parent_args(args)
+        return _run_parent(args)
+    except GateError as exc:
+        if not args._child_arm:
+            _write_failure_receipt(args, exc)
+        prefix = "CHILD_PARITY_GATE_FAIL" if args._child_arm else "PARITY_GATE_FAIL"
+        print(f"{prefix}: {exc}", file=sys.stderr, flush=True)
+        return 1
+    except Exception as exc:  # pragma: no cover - final fail-closed boundary
+        if not args._child_arm:
+            _write_failure_receipt(args, exc)
+        prefix = "CHILD_PARITY_GATE_FAIL" if args._child_arm else "PARITY_GATE_FAIL"
+        print(f"{prefix}: unexpected {type(exc).__name__}: {exc}", file=sys.stderr, flush=True)
+        return 1
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
