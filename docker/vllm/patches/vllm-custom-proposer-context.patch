+CUSTOM_PROPOSER_CONTEXT_API_VERSION = 1
+
+
+@dataclass(frozen=True, slots=True)
+class CustomProposerContext:
+    """Ephemeral, read-only view of one speculative proposal step.
+
+    The legacy custom proposer API only receives CPU token history and KV slot
+    mappings.  Context-aware proposers additionally need target-side tensors,
+    sampling state, and scheduler budgets to avoid reconstructing or copying
+    state that the model runner already owns.
+
+    Tensor and metadata objects are borrowed from the runner for the duration
+    of ``propose_with_context``. Implementations must not mutate or retain
+    them after the call. The ``api_version`` class attribute is the stable
+    compatibility discriminator for out-of-tree proposers.
+    """
+
+    api_version: ClassVar[int] = CUSTOM_PROPOSER_CONTEXT_API_VERSION
+
+    request_ids: tuple[str, ...]
+    num_spec_tokens_to_schedule: Any
+    sampled_token_ids: Any
+    num_tokens_no_spec: Any
+    token_ids_cpu: Any
+    scheduler_output: Any
+    sampling_metadata: Any
+    hidden_states: Any
+    sample_hidden_states: Any
+    aux_hidden_states: Any
+    spec_decode_metadata: Any
+    common_attn_metadata: Any
+    slot_mappings: Any
+
+
+def supports_context_api(proposer: Any) -> bool:
+    """Return whether a custom proposer implements the v1 context API."""
+
+    return callable(getattr(proposer, "propose_with_context", None))
+
+
+def invoke_custom_proposer(
+    proposer: Any,
+    context: CustomProposerContext,
+):
+    """Invoke a context-aware proposer, falling back to the legacy API."""
+
+    if supports_context_api(proposer):
+        return proposer.propose_with_context(context)
+
+    if not isinstance(context.sampled_token_ids, list):
+        raise TypeError(
+            "Legacy custom proposers require CPU sampled_token_ids; implement "
+            "propose_with_context(context) to receive GPU-resident samples."
+        )
+    return proposer.propose(
+        context.sampled_token_ids,
+        context.num_tokens_no_spec,
+        context.token_ids_cpu,
+        slot_mappings=context.slot_mappings,
+    )
+
+
