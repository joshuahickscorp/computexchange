+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+
+import sys
+from types import ModuleType, SimpleNamespace
+from typing import Any
+
+import pytest
+
+from vllm.v1.spec_decode.custom_class_proposer import (
+    CUSTOM_PROPOSER_CONTEXT_API_VERSION,
+    CustomProposerContext,
+    create_custom_proposer,
+    invoke_custom_proposer,
+    supports_context_api,
+)
+
+
+def make_context(*, sampled_token_ids: Any) -> CustomProposerContext:
+    return CustomProposerContext(
+        request_ids=("request-0",),
+        num_spec_tokens_to_schedule=(3,),
+        sampled_token_ids=sampled_token_ids,
+        num_tokens_no_spec=(4,),
+        token_ids_cpu=((1, 2, 3, 4),),
+        scheduler_output=object(),
+        sampling_metadata=object(),
+        hidden_states=object(),
+        sample_hidden_states=object(),
+        aux_hidden_states=object(),
+        spec_decode_metadata=object(),
+        common_attn_metadata=object(),
+        slot_mappings=object(),
+    )
+
+
+def test_context_proposer_receives_full_versioned_context() -> None:
+    class ContextProposer:
+        def __init__(self) -> None:
+            self.received: CustomProposerContext | None = None
+
+        def propose_with_context(
+            self, context: CustomProposerContext
+        ) -> list[list[int]]:
+            self.received = context
+            return [[17, 18, 19]]
+
+    proposer = ContextProposer()
+    context = make_context(sampled_token_ids=object())
+
+    assert supports_context_api(proposer)
+    assert invoke_custom_proposer(proposer, context) == [[17, 18, 19]]
+    assert proposer.received is context
+    assert context.api_version == CUSTOM_PROPOSER_CONTEXT_API_VERSION
+
+
+def test_loader_accepts_context_only_proposer(monkeypatch: pytest.MonkeyPatch) -> None:
+    module = ModuleType("context_only_proposer")
+
+    class ContextOnlyProposer:
+        def __init__(self, vllm_config: Any) -> None:
+            self.vllm_config = vllm_config
+
+        def propose_with_context(
+            self, context: CustomProposerContext
+        ) -> list[list[int]]:
+            return [[context.api_version]]
+
+    module.ContextOnlyProposer = ContextOnlyProposer  # type: ignore[attr-defined]
+    monkeypatch.setitem(sys.modules, module.__name__, module)
+    config = SimpleNamespace(
+        speculative_config=SimpleNamespace(
+            model="context_only_proposer.ContextOnlyProposer",
+            num_speculative_tokens=3,
+        )
+    )
+
+    proposer = create_custom_proposer(config)
+
+    assert isinstance(proposer, ContextOnlyProposer)
+    assert proposer.vllm_config is config
+
+
+def test_legacy_proposer_keeps_original_call_shape() -> None:
+    class LegacyProposer:
+        def __init__(self) -> None:
+            self.received: tuple[Any, ...] | None = None
+
+        def propose(
+            self,
+            sampled_token_ids: list[list[int]],
+            num_tokens_no_spec: Any,
+            token_ids_cpu: Any,
+            *,
+            slot_mappings: Any,
+        ) -> list[list[int]]:
+            self.received = (
+                sampled_token_ids,
+                num_tokens_no_spec,
+                token_ids_cpu,
+                slot_mappings,
+            )
+            return [[7]]
+
+    proposer = LegacyProposer()
+    samples = [[5]]
+    context = make_context(sampled_token_ids=samples)
+
+    assert not supports_context_api(proposer)
+    assert invoke_custom_proposer(proposer, context) == [[7]]
+    assert proposer.received == (
+        samples,
+        context.num_tokens_no_spec,
+        context.token_ids_cpu,
+        context.slot_mappings,
+    )
+
+
+def test_legacy_proposer_rejects_gpu_resident_samples() -> None:
+    class LegacyProposer:
+        def propose(self, *args: Any, **kwargs: Any) -> list[list[int]]:
+            raise AssertionError("legacy proposer must not be called")
+
+    with pytest.raises(TypeError, match="propose_with_context"):
+        invoke_custom_proposer(
+            LegacyProposer(),
+            make_context(sampled_token_ids=object()),
+        )
