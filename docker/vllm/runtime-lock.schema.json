{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://computexchange.invalid/schemas/vllm-runtime-lock-v1.json",
  "title": "Compute Exchange vLLM runtime lock",
  "description": "A fail-closed, reproducible identity for an isolated vLLM speculative-decoding candidate.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "runtime",
    "model",
    "execution",
    "speculative_decoding",
    "sampling",
    "canary"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "status": {
      "enum": ["candidate", "production"]
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vllm_version",
        "vllm_commit",
        "container_image",
        "container_index_digest",
        "container_platform",
        "wheel_sha256",
        "source_sdist_sha256",
        "cuda_runtime",
        "torch_version"
      ],
      "properties": {
        "vllm_version": {
          "const": "0.24.0"
        },
        "vllm_commit": {
          "const": "ee0da84ab9e04ac7610e28580af62c365e898389"
        },
        "container_image": {
          "const": "vllm/vllm-openai@sha256:f9de5cd9fa907fbf6dbba691eb7db095d48ad58ea283e3eba7142f9a91e186e8"
        },
        "container_index_digest": {
          "const": "sha256:251eba5cc7c12fed0b75da22a9240e582b1c9e39f6fbc064f86781b963bd814f"
        },
        "container_platform": {
          "const": "linux/amd64"
        },
        "wheel_sha256": {
          "const": "2d2831aeba311292250df0132dbc4d8e9f42c654536eaec48e6fe58acb1822cf"
        },
        "source_sdist_sha256": {
          "const": "0862453adc1f3339f1a0c9dca1179c34d6ed6e118f87b6e5bddd120af614ac66"
        },
        "cuda_runtime": {
          "const": "13.0.2"
        },
        "torch_version": {
          "const": "2.11.0"
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "catalog_id",
        "repository",
        "revision",
        "artifact_filename",
        "artifact_sha256",
        "tokenizer_repository",
        "tokenizer_revision",
        "served_model_name"
      ],
      "properties": {
        "catalog_id": {
          "const": "llama-3.2-1b-instruct-q4"
        },
        "repository": {
          "const": "unsloth/Llama-3.2-1B-Instruct-GGUF"
        },
        "revision": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "artifact_filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]*\\.gguf$",
          "not": {
            "pattern": "(?:REQUIRED|PLACEHOLDER|CHANGEME|UNKNOWN|TODO|TBD)"
          }
        },
        "artifact_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "tokenizer_repository": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$",
          "not": {
            "pattern": "(?:REQUIRED|PLACEHOLDER|CHANGEME|UNKNOWN|TODO|TBD)"
          }
        },
        "tokenizer_revision": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "served_model_name": {
          "const": "llama-3.2-1b-instruct-q4"
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weight_format",
        "quantization",
        "dtype",
        "tensor_parallel_size",
        "pipeline_parallel_size",
        "data_parallel_size",
        "resolved_kv_cache_dtype",
        "max_model_len",
        "max_num_seqs",
        "max_num_batched_tokens",
        "gpu_memory_utilization",
        "seed",
        "trust_remote_code",
        "attention",
        "compilation",
        "network"
      ],
      "properties": {
        "weight_format": {
          "const": "gguf"
        },
        "quantization": {
          "const": "q4_k_m"
        },
        "dtype": {
          "const": "float16"
        },
        "tensor_parallel_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        },
        "pipeline_parallel_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        },
        "data_parallel_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        },
        "resolved_kv_cache_dtype": {
          "enum": ["float16", "bfloat16", "fp8_e4m3", "fp8_e5m2"]
        },
        "max_model_len": {
          "type": "integer",
          "minimum": 128,
          "maximum": 131072
        },
        "max_num_seqs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4096
        },
        "max_num_batched_tokens": {
          "type": "integer",
          "minimum": 128,
          "maximum": 1048576
        },
        "gpu_memory_utilization": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "seed": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647
        },
        "trust_remote_code": {
          "const": false
        },
        "attention": {
          "type": "object",
          "additionalProperties": false,
          "required": ["backend", "flash_attn_version"],
          "properties": {
            "backend": {
              "enum": ["FLASH_ATTN", "FLASHINFER", "TRITON_ATTN"]
            },
            "flash_attn_version": {
              "type": "integer",
              "minimum": 2,
              "maximum": 4
            }
          }
        },
        "compilation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cudagraph_mode", "mode"],
          "properties": {
            "cudagraph_mode": {
              "enum": ["NONE", "FULL", "PIECEWISE", "FULL_AND_PIECEWISE"]
            },
            "mode": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3
            }
          }
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "required": ["host", "port"],
          "properties": {
            "host": {
              "const": "127.0.0.1"
            },
            "port": {
              "type": "integer",
              "minimum": 1024,
              "maximum": 65535
            }
          }
        }
      }
    },
    "speculative_decoding": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "method",
            "num_speculative_tokens",
            "prompt_lookup_min",
            "prompt_lookup_max"
          ],
          "properties": {
            "enabled": {
              "const": true
            },
            "method": {
              "const": "ngram"
            },
            "num_speculative_tokens": {
              "type": "integer",
              "minimum": 1,
              "maximum": 16
            },
            "prompt_lookup_min": {
              "type": "integer",
              "minimum": 1,
              "maximum": 32
            },
            "prompt_lookup_max": {
              "type": "integer",
              "minimum": 1,
              "maximum": 32
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "method", "num_speculative_tokens"],
          "properties": {
            "enabled": {
              "const": true
            },
            "method": {
              "const": "suffix"
            },
            "num_speculative_tokens": {
              "type": "integer",
              "minimum": 1,
              "maximum": 16
            }
          }
        }
      ]
    },
    "sampling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "temperature",
        "top_p",
        "top_k",
        "seed",
        "n",
        "presence_penalty",
        "frequency_penalty"
      ],
      "properties": {
        "temperature": {
          "const": 0
        },
        "top_p": {
          "const": 1
        },
        "top_k": {
          "const": -1
        },
        "seed": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647
        },
        "n": {
          "const": 1
        },
        "presence_penalty": {
          "const": 0
        },
        "frequency_penalty": {
          "const": 0
        }
      }
    },
    "canary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt",
        "prompt_sha256",
        "max_tokens",
        "expected_completion_sha256",
        "warmup_requests",
        "measured_requests",
        "minimum_acceptance_rate",
        "minimum_output_match_rate"
      ],
      "properties": {
        "prompt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 16384
        },
        "prompt_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 512
        },
        "expected_completion_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "warmup_requests": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "measured_requests": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000
        },
        "minimum_acceptance_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "minimum_output_match_rate": {
          "const": 1
        }
      }
    }
  }
}
