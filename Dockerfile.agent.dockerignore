# Build context for the CUDA agent image (docker build -f Dockerfile.agent .).
# Keep ONLY agent/ source — drop the 4.4 GB build dir and every unrelated tree.
# BuildKit uses this file in preference to .dockerignore when building Dockerfile.agent.

agent/target/
**/*.test

# Everything that isn't the agent.
control/
db/
cli/
sdk/
web/
macapp/
proto/
scripts/
docs/
.git/
.github/

# Secrets / local config — never in an image layer.
.env
.env.local

# Protected / heavy assets.
models/
data/
*.gguf
*.safetensors
*.mlx
*.bin
*.wav

# Docs + cruft.
*.md
.DS_Store
.idea/
.vscode/
*.swp
*~
